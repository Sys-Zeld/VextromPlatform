<%- include("partials/head", { pageTitle }) %>

<section class="token-console">
  <div class="card app-card token-hero-card">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">VEXTROM PLATFORM</span>
        <h1 class="h4 app-card-title mb-1">Service Hub</h1>
        <p class="text-muted mb-0">Entrada principal dos modulos do ecossistema SpecFlow.</p>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <% moduleCards.forEach((moduleItem) => { %>
      <div class="col-12 col-md-6 col-xl-4">
        <article class="card app-card h-100 module-hub-card module-hub-card--<%= moduleItem.key %>">
          <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex justify-content-between align-items-start gap-2">
              <div class="d-flex align-items-start gap-2">
                <span class="module-hub-icon material-symbols-outlined" aria-hidden="true">
                  <%= moduleItem.key === "specflow"
                    ? "schema"
                    : (moduleItem.key === "module-spec"
                      ? "tune"
                      : (moduleItem.key === "report-service" ? "monitoring" : "build_circle")) %>
                </span>
                <h2 class="h5 app-card-title mb-0"><%= moduleItem.name %></h2>
              </div>
              <div class="text-end">
                <span class="badge text-bg-<%= moduleItem.statusVariant %>"><%= moduleItem.status %></span>
                <div class="small text-muted mt-1"><%= moduleItem.moduleVersion %></div>
              </div>
            </div>
            <p class="text-muted mb-0"><%= moduleItem.description %></p>
            <div class="mt-auto">
              <% if (moduleItem.href) { %>
                <a class="btn btn-outline-primary btn-sm" href="<%= moduleItem.href %>"><%= moduleItem.cta %></a>
              <% } else { %>
                <button class="btn btn-outline-secondary btn-sm" type="button" disabled><%= moduleItem.cta %></button>
              <% } %>
            </div>
          </div>
        </article>
      </div>
    <% }) %>
  </div>
</section>

<%- include("partials/footer") %>
