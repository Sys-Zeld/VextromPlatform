<!doctype html>
<html lang="<%= lang === 'pt' ? 'pt-BR' : 'en' %>">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="https://vextrom.com.br/wp-content/uploads/fbrfg/favicon-32x32.png" />
    <title><%= pageTitle %> | <%= t("app.titleSuffix") %></title>
    <script>
      (function () {
        var storedTheme = null;
        try {
          storedTheme = localStorage.getItem("app_theme");
        } catch (_err) {
          storedTheme = null;
        }
        var allowedThemes = ["soft", "vextrom", "xvextrom", "xvetrom"];
        var theme = allowedThemes.indexOf(storedTheme) >= 0 ? storedTheme : "vextrom";
        if (theme === "xvetrom") theme = "xvextrom";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link href="/public/css/app.css" rel="stylesheet" />
  </head>
  <body class="app-shell <%= currentPath && currentPath.startsWith('/admin') ? 'admin-page' : '' %>">
    <main class="container app-main py-4 py-md-5">
      <div class="app-topbar">
        <div class="app-brand-wrap">
          <a class="app-brand" href="/">
            <img class="app-brand-logo" src="/public/img/logo-vextrom.svg" alt="Vextrom" />
          </a>
          <span class="app-brand-title">
            <%= t("head.brandTitle") %>
            <small class="app-brand-version"><%= appVersionShort %></small>
          </span>
          <img class="app-iec-icon" src="/public/img/iec-icon.svg" alt="IEC" />
        </div>
        <div class="app-topbar-controls">
          <div class="topbar-group">
            <span class="lang-label"><%= t("head.langLabel") %>:</span>
            <a class="btn btn-sm lang-btn <%= lang === 'pt' ? 'btn-primary' : 'btn-outline-primary' %>" href="<%= currentPath %>?lang=pt">PT</a>
            <a class="btn btn-sm lang-btn <%= lang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>" href="<%= currentPath %>?lang=en">EN</a>
          </div>
          <div class="topbar-theme-block">
            <div class="topbar-group">
              <label class="lang-label mb-0" for="themeSelector"><%= t("head.themeLabel") %>:</label>
              <select id="themeSelector" class="form-select form-select-sm theme-select" aria-label="<%= t('head.themeLabel') %>">
                <option value="soft"><%= t("head.themeSoft") %></option>
                <option value="vextrom"><%= t("head.themeVextrom") %></option>
                <option value="xvextrom"><%= t("head.themeXVextrom") %></option>
              </select>
            </div>
            <% if (isAdminAuthenticated && adminUsername) { %>
              <small class="topbar-user-meta">Usuario logado: <strong><%= adminUsername %></strong></small>
              <% if (typeof csrfToken !== "undefined" && csrfToken) { %>
                <form method="post" action="/admin/logout" class="topbar-logout-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button class="btn btn-outline-secondary btn-sm btn-no-icon topbar-logout-btn" type="submit"><%= t("admin.logoutSessionButton") %></button>
                </form>
              <% } %>
            <% } %>
          </div>
        </div>
      </div>
