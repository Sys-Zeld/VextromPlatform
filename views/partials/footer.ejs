    <script>
      (function () {
        "use strict";
        function updateThemeQr(theme) {
          var normalized = theme === "vextrom" ? "vextrom" : "soft";
          var qrNodes = document.querySelectorAll("img[data-qr-soft][data-qr-vextrom]");
          qrNodes.forEach(function (img) {
            var nextSrc = normalized === "vextrom" ? img.getAttribute("data-qr-vextrom") : img.getAttribute("data-qr-soft");
            if (nextSrc && img.getAttribute("src") !== nextSrc) {
              img.setAttribute("src", nextSrc);
            }
          });
        }

        function persistThemeCookie(theme) {
          var maxAgeSeconds = 365 * 24 * 60 * 60;
          document.cookie = "app_theme=" + encodeURIComponent(theme) + "; Path=/; Max-Age=" + maxAgeSeconds + "; SameSite=Lax";
        }

        var currentTheme = document.documentElement.getAttribute("data-theme") || "vextrom";
        updateThemeQr(currentTheme);
        persistThemeCookie(currentTheme);
        var themeSelector = document.getElementById("themeSelector");
        if (themeSelector) {
          themeSelector.value = currentTheme;
          themeSelector.addEventListener("change", function () {
            var nextTheme = ["soft", "vextrom"].indexOf(themeSelector.value) >= 0
              ? themeSelector.value
              : "soft";
            document.documentElement.setAttribute("data-theme", nextTheme);
            updateThemeQr(nextTheme);
            persistThemeCookie(nextTheme);
            try {
              localStorage.setItem("app_theme", nextTheme);
            } catch (_err) {}
          });
        }

        var forms = document.querySelectorAll(".needs-validation");
        Array.prototype.slice.call(forms).forEach(function (form) {
          form.addEventListener("submit", function (event) {
            if (!form.checkValidity()) {
              event.preventDefault();
              event.stopPropagation();
            }
            form.classList.add("was-validated");
          });
        });
      })();
    </script>
