NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
SPECFLOW_ENABLED=true
MODULE_SPEC_ENABLED=false
REPORT_SERVICE_ENABLED=true

# Banco principal (SpecFlow / login / hubservice)
DATABASE_URL=postgres://postgres:zeldchip2026@localhost:5432/dbspeflow
DATABASE_SSL=false
SPECFLOW_DATABASE_URL=postgres://postgres:zeldchip2026@localhost:5432/dbspeflow
SPECFLOW_DATABASE_SSL=false
MODULE_SPEC_DATABASE_URL=postgres://postgres:zeldchip2026@localhost:5432/dbmodulespec
MODULE_SPEC_DATABASE_SSL=false
REPORT_SERVICE_DATABASE_URL=postgres://postgres:zeldchip2026@localhost:5432/reportservice
REPORT_SERVICE_DATABASE_SSL=false
CONFIG_DATABASE_URL=postgres://postgres:zeldchip2026@localhost:5432/configdb
CONFIG_DATABASE_SSL=false
# Linux example: /opt/bitnami/postgresql/bin
# Windows example: C:\Program Files\PostgreSQL\16\bin
PG_BIN_DIR=
DB_RESTORE_TIMEOUT_MS=1200000

ADMIN_USER=admin
ADMIN_PASS=@vextrom
ADMIN_SESSION_SECRET=change-me-too
ADMIN_SESSION_COOKIE_NAME=admin_session
ADMIN_SESSION_TTL_HOURS=12
ADMIN_SESSION_STATE_FILE=./dados/admin-session-state.json
ADMIN_USERS_FILE=./dados/admin-users.json

# SMTP geral (compativel com Mailtrap)
SMTP_HOST=live.smtp.mailtrap.io
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=b9cc2e3673a427
SMTP_PASS=bc2dd3265e2ef7
