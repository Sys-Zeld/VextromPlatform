# Alternativa Mailtrap (opcional): se preencher, tambem e reconhecido pela app
MAILTRAP_SMTP_HOST=live.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=465
MAILTRAP_SMTP_SECURE=true
MAILTRAP_SMTP_USER=api
MAILTRAP_SMTP_PASS=
