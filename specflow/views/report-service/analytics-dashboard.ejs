<%- include("../partials/head", { pageTitle }) %>
<link href="/public/css/report-analytics.css" rel="stylesheet" />
<%
  function fmtNumber(value) {
    const n = Number(value || 0);
    return Number.isFinite(n) ? n.toLocaleString("pt-BR") : "0";
  }
  function fmtHours(value) {
    const n = Number(value || 0);
    return Number.isFinite(n) ? n.toLocaleString("pt-BR", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : "0,00";
  }
  function fmtDays(value) {
    const n = Number(value || 0);
    return Number.isFinite(n) ? n.toLocaleString("pt-BR", { minimumFractionDigits: 1, maximumFractionDigits: 1 }) : "0,0";
  }
  function pct(part, total) {
    const p = Number(part || 0);
    const t = Number(total || 0);
    if (!t) return 0;
    return Math.min(100, Math.round(p / t * 100));
  }
  function maxVal(arr, key) {
    return arr.reduce((m, r) => Math.max(m, Number(r[key] || 0)), 0);
  }

  const query = new URLSearchParams({
    date_from: filters.dateFrom || "",
    date_to: filters.dateTo || "",
    customer_id: filters.customerId || "",
    site_id: filters.siteId || "",
    technician_id: filters.technicianId || "",
    order_status: filters.orderStatus || ""
  }).toString();

  const kpis   = dashboard.kpis || {};
  const tables = dashboard.tables || {};
  const eq     = dashboard.equipmentStats || {};
  const dq     = dashboard.dataQuality || {};

  const statusLabels = {
    draft: "Rascunho", valid: "Válida", in_progress: "Em Execução",
    waiting_review: "Aguard. Revisão", approved: "Aprovada",
    issued: "Emitida", closed: "Encerrada", cancelled: "Cancelada"
  };

  const topHours = Math.max(Number(kpis.total_hours || 0), 1);
%>

<div class="token-console dash">

  <!-- ── Banner ──────────────────────────────────────────────────────────── -->
  <div class="dash-banner">
    <div class="dash-banner-left">
      <div class="dash-banner-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
        </svg>
      </div>
      <div>
        <span class="dash-banner-eyebrow">Service Report</span>
        <h1>Relatório / Dashboard</h1>
        <p>Indicadores gerenciais e operacionais em tempo real.</p>
      </div>
    </div>
    <div class="dash-banner-actions">
      <a class="btn-ghost" href="/admin/report-service/orders">Ordens</a>
      <a class="btn-ghost" href="/admin/report-service/customers">Clientes</a>
      <a class="btn-ghost" href="/admin/report-service/spare-parts">Spare-Parts</a>
      <a class="btn-accent" href="/admin/report-service/analytics/export-pdf?<%= query %>">
        ↓ Exportar PDF
      </a>
    </div>
  </div>

  <!-- ── Filtros ─────────────────────────────────────────────────────────── -->
  <div class="dash-filter-card">
    <div class="dash-filter-title">
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/></svg>
      Filtros
    </div>
    <form method="get" action="/admin/report-service/analytics" class="row g-2 align-items-end">
      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Data início</label>
        <input class="form-control form-control-sm" type="date" name="date_from" value="<%= filters.dateFrom || '' %>" />
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Data fim</label>
        <input class="form-control form-control-sm" type="date" name="date_to" value="<%= filters.dateTo || '' %>" />
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Cliente</label>
        <select class="form-select form-select-sm" name="customer_id">
          <option value="">Todos</option>
          <% (options.customers || []).forEach((c) => { %>
            <option value="<%= c.id %>" <%= Number(filters.customerId) === Number(c.id) ? "selected" : "" %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Site</label>
        <select class="form-select form-select-sm" name="site_id">
          <option value="">Todos</option>
          <% (options.sites || []).forEach((s) => { %>
            <option value="<%= s.id %>" <%= Number(filters.siteId) === Number(s.id) ? "selected" : "" %>><%= s.site_name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Técnico</label>
        <select class="form-select form-select-sm" name="technician_id">
          <option value="">Todos</option>
          <% (options.technicians || []).forEach((t) => { %>
            <option value="<%= t.id %>" <%= Number(filters.technicianId) === Number(t.id) ? "selected" : "" %>><%= t.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-6 col-md-2">
        <label class="form-label small mb-1">Status</label>
        <select class="form-select form-select-sm" name="order_status">
          <option value="">Todos</option>
          <% ["draft","valid","in_progress","waiting_review","approved","issued","closed","cancelled"].forEach((st) => { %>
            <option value="<%= st %>" <%= filters.orderStatus === st ? "selected" : "" %>><%= statusLabels[st] || st %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-12 d-flex gap-2 pt-1">
        <button class="btn btn-primary btn-sm" type="submit">Aplicar</button>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/analytics">Limpar filtros</a>
      </div>
    </form>
  </div>

  <!-- ── KPIs: Ordens ────────────────────────────────────────────────────── -->
  <div>
    <div class="dash-section-heading mb-2">
      <span class="dash-section-label">Ordens de Serviço</span>
      <div class="dash-section-heading-line"></div>
    </div>
    <div class="dash-kpis dash-kpis-9">

      <div class="dash-kpi kpi-blue">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <div class="dash-kpi-label">Total OS</div>
        <div class="dash-kpi-value c-blue"><%= fmtNumber(kpis.total_os) %></div>
        <div class="dash-kpi-sub">ordens cadastradas</div>
      </div>

      <div class="dash-kpi kpi-slate">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </div>
        <div class="dash-kpi-label">Rascunho</div>
        <div class="dash-kpi-value c-slate"><%= fmtNumber(kpis.total_draft) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_draft, kpis.total_os) %>% do total</div>
      </div>

      <div class="dash-kpi kpi-blue">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="dash-kpi-label">Válidas</div>
        <div class="dash-kpi-value c-blue"><%= fmtNumber(kpis.total_valid) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_valid, kpis.total_os) %>% do total</div>
      </div>

      <div class="dash-kpi kpi-amber">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div class="dash-kpi-label">Em Execução</div>
        <div class="dash-kpi-value c-amber"><%= fmtNumber(kpis.total_in_progress) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_in_progress, kpis.total_os) %>% do total</div>
      </div>

      <div class="dash-kpi kpi-orange">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
        </div>
        <div class="dash-kpi-label">Aguard. Revisão</div>
        <div class="dash-kpi-value c-orange"><%= fmtNumber(kpis.total_waiting_review) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_waiting_review, kpis.total_os) %>% do total</div>
      </div>

      <div class="dash-kpi kpi-green">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        </div>
        <div class="dash-kpi-label">Aprovadas</div>
        <div class="dash-kpi-value c-green"><%= fmtNumber(kpis.total_approved) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_approved, kpis.total_os) %>% do total</div>
      </div>

      <div class="dash-kpi kpi-emerald">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
        </div>
        <div class="dash-kpi-label">Emitidas</div>
        <div class="dash-kpi-value c-emerald"><%= fmtNumber(kpis.total_issued) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_issued, kpis.total_os) %>% do total</div>
      </div>

      <div class="dash-kpi kpi-slate">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
        </div>
        <div class="dash-kpi-label">Encerradas</div>
        <div class="dash-kpi-value c-slate"><%= fmtNumber(kpis.total_closed) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_closed, kpis.total_os) %>% do total</div>
      </div>

      <div class="dash-kpi kpi-red">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </div>
        <div class="dash-kpi-label">Canceladas</div>
        <div class="dash-kpi-value c-red"><%= fmtNumber(kpis.total_cancelled) %></div>
        <div class="dash-kpi-sub"><%= pct(kpis.total_cancelled, kpis.total_os) %>% do total</div>
      </div>

    </div>
  </div>

  <!-- ── KPIs: Operacional ───────────────────────────────────────────────── -->
  <div>
    <div class="dash-section-heading mb-2">
      <span class="dash-section-label">Operacional</span>
      <div class="dash-section-heading-line"></div>
    </div>
    <div class="dash-kpis dash-kpis-6">

      <div class="dash-kpi kpi-teal">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="dash-kpi-label">Horas Trabalhadas</div>
        <div class="dash-kpi-value c-teal"><%= fmtHours(kpis.total_hours) %></div>
        <div class="dash-kpi-sub">h totais no período</div>
      </div>

      <div class="dash-kpi kpi-violet">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        </div>
        <div class="dash-kpi-label">Média Fechamento</div>
        <div class="dash-kpi-value c-violet"><%= fmtDays(kpis.avg_close_days) %></div>
        <div class="dash-kpi-sub">dias abertura → fechamento</div>
      </div>

      <div class="dash-kpi kpi-blue">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
        </div>
        <div class="dash-kpi-label">Equipamentos</div>
        <div class="dash-kpi-value c-blue"><%= fmtNumber(eq.total_equipments) %></div>
        <div class="dash-kpi-sub"><%= fmtNumber(eq.total_families) %> famílias distintas</div>
      </div>

      <div class="dash-kpi kpi-green">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <div class="dash-kpi-label">Assinaturas OK</div>
        <div class="dash-kpi-value c-green"><%= fmtNumber(kpis.signed_count) %></div>
        <div class="dash-kpi-sub">relatórios assinados</div>
      </div>

      <div class="dash-kpi kpi-amber">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="dash-kpi-label">Aguard. Assinatura</div>
        <div class="dash-kpi-value c-amber"><%= fmtNumber(kpis.pending_count) %></div>
        <div class="dash-kpi-sub">sign requests pendentes</div>
      </div>

      <div class="dash-kpi kpi-red">
        <div class="dash-kpi-icon" style="background:var(--kpi-icon-bg);">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--kpi-icon-color)"><path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="dash-kpi-label">Assin. Recusadas</div>
        <div class="dash-kpi-value c-red"><%= fmtNumber(kpis.cancelled_count) %></div>
        <div class="dash-kpi-sub">sign requests cancelados</div>
      </div>

    </div>
  </div>

  <!-- ── Gráficos ────────────────────────────────────────────────────────── -->
  <div>
    <div class="dash-section-heading mb-2">
      <span class="dash-section-label">Análises Gráficas</span>
      <div class="dash-section-heading-line"></div>
    </div>
    <div class="row g-3">

      <!-- Tendência mensal -->
      <div class="col-12 col-xl-8">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18"/></svg>
              Tendência Mensal
            </h2>
            <span class="dash-card-badge">OS abertas vs. encerradas</span>
          </div>
          <div class="dash-card-chart">
            <div class="chart-wrap" style="height:240px;"><canvas id="monthlyTrendChart"></canvas></div>
          </div>
        </div>
      </div>

      <!-- Assinaturas donut -->
      <div class="col-12 col-xl-4">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              Assinaturas
            </h2>
          </div>
          <div class="dash-card-chart">
            <div class="chart-wrap" style="height:240px;"><canvas id="signatureStatusChart"></canvas></div>
          </div>
        </div>
      </div>

      <!-- OS por status -->
      <div class="col-12 col-md-6">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
              OS por Status
            </h2>
          </div>
          <div class="dash-card-chart">
            <div class="chart-wrap" style="height:200px;"><canvas id="statusChart"></canvas></div>
          </div>
        </div>
      </div>

      <!-- Backlog aging -->
      <div class="col-12 col-md-6">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Aging do Backlog
            </h2>
            <span class="dash-card-badge">OS não aprovadas</span>
          </div>
          <div class="dash-card-chart">
            <div class="chart-wrap" style="height:200px;"><canvas id="backlogChart"></canvas></div>
          </div>
        </div>
      </div>

      <!-- Horas por técnico -->
      <div class="col-12 col-xl-6">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              Horas por Técnico
            </h2>
            <span class="dash-card-badge">top 15</span>
          </div>
          <div class="dash-card-chart">
            <div class="chart-wrap" style="height:240px;"><canvas id="hoursChart"></canvas></div>
          </div>
        </div>
      </div>

      <!-- Top clientes -->
      <div class="col-12 col-xl-6">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              OS por Cliente
            </h2>
            <span class="dash-card-badge">top 10</span>
          </div>
          <div class="dash-card-chart">
            <div class="chart-wrap" style="height:240px;"><canvas id="customerChart"></canvas></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ── Tabelas ─────────────────────────────────────────────────────────── -->
  <div>
    <div class="dash-section-heading mb-2">
      <span class="dash-section-label">Tabelas Detalhadas</span>
      <div class="dash-section-heading-line"></div>
    </div>
    <div class="row g-3">

      <!-- OS por técnico -->
      <div class="col-12 col-lg-4">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">OS por Técnico</h2>
            <span class="dash-card-badge"><%= (tables.ordersByTechnician || []).length %> técnicos</span>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th class="rank">#</th><th>Técnico</th><th class="num">OS</th></tr></thead>
              <tbody>
                <% const maxOsTech = maxVal(tables.ordersByTechnician || [], 'os_qty'); %>
                <% (tables.ordersByTechnician || []).forEach((row, i) => { %>
                  <tr>
                    <td class="rank"><%= i + 1 %></td>
                    <td>
                      <div class="bar-cell">
                        <span><%= row.name %></span>
                        <div class="bar-cell-track">
                          <div class="bar-cell-fill" style="width:<%= pct(row.os_qty, maxOsTech) %>%; --bar-color:#3b82f6;"></div>
                        </div>
                      </div>
                    </td>
                    <td class="num"><%= fmtNumber(row.os_qty) %></td>
                  </tr>
                <% }) %>
                <% if (!(tables.ordersByTechnician || []).length) { %>
                  <tr><td colspan="3" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Horas por técnico -->
      <div class="col-12 col-lg-4">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">Horas por Técnico</h2>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th class="rank">#</th><th>Técnico</th><th class="num">Horas</th></tr></thead>
              <tbody>
                <% const maxHoursTech = maxVal(tables.hoursByTechnician || [], 'total_hours'); %>
                <% (tables.hoursByTechnician || []).forEach((row, i) => { %>
                  <tr>
                    <td class="rank"><%= i + 1 %></td>
                    <td>
                      <div class="bar-cell">
                        <span><%= row.technician_name %></span>
                        <div class="bar-cell-track">
                          <div class="bar-cell-fill" style="width:<%= pct(row.total_hours, maxHoursTech) %>%; --bar-color:#14b8a6;"></div>
                        </div>
                      </div>
                    </td>
                    <td class="num"><%= fmtHours(row.total_hours) %></td>
                  </tr>
                <% }) %>
                <% if (!(tables.hoursByTechnician || []).length) { %>
                  <tr><td colspan="3" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Top OS por horas -->
      <div class="col-12 col-lg-4">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">OS com Mais Horas</h2>
            <span class="dash-card-badge">top 15</span>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th class="rank">#</th><th>OS</th><th class="num">h</th></tr></thead>
              <tbody>
                <% (tables.hoursByOrder || []).slice(0, 15).forEach((row, i) => { %>
                  <tr>
                    <td class="rank"><%= i + 1 %></td>
                    <td>
                      <span class="code"><%= row.service_order_code %></span>
                      <span class="trunc d-block" style="font-size:.75rem;color:var(--muted-text);" title="<%= row.title %>"><%= row.title %></span>
                    </td>
                    <td class="num"><%= fmtHours(row.total_hours) %></td>
                  </tr>
                <% }) %>
                <% if (!(tables.hoursByOrder || []).length) { %>
                  <tr><td colspan="3" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Top clientes -->
      <div class="col-12 col-lg-4">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">Top Clientes</h2>
            <span class="dash-card-badge">por OS</span>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th class="rank">#</th><th>Cliente</th><th class="num">OS</th></tr></thead>
              <tbody>
                <% const maxOsCust = maxVal(tables.topCustomers || [], 'os_qty'); %>
                <% (tables.topCustomers || []).forEach((row, i) => { %>
                  <tr>
                    <td class="rank"><%= i + 1 %></td>
                    <td>
                      <div class="bar-cell">
                        <span><%= row.name %></span>
                        <div class="bar-cell-track">
                          <div class="bar-cell-fill" style="width:<%= pct(row.os_qty, maxOsCust) %>%; --bar-color:#8b5cf6;"></div>
                        </div>
                      </div>
                    </td>
                    <td class="num"><%= fmtNumber(row.os_qty) %></td>
                  </tr>
                <% }) %>
                <% if (!(tables.topCustomers || []).length) { %>
                  <tr><td colspan="3" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Top sites -->
      <div class="col-12 col-lg-4">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">Top Sites</h2>
            <span class="dash-card-badge">por OS</span>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th class="rank">#</th><th>Site</th><th class="num">OS</th></tr></thead>
              <tbody>
                <% const maxOsSite = maxVal(tables.topSites || [], 'os_qty'); %>
                <% (tables.topSites || []).forEach((row, i) => { %>
                  <tr>
                    <td class="rank"><%= i + 1 %></td>
                    <td>
                      <div class="bar-cell">
                        <span><%= row.site_name %></span>
                        <div class="bar-cell-track">
                          <div class="bar-cell-fill" style="width:<%= pct(row.os_qty, maxOsSite) %>%; --bar-color:#f97316;"></div>
                        </div>
                      </div>
                    </td>
                    <td class="num"><%= fmtNumber(row.os_qty) %></td>
                  </tr>
                <% }) %>
                <% if (!(tables.topSites || []).length) { %>
                  <tr><td colspan="3" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Equipamentos por família -->
      <div class="col-12 col-lg-4">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">Equipamentos por Família</h2>
            <span class="dash-card-badge"><%= fmtNumber(eq.total_equipments) %> total</span>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th class="rank">#</th><th>Família</th><th class="num">Qtd</th></tr></thead>
              <tbody>
                <% const maxEq = maxVal(eq.byFamily || [], 'qty'); %>
                <% (eq.byFamily || []).forEach((row, i) => { %>
                  <tr>
                    <td class="rank"><%= i + 1 %></td>
                    <td>
                      <div class="bar-cell">
                        <span><%= row.model_family %></span>
                        <div class="bar-cell-track">
                          <div class="bar-cell-fill" style="width:<%= pct(row.qty, maxEq) %>%; --bar-color:#10b981;"></div>
                        </div>
                      </div>
                    </td>
                    <td class="num"><%= fmtNumber(row.qty) %></td>
                  </tr>
                <% }) %>
                <% if (!(eq.byFamily || []).length) { %>
                  <tr><td colspan="3" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Spare-parts -->
      <div class="col-12 col-lg-8">
        <div class="dash-card">
          <div class="dash-card-header">
            <h2 class="dash-card-title">Spare-Parts Mais Utilizados</h2>
            <span class="dash-card-badge">top 20</span>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th class="rank">#</th><th>Part Number</th><th>Descrição</th><th class="num">Qtd</th></tr></thead>
              <tbody>
                <% const maxSp = maxVal(tables.topSpareParts || [], 'qty_used'); %>
                <% (tables.topSpareParts || []).slice(0, 20).forEach((row, i) => { %>
                  <tr>
                    <td class="rank"><%= i + 1 %></td>
                    <td><span class="code"><%= row.part_number || '-' %></span></td>
                    <td class="trunc"><%= row.description || '-' %></td>
                    <td class="num">
                      <div class="bar-cell" style="justify-content:flex-end;">
                        <div class="bar-cell-track" style="max-width:60px;">
                          <div class="bar-cell-fill" style="width:<%= pct(row.qty_used, maxSp) %>%; --bar-color:#f59e0b;"></div>
                        </div>
                        <%= fmtNumber(row.qty_used) %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
                <% if (!(tables.topSpareParts || []).length) { %>
                  <tr><td colspan="4" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Qualidade + Revisões -->
      <div class="col-12 col-lg-4">

        <!-- Qualidade -->
        <div class="dash-card mb-3" style="height:auto;">
          <div class="dash-card-header">
            <h2 class="dash-card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              Qualidade de Preenchimento
            </h2>
          </div>
          <div class="dash-card-body">
            <div class="quality-row">
              <span class="quality-label">Total de OS</span>
              <span class="quality-badge ok"><%= fmtNumber(dq.total_orders) %></span>
            </div>
            <div class="quality-row">
              <span class="quality-label">Sem timesheet</span>
              <span class="quality-badge <%= Number(dq.missing_timesheet) > 0 ? 'bad' : 'ok' %>"><%= fmtNumber(dq.missing_timesheet) %></span>
            </div>
            <div class="quality-row">
              <span class="quality-label">Sem descrição diária</span>
              <span class="quality-badge <%= Number(dq.missing_daily_description) > 0 ? 'warn' : 'ok' %>"><%= fmtNumber(dq.missing_daily_description) %></span>
            </div>
            <div class="quality-row">
              <span class="quality-label">Sem conclusão geral</span>
              <span class="quality-badge <%= Number(dq.missing_conclusion) > 0 ? 'warn' : 'ok' %>"><%= fmtNumber(dq.missing_conclusion) %></span>
            </div>
            <div class="quality-row">
              <span class="quality-label">Sem assinatura cliente</span>
              <span class="quality-badge <%= Number(dq.missing_signature) > 0 ? 'bad' : 'ok' %>"><%= fmtNumber(dq.missing_signature) %></span>
            </div>
          </div>
        </div>

        <!-- Revisões -->
        <div class="dash-card" style="height:auto;">
          <div class="dash-card-header">
            <h2 class="dash-card-title">Distribuição por Revisão</h2>
          </div>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead><tr><th>Revisão</th><th class="num">Qtd</th></tr></thead>
              <tbody>
                <% (tables.revisionDistribution || []).forEach((row) => { %>
                  <tr>
                    <td><span class="code"><%= row.revision %></span></td>
                    <td class="num"><%= fmtNumber(row.qty) %></td>
                  </tr>
                <% }) %>
                <% if (!(tables.revisionDistribution || []).length) { %>
                  <tr><td colspan="2" class="text-center text-muted py-3" style="font-size:.8rem;">Sem dados</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>

    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
  window.reportAnalyticsData = <%- JSON.stringify(dashboard || {}).replace(/</g, "\\u003c") %>;
</script>
<script src="/public/js/report-analytics.js"></script>
<%- include("../partials/footer") %>
