<%- include("../partials/head", { pageTitle }) %>
<link href="/public/css/report-editor.css" rel="stylesheet" />
<%
  function formatDateOnly(value) {
    if (!value) return "-";
    const raw = String(value).trim();
    const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (iso) return `${iso[3]}/${iso[2]}/${iso[1].slice(-2)}`;
    return "-";
  }
  const linkedTechSet = new Set((linkedTechIds || []).map(Number));
  const linkedInstrSet = new Set((linkedInstrIds || []).map(Number));
%>

<section class="token-console">
  <div class="card app-card token-hero-card">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">SERVICE REPORT</span>
        <h1 class="h4 app-card-title mb-1"><%= order.service_order_display || "-" %></h1>
        <p class="text-muted mb-0"><%= t("rs.assets.pageSubtitle") %></p>
      </div>
      <div class="token-hero-actions">
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders"><%= t("rs.orders.pageTitle") %></a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>">Editar OS</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>/report-editor">Editar Relatorio</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/assets">Cadastro Global</a>
      </div>
    </div>
  </div>

  <% if (saved) { %><div class="alert alert-success mb-0"><%= t("rs.assets.savedSuccess") %></div><% } %>

  <div class="row g-3 mt-0">

    <%# ========== EQUIPE TECNICA ========== %>
    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3"><%= t("rs.assets.techTeamTitle") %></h2>

          <% if (allTechnicians.length) { %>
            <form method="post" action="/admin/report-service/orders/<%= order.id %>/assets/technicians/link" class="d-flex gap-2 mb-3">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <select class="form-select form-select-sm" name="technician_id" required>
                <option value=""><%= t("rs.assets.selectToLink") %></option>
                <% allTechnicians.forEach((t) => { %>
                  <% if (!linkedTechSet.has(t.id)) { %>
                    <option value="<%= t.id %>"><%= t.name %><% if (t.role) { %> — <%= t.role %><% } %><% if (t.company) { %> (<%= t.company %>)<% } %></option>
                  <% } %>
                <% }) %>
              </select>
              <button class="btn btn-primary btn-sm text-nowrap" type="submit"><%= t("rs.assets.linkBtn") %></button>
            </form>
          <% } else { %>
            <p class="small text-muted mb-3"><%= t("rs.assets.noTechnicians") %> <a href="/admin/report-service/assets"><%= t("rs.assets.registerNow") %></a>.</p>
          <% } %>

          <div class="table-responsive">
            <table class="table table-sm app-table mb-0">
              <thead>
                <tr><th><%= t("rs.name") %></th><th><%= t("rs.assets.colRole") %></th><th><%= t("rs.assets.colCompany") %></th><th><%= t("rs.assets.colLeader") %></th><th></th></tr>
              </thead>
              <tbody>
                <% if (!linkedTechs.length) { %>
                  <tr><td colspan="5" class="text-center text-muted py-3"><%= t("rs.assets.noTechLinked") %></td></tr>
                <% } %>
                <% linkedTechs.forEach((t) => { %>
                  <tr>
                    <td>
                      <%= t.name %>
                      <% if (t.email) { %><br /><small class="text-muted"><%= t.email %></small><% } %>
                      <% if (t.phone) { %><br /><small class="text-muted"><%= t.phone %></small><% } %>
                    </td>
                    <td><%= t.role || "-" %></td>
                    <td><%= t.company || "-" %></td>
                    <td><%= t.is_lead ? "Sim" : "-" %></td>
                    <td>
                      <form method="post" action="/admin/report-service/orders/<%= order.id %>/assets/technicians/<%= t.id %>/unlink" class="m-0" onsubmit="return confirm('<%= t('rs.assets.confirmUnlinkTech') %>');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button class="btn btn-outline-danger btn-sm" type="submit"><%= t("rs.assets.unlinkBtn") %></button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <%# ========== INSTRUMENTOS ========== %>
    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3"><%= t("rs.assets.instrumentsTitle") %></h2>

          <% if (allInstruments.length) { %>
            <form method="post" action="/admin/report-service/orders/<%= order.id %>/assets/instruments/link" class="d-flex gap-2 mb-3">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <select class="form-select form-select-sm" name="instrument_id" required>
                <option value=""><%= t("rs.assets.selectToLink") %></option>
                <% allInstruments.forEach((instr) => { %>
                  <% if (!linkedInstrSet.has(instr.id)) { %>
                    <option value="<%= instr.id %>"><%= instr.name %><% if (instr.model) { %> — <%= instr.model %><% } %><% if (instr.serial_number) { %> (<%= instr.serial_number %>)<% } %></option>
                  <% } %>
                <% }) %>
              </select>
              <button class="btn btn-primary btn-sm text-nowrap" type="submit"><%= t("rs.assets.linkBtn") %></button>
            </form>
          <% } else { %>
            <p class="small text-muted mb-3"><%= t("rs.assets.noInstruments") %> <a href="/admin/report-service/assets"><%= t("rs.assets.registerNow") %></a>.</p>
          <% } %>

          <div class="table-responsive">
            <table class="table table-sm app-table mb-0">
              <thead>
                <tr><th><%= t("rs.name") %></th><th><%= t("rs.assets.colModel") %></th><th><%= t("rs.assets.colSerial") %></th><th><%= t("rs.assets.colCalibration") %></th><th></th></tr>
              </thead>
              <tbody>
                <% if (!linkedInstrs.length) { %>
                  <tr><td colspan="5" class="text-center text-muted py-3"><%= t("rs.assets.noInstrumentLinked") %></td></tr>
                <% } %>
                <% linkedInstrs.forEach((instr) => { %>
                  <tr>
                    <td>
                      <%= instr.name %>
                      <% if (instr.notes) { %><br /><small class="text-muted"><%= instr.notes %></small><% } %>
                    </td>
                    <td><%= instr.model || "-" %></td>
                    <td><%= instr.serial_number || "-" %></td>
                    <td><%= formatDateOnly(instr.calibration_due_date) %></td>
                    <td>
                      <form method="post" action="/admin/report-service/orders/<%= order.id %>/assets/instruments/<%= instr.id %>/unlink" class="m-0" onsubmit="return confirm('<%= t('rs.assets.confirmUnlinkInstrument') %>');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button class="btn btn-outline-danger btn-sm" type="submit"><%= t("rs.assets.unlinkBtn") %></button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<%- include("../partials/footer") %>
