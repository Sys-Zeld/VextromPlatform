<%- include("../partials/head", { pageTitle }) %>
<link href="/public/css/report-preview.css" rel="stylesheet" />
<link href="/public/css/report-print.css" rel="stylesheet" />

<section class="report-preview-actions card app-card mb-3">
  <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
    <div>
      <h1 class="h5 app-card-title mb-1">Preview do Relatorio</h1>
      <p class="text-muted mb-0">Template HTML oficial do Service Report.</p>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>">Voltar ao editor</a>
      <form method="post" action="/admin/report-service/orders/<%= order.id %>/generate-pdf" class="m-0">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button class="btn btn-primary btn-sm" type="submit">Gerar PDF</button>
      </form>
    </div>
  </div>
</section>

<%- include("preview-document") %>

<%- include("../partials/footer") %>
