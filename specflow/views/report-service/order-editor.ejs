<script>
  window.orderSparePartsByEquipment = <%- JSON.stringify(orderSparePartsByEquipment || {}).replace(/</g, "\\u003c") %>;
</script>
<script>
  (function () {
    var equipmentSelect = document.getElementById("componentEquipmentSelect");
    var descriptionSelect = document.getElementById("componentDescriptionSelect");
    var partNumberInput = document.getElementById("componentPartNumberInput");
    var source = window.orderSparePartsByEquipment || {};
    if (!equipmentSelect || !descriptionSelect || !partNumberInput) return;

    function esc(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function fillDescriptions(equipmentId) {
      var key = String(equipmentId || "");
      var list = Array.isArray(source[key]) ? source[key] : [];
      descriptionSelect.innerHTML = "";

      var defaultOpt = document.createElement("option");
      defaultOpt.value = "";
      defaultOpt.textContent = list.length
        ? "Selecione a descricao (spare-part)"
        : "Sem spare-parts associados ao equipamento";
      descriptionSelect.appendChild(defaultOpt);

      list.forEach(function (item) {
        var opt = document.createElement("option");
        opt.value = String(item.description || "");
        opt.setAttribute("data-part-number", String(item.part_number || ""));
        opt.innerHTML = esc(item.description || "-");
        descriptionSelect.appendChild(opt);
      });

      descriptionSelect.value = "";
      partNumberInput.value = "";
    }

    equipmentSelect.addEventListener("change", function () {
      fillDescriptions(equipmentSelect.value);
    });

    descriptionSelect.addEventListener("change", function () {
      var selected = descriptionSelect.options[descriptionSelect.selectedIndex];
      partNumberInput.value = selected ? String(selected.getAttribute("data-part-number") || "") : "";
    });

    fillDescriptions(equipmentSelect.value);
  })();
</script>
<script>
  (function () {
    var btn = document.getElementById("generateConclusionBtn");
    var statusEl = document.getElementById("generateConclusionStatus");
    var successEl = document.getElementById("generateConclusionSuccess");
    var errorEl = document.getElementById("generateConclusionError");
    if (!btn) return;

    var csrfInput = document.querySelector('input[name="_csrf"]');
    var csrfToken = csrfInput ? csrfInput.value : "";
    var endpoint = "/admin/report-service/orders/<%= order.id %>/daily-logs/generate-conclusion";

    btn.addEventListener("click", async function () {
      btn.disabled = true;
      if (statusEl) { statusEl.textContent = "Gerando com IA..."; statusEl.classList.remove("d-none"); }
      if (successEl) successEl.classList.add("d-none");
      if (errorEl) errorEl.classList.add("d-none");
      try {
        var response = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json", "X-CSRF-Token": csrfToken },
          credentials: "same-origin",
          body: JSON.stringify({})
        });
        var payload = await response.json().catch(function () { return {}; });
        if (!response.ok || !payload.ok) {
          throw new Error(payload.message || "Falha ao gerar conclusao.");
        }

        if (statusEl) statusEl.classList.add("d-none");
        if (successEl) successEl.classList.remove("d-none");
        btn.disabled = false;
        setTimeout(function () { window.location.reload(); }, 1500);
      } catch (err) {
        if (statusEl) statusEl.classList.add("d-none");
        if (errorEl) {
          errorEl.textContent = err.message || "Falha ao gerar conclusao com IA.";
          errorEl.classList.remove("d-none");
        }
        btn.disabled = false;
      }
    });
  })();
</script>
<script>
  (function () {
    var form = document.getElementById("timesheet-form");
    var entryIdInput = document.getElementById("timesheetEntryId");
    var submitBtn = document.getElementById("timesheetSubmitBtn");
    var cancelBtn = document.getElementById("timesheetCancelEditBtn");
    var overlapError = document.getElementById("timesheetOverlapError");
    if (!form) return;

    var csrfInput = form.querySelector('input[name="_csrf"]');
    var csrfToken = csrfInput ? csrfInput.value : "";

    // ---- timesheet data index for client-side overlap check ----
    var tsIndex = <%- JSON.stringify(
      (timesheet || []).map(function(item) {
        return {
          id: Number(item.id),
          date: String(item.activity_date || "").slice(0, 10),
          inClient: item.check_in_client || item.check_in_base || "",
          outClient: item.check_out_client || item.check_out_base || ""
        };
      })
    ) %>;

    function parseTime(str) {
      if (!str) return null;
      var m = String(str).trim().match(/^(\d{1,2}):(\d{2})$/);
      if (!m) return null;
      return Number(m[1]) * 60 + Number(m[2]);
    }

    function checkOverlap(date, inTime, outTime, excludeId) {
      var newStart = parseTime(inTime);
      var newEnd = parseTime(outTime);
      if (newStart === null || newEnd === null || newEnd <= newStart) return null;
      for (var i = 0; i < tsIndex.length; i++) {
        var entry = tsIndex[i];
        if (excludeId !== null && entry.id === excludeId) continue;
        if (entry.date !== date) continue;
        var eStart = parseTime(entry.inClient);
        var eEnd = parseTime(entry.outClient);
        if (eStart === null || eEnd === null) continue;
        if (newStart < eEnd && newEnd > eStart) return entry;
      }
      return null;
    }

    function calcTimesheetHours() {
      var inVal = (document.getElementById("tsCheckInClient").value || "").trim();
      var outVal = (document.getElementById("tsCheckOutClient").value || "").trim();
      var display = document.getElementById("tsWorkedHoursDisplay");
      if (!display) return;
      var inMin = parseTime(inVal);
      var outMin = parseTime(outVal);
      if (inMin !== null && outMin !== null && outMin > inMin) {
        var diff = (outMin - inMin) / 60;
        display.value = diff.toFixed(2) + " h";
      } else {
        display.value = "";
      }
    }

    document.getElementById("tsCheckInClient").addEventListener("change", calcTimesheetHours);
    document.getElementById("tsCheckOutClient").addEventListener("change", calcTimesheetHours);
    document.getElementById("tsCheckInClient").addEventListener("input", calcTimesheetHours);
    document.getElementById("tsCheckOutClient").addEventListener("input", calcTimesheetHours);

    function resetForm() {
      entryIdInput.value = "";
      form.action = "/admin/report-service/orders/<%= order.id %>/timesheet";
      submitBtn.textContent = "Adicionar";
      cancelBtn.classList.add("d-none");
      form.reset();
      if (overlapError) overlapError.classList.add("d-none");
      document.getElementById("tsWorkedHoursDisplay").value = "";
    }

    if (cancelBtn) {
      cancelBtn.addEventListener("click", resetForm);
    }

    // Edit buttons
    var editBtns = document.querySelectorAll(".ts-edit-btn");
    editBtns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var row = btn.closest("tr");
        if (!row) return;
        var id = row.getAttribute("data-ts-id");
        document.getElementById("tsActivityDate").value = row.getAttribute("data-ts-date") || "";
        document.getElementById("tsTechnicianName").value = row.getAttribute("data-ts-technician") || "";
        document.getElementById("tsCheckInBase").value = row.getAttribute("data-ts-in-base") || "";
        document.getElementById("tsCheckInClient").value = row.getAttribute("data-ts-in-client") || "";
        document.getElementById("tsCheckOutClient").value = row.getAttribute("data-ts-out-client") || "";
        document.getElementById("tsCheckOutBase").value = row.getAttribute("data-ts-out-base") || "";
        document.getElementById("tsNotes").value = row.getAttribute("data-ts-notes") || "";
        calcTimesheetHours();
        entryIdInput.value = id;
        form.action = "/admin/report-service/orders/<%= order.id %>/timesheet/" + id + "/update";
        submitBtn.textContent = "Salvar edicao";
        cancelBtn.classList.remove("d-none");
        if (overlapError) overlapError.classList.add("d-none");
        document.getElementById("timesheet-card").scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    // Client-side overlap validation on submit
    form.addEventListener("submit", function (e) {
      if (overlapError) overlapError.classList.add("d-none");
      var date = document.getElementById("tsActivityDate").value;
      var inClient = document.getElementById("tsCheckInClient").value.trim();
      var outClient = document.getElementById("tsCheckOutClient").value.trim();
      if (!inClient || !outClient) return; // server will handle empty
      var excludeId = entryIdInput.value ? Number(entryIdInput.value) : null;
      var conflict = checkOverlap(date, inClient, outClient, excludeId);
      if (conflict) {
        e.preventDefault();
        var msg = "Sobreposicao de horario: conflito com " + (conflict.inClient || "-") + " - " + (conflict.outClient || "-") + " no mesmo dia. Verifique o horario e tente novamente.";
        if (overlapError) {
          overlapError.textContent = msg;
          overlapError.classList.remove("d-none");
          overlapError.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }
      }
    });
  })();
</script>
