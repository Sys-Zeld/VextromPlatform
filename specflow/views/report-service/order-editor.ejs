<%- include("../partials/head", { pageTitle }) %>
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/quill-better-table@1.2.10/dist/quill-better-table.css" rel="stylesheet" />
<link href="/public/css/report-editor.css" rel="stylesheet" />
<%
  function formatClassicDateTime(value) {
    if (!value) return "-";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "-";
    const weekDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    const day = String(date.getDate()).padStart(2, "0");
    const hours = String(date.getHours()).padStart(2, "0");
    const minutes = String(date.getMinutes()).padStart(2, "0");
    const seconds = String(date.getSeconds()).padStart(2, "0");
    return `${weekDays[date.getDay()]} ${months[date.getMonth()]} ${day} ${date.getFullYear()} ${hours}:${minutes}:${seconds}`;
  }

  function formatDateOnly(value) {
    if (!value) return "-";
    const raw = String(value).trim();
    const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (iso) return `${iso[3]}/${iso[2]}/${iso[1].slice(-2)}`;
    const date = new Date(raw);
    if (Number.isNaN(date.getTime())) return "-";
    const day = String(date.getDate()).padStart(2, "0");
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const year = String(date.getFullYear()).slice(-2);
    return `${day}/${month}/${year}`;
  }

  function formatDateShort(value) {
    if (!value) return "-";
    const raw = String(value).trim();
    const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (iso) return `${iso[3]}/${iso[2]}/${iso[1].slice(-2)}`;
    const date = new Date(raw);
    if (Number.isNaN(date.getTime())) return "-";
    const day = String(date.getDate()).padStart(2, "0");
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const year = String(date.getFullYear()).slice(-2);
    return `${day}/${month}/${year}`;
  }

  function summarizeOneSentence(htmlValue) {
    const plain = String(htmlValue || "")
      .replace(/<style[\s\S]*?<\/style>/gi, " ")
      .replace(/<script[\s\S]*?<\/script>/gi, " ")
      .replace(/<br\s*\/?>/gi, " ")
      .replace(/<\/p>/gi, ". ")
      .replace(/<\/h[1-6]>/gi, ". ")
      .replace(/<[^>]+>/g, " ")
      .replace(/&nbsp;/gi, " ")
      .replace(/\s+/g, " ")
      .trim();
    if (!plain) return "-";
    const sentenceMatch = plain.match(/^[^.!?]+[.!?]?/);
    const firstSentence = sentenceMatch ? sentenceMatch[0].trim() : plain;
    if (firstSentence.length <= 80) return firstSentence;
    return `${firstSentence.slice(0, 77)}...`;
  }

  const todayIso = new Date().toISOString().slice(0, 10);
%>

<section class="token-console">
  <% const isSystemAdmin = String(adminRole || "").toLowerCase() === "admin"; %>
  <div class="card app-card token-hero-card">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">SERVICE REPORT</span>
        <h1 class="h4 app-card-title mb-1"><%= order.service_order_display || "-" %></h1>
        <p class="text-muted mb-0"><%= order.title %> - <%= order.customer_name %></p>
      </div>
      <div class="token-hero-actions">
        <span class="badge text-bg-secondary">Status: <%= order.status || "draft" %></span>
        <% if (order.opening_date) { %><span class="badge text-bg-light border">Abertura: <%= formatDateShort(order.opening_date) %></span><% } %>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/hub">Service Hub</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders">Ordens</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/analytics">Relatório/Dashboard</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/config">Config Report</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>/report-editor">Editar Relatorio</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>/assets">Equipe / Instrum. OS</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/assets">Cadastro Global</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>/preview-html" target="_blank" rel="noopener">Preview HTML</a>
        <% if (String(order.status || "").toLowerCase() === "valid") { %>
          <a class="btn btn-outline-success btn-sm" href="/admin/report-service/orders/<%= order.id %>/sign-report">Assinar Relatorio</a>
        <% } %>
        <% if (String(order.status || "").toLowerCase() === "approved" && isSystemAdmin) { %>
          <details class="d-inline-block">
            <summary class="btn btn-warning btn-sm">Revalidar OS</summary>
            <form method="post" action="/admin/report-service/orders/<%= order.id %>/revalidate-os" class="d-flex align-items-center gap-2 mt-2 p-2 border rounded bg-light">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn btn-outline-warning btn-sm" type="submit">Confirmar</button>
            </form>
          </details>
        <% } else { %>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/validate-os">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button class="btn btn-success btn-sm" type="submit">Validar OS</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <% if (saved) { %><div class="alert alert-success mb-0">Dados salvos com sucesso.</div><% } %>
  <% if (osEmailSent) { %><div class="alert alert-success mb-0">E-mail da OS enviado com sucesso para os tecnicos.</div><% } %>
  <% if (osEmailError === 'no_recipients') { %><div class="alert alert-danger mb-0">Nenhum destinatario valido. Verifique se os tecnicos da OS possuem e-mail cadastrado.</div><% } %>
  <% if (osEmailError === 'invalid_cc') { %><div class="alert alert-danger mb-0">Existe e-mail invalido no campo CC.</div><% } %>
  <% if (osEmailError === 'smtp') { %><div class="alert alert-danger mb-0">Configuracao SMTP indisponivel. Configure o SMTP no modulo Manutencao Report Service.</div><% } %>
  <% if (osEmailError === 'send_failed') { %><div class="alert alert-danger mb-0">Falha ao enviar o e-mail da OS. Verifique a configuracao SMTP.</div><% } %>
  <% if (editLocked) { %><div class="alert alert-warning mb-0">OS aprovada. Edicao bloqueada. Use <strong>Revalidar OS</strong> para liberar.</div><% } %>
  <% if (revalidated) { %><div class="alert alert-success mb-0">OS revalidada com sucesso. Status atualizado para <strong>valid</strong>.</div><% } %>
  <% if (revalidateError === 'forbidden_admin') { %><div class="alert alert-warning mb-0">Somente usuario com perfil <strong>admin</strong> pode revalidar OS.</div><% } %>
  <% if (revalidateError === 'invalid_state') { %><div class="alert alert-warning mb-0">A OS precisa estar com status <strong>approved</strong> para revalidar.</div><% } %>
  <% if (signLocked) { %><div class="alert alert-warning mb-0">Assinatura do relatorio liberada apenas para OS com status <strong>valid</strong>.</div><% } %>
  <% if (validationSuccess) { %><div class="alert alert-success mb-0">OS validada com sucesso. Status atualizado para <strong>valid</strong>.</div><% } %>
  <% if (validationError && osValidation && !osValidation.valid) { %>
    <div class="alert alert-danger mb-0">
      <div class="fw-semibold mb-1">Nao foi possivel validar a OS. Pendencias:</div>
      <ul class="mb-0">
        <% (osValidation.missing || []).forEach((item) => { %>
          <li><%= item %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="row g-3 report-editor-layout">
    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Associar equipamento a OS</h2>
          <div class="d-flex justify-content-end mb-2">
            <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/equipments">Adicionar novo equipamento</a>
          </div>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/equipments" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12">
              <select class="form-select" name="equipment_id" required>
                <option value="">Selecione equipamento</option>
                <% equipments.forEach((equipment) => { %>
                  <option value="<%= equipment.id %>">#<%= equipment.id %> - <%= equipment.type %> (<%= equipment.serial_number || "-" %>)</option>
                <% }) %>
                <% if (!equipments.length) { %>
                  <option value="" disabled>Nenhum equipamento do cliente/site desta OS</option>
                <% } %>
              </select>
            </div>
            <div class="col-12"><input class="form-control" name="notes" placeholder="Notas" /></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary btn-sm" type="submit">Associar</button></div>
          </form>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>ID Ref</th><th>Tipo</th><th>Serial</th><th>Tag</th><th>Acoes</th></tr></thead>
              <tbody>
                <% if (!orderEquipments.length) { %><tr><td colspan="5" class="text-center text-muted py-3">Sem equipamentos associados.</td></tr><% } %>
                <% orderEquipments.forEach((item) => { %>
                  <tr>
                    <td><%= item.ref_id || item.equipment_id %></td>
                    <td><%= item.type %></td>
                    <td><%= item.serial_number || "-" %></td>
                    <td><%= item.tag_number || "-" %></td>
                    <td>
                      <form method="post" action="/admin/report-service/orders/<%= order.id %>/equipments/<%= item.equipment_id %>/delete" class="m-0" onsubmit="return confirm('Excluir este equipamento associado da OS?');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card" id="timesheet-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="h6 app-card-title mb-0">Timesheet diario</h2>
            <button class="btn btn-outline-secondary btn-sm d-none" type="button" id="timesheetCancelEditBtn">Cancelar edicao</button>
          </div>

          <% if (timesheetError) { %>
            <div class="alert alert-danger py-2 mb-3"><%= timesheetError %></div>
          <% } %>
          <div class="alert alert-danger py-2 mb-3 d-none" id="timesheetOverlapError"></div>

          <form method="post" action="/admin/report-service/orders/<%= order.id %>/timesheet" class="row g-2" id="timesheet-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="_timesheet_entry_id" id="timesheetEntryId" value="" />
            <div class="col-6"><input class="form-control" type="date" name="activity_date" id="tsActivityDate" required /></div>
            <div class="col-6"><input class="form-control" name="technician_name" id="tsTechnicianName" placeholder="Tecnico" /></div>
            <div class="col-6"><input class="form-control" name="check_in_base" id="tsCheckInBase" placeholder="Entrada base HH:MM" /></div>
            <div class="col-6"><input class="form-control" name="check_in_client" id="tsCheckInClient" placeholder="Entrada cliente HH:MM" /></div>
            <div class="col-6"><input class="form-control" name="check_out_client" id="tsCheckOutClient" placeholder="Saida cliente HH:MM" /></div>
            <div class="col-6"><input class="form-control" name="check_out_base" id="tsCheckOutBase" placeholder="Saida base HH:MM" /></div>
            <div class="col-6">
              <input class="form-control bg-light" id="tsWorkedHoursDisplay" placeholder="Horas (auto)" readonly tabindex="-1" />
            </div>
            <div class="col-12"><textarea class="form-control" name="notes" id="tsNotes" rows="2" placeholder="Notas"></textarea></div>
            <div class="col-12 d-flex justify-content-end">
              <button class="btn btn-primary btn-sm" type="submit" id="timesheetSubmitBtn">Adicionar</button>
            </div>
          </form>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0" id="timesheet-table">
              <thead><tr><th>Data</th><th>Tecnico</th><th>In cliente</th><th>Out cliente</th><th>Horas</th><th>Acoes</th></tr></thead>
              <tbody>
                <% if (!timesheet.length) { %><tr><td colspan="6" class="text-center text-muted py-3">Sem registros.</td></tr><% } %>
                <% timesheet.forEach((item) => { %>
                  <tr
                    data-ts-id="<%= item.id %>"
                    data-ts-date="<%= String(item.activity_date || '').slice(0, 10) %>"
                    data-ts-technician="<%= item.technician_name || '' %>"
                    data-ts-in-base="<%= item.check_in_base || '' %>"
                    data-ts-in-client="<%= item.check_in_client || '' %>"
                    data-ts-out-client="<%= item.check_out_client || '' %>"
                    data-ts-out-base="<%= item.check_out_base || '' %>"
                    data-ts-notes="<%= (item.notes || '').replace(/\"/g, '&quot;') %>"
                  >
                    <td><%= formatDateOnly(item.activity_date) %></td>
                    <td><%= item.technician_name || "-" %></td>
                    <td><%= item.check_in_client || "-" %></td>
                    <td><%= item.check_out_client || "-" %></td>
                    <td><%= item.worked_hours != null ? Number(item.worked_hours).toFixed(2) + ' h' : '-' %></td>
                    <td>
                      <div class="d-flex gap-1">
                        <button class="btn btn-outline-primary btn-sm ts-edit-btn" type="button">Editar</button>
                        <form method="post" action="/admin/report-service/orders/<%= order.id %>/timesheet/<%= item.id %>/delete" class="m-0" onsubmit="return confirm('Excluir este registro de timesheet?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card app-card daily-log-editor-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="h6 app-card-title mb-0">Descricao diaria do atendimento</h2>
            <div class="d-flex align-items-center gap-2">
              <button class="btn btn-outline-secondary btn-sm d-none" type="button" id="dailyLogCancelEditBtn">Cancelar edicao</button>
              <button class="btn btn-primary btn-sm" type="submit" form="daily-log-form" id="dailyLogSubmitBtn">Adicionar log diario</button>
            </div>
          </div>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/daily-logs" class="row g-2" id="daily-log-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="daily_log_id" value="" data-daily-log-id />
            <input type="hidden" name="notes" value="" data-daily-log-notes />
            <div class="col-12 col-md-3"><input class="form-control" type="date" name="activity_date" value="<%= todayIso %>" data-default-today required /></div>
            <div class="col-12 col-md-5"><input class="form-control" name="title" placeholder="Titulo opcional" /></div>
            <div class="col-12 col-md-2"><input class="form-control" name="sort_order" placeholder="Ordem" /></div>
            <div class="col-12">
              <div class="d-flex justify-content-between align-items-center gap-2 mb-1">
                <label class="form-label mb-0 small text-muted">Descrever a atividade</label>
                <button class="btn btn-outline-secondary btn-sm" type="button" id="dailyLogAiReviseBtn">Revisar com IA</button>
              </div>
              <div class="small text-muted mb-1" id="dailyLogAiStatus"></div>
              <input type="hidden" name="content" data-daily-log-content />
              <div class="report-quill-editor daily-log-quill-editor" data-daily-log-quill></div>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="h6 app-card-title mb-0">Logs diarios cadastrados</h2>
            <div class="d-flex align-items-center gap-2">
              <span class="small text-muted d-none" id="generateConclusionStatus"></span>
              <button class="btn btn-outline-primary btn-sm" type="button" id="generateConclusionBtn">
                Gerar Conclusao com IA
              </button>
            </div>
          </div>
          <div class="alert alert-success d-none py-2 mb-2" id="generateConclusionSuccess">
            Conclusao geral gerada! Use a tag <code>@conclusaogeral</code> nos capitulos do relatorio. Clique em <strong>Editar</strong> no log gerado para revisar o texto.
          </div>
          <div class="alert alert-danger d-none py-2 mb-2" id="generateConclusionError"></div>
          <div class="table-responsive">
            <table class="table table-sm app-table mb-0 daily-log-table">
              <thead><tr><th>ID</th><th>Data</th><th>Titulo</th><th>Conteudo (resumo)</th><th>Tag para capitulo</th><th>Acoes</th></tr></thead>
              <tbody>
                <% if (!dailyLogs.length) { %><tr><td colspan="6" class="text-center text-muted py-3">Sem logs.</td></tr><% } %>
                <% dailyLogs.forEach((item) => { %>
                  <tr>
                    <td><code><%= item.order_seq %></code></td>
                    <td><%= formatDateShort(item.activity_date) %></td>
                    <td class="daily-log-title-cell" title="<%= item.title || '-' %>"><%= item.title || "-" %></td>
                    <td class="daily-log-content-cell" title="<%= summarizeOneSentence(item.content || "") %>"><%= summarizeOneSentence(item.content || "") %></td>
                    <td><% if (item.notes === 'conclusaogeral') { %><code>@conclusaogeral</code><% } else { %><code>@descricaodia=<%= item.order_seq %></code><% } %></td>
                    <td class="daily-log-actions-cell">
                      <div class="d-flex gap-1">
                        <button
                          class="btn btn-outline-primary btn-sm daily-log-action-btn"
                          type="button"
                          data-daily-log-edit-id="<%= item.id %>"
                        >
                          Editar
                        </button>
                        <form method="post" action="/admin/report-service/orders/<%= order.id %>/daily-logs/<%= item.id %>/delete" class="m-0" onsubmit="return confirm('Excluir este log diario?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="btn btn-outline-danger btn-sm daily-log-action-btn" type="submit">Excluir</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Componentes (tabela)</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/components" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-4">
              <select class="form-select" name="category">
                <% componentCategories.forEach((category) => { %><option value="<%= category %>"><%= category %></option><% }) %>
              </select>
            </div>
            <div class="col-12 col-md-4">
              <select class="form-select" name="equipment_id" id="componentEquipmentSelect">
                <option value="">Sem equipamento</option>
                <% orderEquipments.forEach((item) => { %><option value="<%= item.equipment_id %>"><%= item.type %></option><% }) %>
              </select>
            </div>
            <div class="col-12 col-md-4"><input class="form-control" name="quantity" placeholder="Quantidade" /></div>
            <div class="col-12 col-md-6">
              <select class="form-select" name="description" id="componentDescriptionSelect" required>
                <option value="">Selecione a descricao (spare-part)</option>
              </select>
            </div>
            <div class="col-12 col-md-6"><input class="form-control" name="part_number" id="componentPartNumberInput" placeholder="Part Number" readonly /></div>
            <div class="col-12"><textarea class="form-control" name="notes" rows="2" placeholder="Notas"></textarea></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary btn-sm" type="submit">Adicionar componente</button></div>
          </form>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>Categoria</th><th>Descricao</th><th>P/N</th><th>Qtd</th><th>Acoes</th></tr></thead>
              <tbody>
                <% if (!components.length) { %><tr><td colspan="5" class="text-center text-muted py-3">Sem componentes.</td></tr><% } %>
                <% components.forEach((item) => { %>
                  <tr>
                    <td><%= item.category %></td>
                    <td><%= item.description %></td>
                    <td><%= item.part_number || "-" %></td>
                    <td><%= item.quantity %></td>
                    <td>
                      <form method="post" action="/admin/report-service/orders/<%= order.id %>/components/<%= item.id %>/delete" class="m-0" onsubmit="return confirm('Excluir este spare/componente da OS?');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Equipe tecnica da OS</h2>
          <% const linkedTechIds = new Set((technicians || []).map(function(t){ return t.id; })); %>
          <% const availableTechs = (allGlobalTechnicians || []).filter(function(t){ return !linkedTechIds.has(t.id); }); %>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/technicians/link" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12">
              <select class="form-select" name="technician_id" required>
                <option value="">Selecione tecnico do cadastro</option>
                <% availableTechs.forEach(function(t) { %>
                  <option value="<%= t.id %>"><%= t.name %><% if (t.role) { %> — <%= t.role %><% } %><% if (t.company) { %> (<%= t.company %>)<% } %></option>
                <% }); %>
                <% if (!availableTechs.length) { %>
                  <option value="" disabled>Todos os tecnicos ja estao associados</option>
                <% } %>
              </select>
            </div>
            <div class="col-12 d-flex justify-content-between align-items-center">
