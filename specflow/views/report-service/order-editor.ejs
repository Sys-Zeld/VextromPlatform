<%- include("../partials/head", { pageTitle }) %>
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/quill-better-table@1.2.10/dist/quill-better-table.css" rel="stylesheet" />
<link href="/public/css/report-editor.css" rel="stylesheet" />
<%
  function formatClassicDateTime(value) {
    if (!value) return "-";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "-";
    const weekDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    const day = String(date.getDate()).padStart(2, "0");
    const hours = String(date.getHours()).padStart(2, "0");
    const minutes = String(date.getMinutes()).padStart(2, "0");
    const seconds = String(date.getSeconds()).padStart(2, "0");
    return `${weekDays[date.getDay()]} ${months[date.getMonth()]} ${day} ${date.getFullYear()} ${hours}:${minutes}:${seconds}`;
  }

  function formatDateOnly(value) {
    if (!value) return "-";
    const raw = String(value).trim();
    const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (iso) return `${iso[3]}/${iso[2]}/${iso[1]}`;
    const date = new Date(raw);
    if (Number.isNaN(date.getTime())) return "-";
    const day = String(date.getDate()).padStart(2, "0");
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const year = String(date.getFullYear());
    return `${day}/${month}/${year}`;
  }

  function getSectionImageRegistry(sectionKey) {
    const list = Array.isArray(images) ? images : [];
    return list
      .filter((item) => String(item.section_key || "") === String(sectionKey || ""))
      .sort((a, b) => Number(a.sort_order || 0) - Number(b.sort_order || 0) || Number(a.id || 0) - Number(b.id || 0));
  }

  function getTagImageRegistry() {
    return getSectionImageRegistry("__tag__");
  }

  function extractImageFileName(filePath) {
    return String(filePath || "")
      .split(/[\\/]/)
      .filter(Boolean)
      .pop() || "";
  }
%>

<section class="token-console">
  <div class="card app-card token-hero-card">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">SERVICE REPORT</span>
        <h1 class="h4 app-card-title mb-1"><%= order.service_order_display || "-" %></h1>
        <p class="text-muted mb-0"><%= order.title %> - <%= order.customer_name %></p>
      </div>
      <div class="token-hero-actions">
        <a class="btn btn-outline-secondary btn-sm" href="/admin/hub">Service Hub</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders">Ordens</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>/preview" target="_blank" rel="noopener">Preview HTML</a>
        <form method="post" action="/admin/report-service/orders/<%= order.id %>/generate-pdf">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn-primary btn-sm" type="submit">Gerar PDF</button>
        </form>
      </div>
    </div>
  </div>

  <% if (saved) { %><div class="alert alert-success mb-0">Dados salvos com sucesso.</div><% } %>

  <div class="row g-3 report-editor-layout">
    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Associar equipamento a OS</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/equipments" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12">
              <select class="form-select" name="equipment_id" required>
                <option value="">Selecione equipamento</option>
                <% equipments.forEach((equipment) => { %>
                  <option value="<%= equipment.id %>">#<%= equipment.id %> - <%= equipment.type %> (<%= equipment.serial_number || "-" %>)</option>
                <% }) %>
              </select>
            </div>
            <div class="col-12"><input class="form-control" name="notes" placeholder="Notas" /></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary btn-sm" type="submit">Associar</button></div>
          </form>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>ID Ref</th><th>Tipo</th><th>Serial</th><th>Tag</th></tr></thead>
              <tbody>
                <% if (!orderEquipments.length) { %><tr><td colspan="4" class="text-center text-muted py-3">Sem equipamentos associados.</td></tr><% } %>
                <% orderEquipments.forEach((item) => { %>
                  <tr>
                    <td><%= item.ref_id || item.equipment_id %></td>
                    <td><%= item.type %></td>
                    <td><%= item.serial_number || "-" %></td>
                    <td><%= item.tag_number || "-" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Timesheet diario</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/timesheet" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-6"><input class="form-control" type="date" name="activity_date" required /></div>
            <div class="col-6"><input class="form-control" name="technician_name" placeholder="Tecnico" /></div>
            <div class="col-6"><input class="form-control" name="check_in_base" placeholder="Entrada base" /></div>
            <div class="col-6"><input class="form-control" name="check_in_client" placeholder="Entrada cliente" /></div>
            <div class="col-6"><input class="form-control" name="check_out_client" placeholder="Saida cliente" /></div>
            <div class="col-6"><input class="form-control" name="check_out_base" placeholder="Saida base" /></div>
            <div class="col-6"><input class="form-control" name="worked_hours" placeholder="Horas (opcional)" /></div>
            <div class="col-12"><textarea class="form-control" name="notes" rows="2" placeholder="Notas"></textarea></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary btn-sm" type="submit">Adicionar</button></div>
          </form>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>Data</th><th>Tecnico</th><th>In cliente</th><th>Out cliente</th></tr></thead>
              <tbody>
                <% if (!timesheet.length) { %><tr><td colspan="4" class="text-center text-muted py-3">Sem registros.</td></tr><% } %>
                <% timesheet.forEach((item) => { %>
                  <tr>
                    <td><%= formatDateOnly(item.activity_date) %></td>
                    <td><%= item.technician_name || "-" %></td>
                    <td><%= item.check_in_client || "-" %></td>
                    <td><%= item.check_out_client || "-" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Descricao diaria do atendimento</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/daily-logs" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-3"><input class="form-control" type="date" name="activity_date" required /></div>
            <div class="col-12 col-md-5"><input class="form-control" name="title" placeholder="Titulo opcional" /></div>
            <div class="col-12 col-md-2"><input class="form-control" name="sort_order" placeholder="Ordem" /></div>
            <div class="col-12"><textarea class="form-control" name="content" rows="3" placeholder="Descricao tecnica"></textarea></div>
            <div class="col-12"><textarea class="form-control" name="notes" rows="2" placeholder="Observacoes"></textarea></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary btn-sm" type="submit">Adicionar log diario</button></div>
          </form>
          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>Data</th><th>Titulo</th><th>Conteudo</th></tr></thead>
              <tbody>
                <% if (!dailyLogs.length) { %><tr><td colspan="3" class="text-center text-muted py-3">Sem logs.</td></tr><% } %>
                <% dailyLogs.forEach((item) => { %>
                  <tr>
                    <td><%= formatClassicDateTime(item.activity_date) %></td>
                    <td><%= item.title || "-" %></td>
                    <td><%= item.content || "-" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="h6 app-card-title mb-0">Capitulos editaveis do relatorio</h2>
            <form method="post" action="/admin/report-service/orders/<%= order.id %>/sections" class="d-flex gap-2 align-items-center">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input class="form-control form-control-sm" name="section_title" placeholder="Titulo do novo capitulo" required />
              <button class="btn btn-outline-primary btn-sm" type="submit">Adicionar capitulo</button>
            </form>
          </div>
          <div class="report-section-cards">
            <% sections.forEach((section, index) => { %>
              <form
                method="post"
                action="/admin/report-service/orders/<%= order.id %>/sections/<%= section.section_key %>"
                class="report-section-card"
                data-report-section-form
                data-section-key="<%= section.section_key %>"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="section_title" value="<%= section.section_title || '' %>" data-section-title-text />
                <input type="hidden" name="section_title_delta_json" value='<%= JSON.stringify(section?.section_title_delta_json || { ops: [{ insert: "\\n" }] }) %>' data-section-title-delta />
                <input type="hidden" name="section_title_html" value="<%= section ? section.section_title_html : '' %>" data-section-title-html />
                <input type="hidden" name="section_title_text" value="<%= section ? section.section_title_text : '' %>" data-section-title-plain />

                <input type="hidden" name="content_delta_json" value='<%= JSON.stringify(section?.content_delta_json || { ops: [{ insert: "\\n" }] }) %>' data-section-delta />
                <input type="hidden" name="content_html" value="<%= section ? section.content_html : '' %>" data-section-html />
                <input type="hidden" name="content_text" value="<%= section ? section.content_text : '' %>" data-section-text />

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                  <div>
                    <span class="badge bg-secondary-subtle text-secondary-emphasis border">Capitulo <%= index + 1 %></span>
                    <code class="small ms-2"><%= section.section_key %></code>
                  </div>
                  <div class="d-flex align-items-center gap-2 flex-wrap">
                    <div class="form-check form-switch m-0">
                      <input type="hidden" name="is_visible" value="false" />
                      <input class="form-check-input" type="checkbox" name="is_visible" value="true" <%= section?.is_visible === false ? "" : "checked" %> />
                      <label class="form-check-label">Exibir secao</label>
                    </div>
                    <button
                      class="btn btn-outline-danger btn-sm"
                      type="submit"
                      formaction="/admin/report-service/orders/<%= order.id %>/sections/<%= section.section_key %>/delete"
                      formnovalidate
                      onclick="return confirm('Excluir este capitulo?');"
                    >
                      Excluir capitulo
                    </button>
                    <button class="btn btn-outline-primary btn-sm" type="submit">Salvar capitulo</button>
                  </div>
                </div>

                <label class="form-label mb-1 small text-muted">Titulo do capitulo (rich text)</label>
                <div class="small text-muted mb-2">
                  Use este campo somente para o titulo do capitulo (primeira linha). O conteudo do relatorio deve ser escrito no campo abaixo.
                </div>
                <div class="report-quill-title-editor mb-3" data-quill-title-editor></div>

                <label class="form-label mb-1 small text-muted">Conteudo do capitulo</label>
                <div class="small text-muted mb-2">
                  Use <code>@img=ID</code> para imagem, <code>@tblcmpr</code> (replaced), <code>@tblcmpq</code> (required), <code>@tblcmps</code> (spare) para tabelas de componentes, <code>@timesheet</code> para tabela de timesheet e <code>@equip=ID</code> para inserir o TAG do equipamento cadastrado.
                </div>
                <div class="report-quill-editor" data-quill-editor></div>

              </form>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Banco de imagens para tags (@img=ID)</h2>
          <div class="border rounded p-3 mt-1 bg-light">
            <div class="fw-semibold mb-2">Importar imagem para docs/report/img</div>
            <div class="row g-2 align-items-end">
              <div class="col-12 col-md-6">
                <label class="form-label mb-1">Arquivo de imagem</label>
                <input type="file" class="form-control" id="tagImageFileInput" accept="image/png,image/jpeg,image/webp,image/gif" />
              </div>
              <div class="col-12 col-md-4">
                <label class="form-label mb-1">Legenda (opcional)</label>
                <input class="form-control" id="tagImageCaptionInput" placeholder="Imagem importada" />
              </div>
              <div class="col-12 col-md-2">
                <button class="btn btn-outline-primary w-100" type="button" id="tagImageImportBtn">Importar</button>
              </div>
            </div>
            <div class="small text-muted mt-2" id="tagImageImportStatus">Selecione um arquivo para importar.</div>
          </div>

          <div class="small text-muted mt-2">
            Use no texto do capitulo: <code>@img=ID</code> para renderizar a imagem no preview no ponto da tag.
          </div>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>ID</th><th>Arquivo</th><th>Legenda</th><th>Acoes</th></tr></thead>
              <tbody>
                <% const tagImageRegistry = getTagImageRegistry(); %>
                <% if (!tagImageRegistry.length) { %><tr><td colspan="4" class="text-center text-muted py-3">Sem imagens cadastradas para tags.</td></tr><% } %>
                <% tagImageRegistry.forEach((item) => { %>
                  <tr>
                    <td><code><%= item.ref_id || item.id %></code></td>
                    <td><code><%= extractImageFileName(item.file_path) %></code></td>
                    <td><%= item.caption || "-" %></td>
                    <td>
                      <form method="post" action="/admin/report-service/orders/<%= order.id %>/images/<%= (item.ref_id || item.id) %>/delete" class="m-0" onsubmit="return confirm('Excluir esta imagem do banco de tags?');">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Componentes (tabela)</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/components" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-4">
              <select class="form-select" name="category">
                <% componentCategories.forEach((category) => { %><option value="<%= category %>"><%= category %></option><% }) %>
              </select>
            </div>
            <div class="col-12 col-md-4">
              <select class="form-select" name="equipment_id">
                <option value="">Sem equipamento</option>
                <% orderEquipments.forEach((item) => { %><option value="<%= item.equipment_id %>"><%= item.type %></option><% }) %>
              </select>
            </div>
            <div class="col-12 col-md-4"><input class="form-control" name="quantity" placeholder="Quantidade" /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="description" placeholder="Descricao" required /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="part_number" placeholder="Part Number" /></div>
            <div class="col-12"><textarea class="form-control" name="notes" rows="2" placeholder="Notas"></textarea></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary btn-sm" type="submit">Adicionar componente</button></div>
          </form>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>Categoria</th><th>Descricao</th><th>P/N</th><th>Qtd</th></tr></thead>
              <tbody>
                <% if (!components.length) { %><tr><td colspan="4" class="text-center text-muted py-3">Sem componentes.</td></tr><% } %>
                <% components.forEach((item) => { %>
                  <tr>
                    <td><%= item.category %></td>
                    <td><%= item.description %></td>
                    <td><%= item.part_number || "-" %></td>
                    <td><%= item.quantity %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Assinaturas</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/signatures" class="row g-2 mb-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-6">
              <select class="form-select" name="signer_type">
                <% signerTypes.forEach((type) => { %><option value="<%= type %>"><%= type %></option><% }) %>
              </select>
            </div>
            <div class="col-12 col-md-6"><input class="form-control" name="signer_name" placeholder="Nome do signatario" required /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="signer_role" placeholder="Cargo" /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="signer_company" placeholder="Empresa" /></div>
            <div class="col-12">
              <label class="form-label">Assinatura (canvas)</label>
              <canvas id="signatureCanvas" width="680" height="180" class="w-100 border rounded bg-white"></canvas>
              <input type="hidden" name="signature_data" id="signatureDataInput" />
              <div class="d-flex gap-2 mt-2">
                <button class="btn btn-outline-secondary btn-sm" type="button" id="signatureClearBtn">Limpar assinatura</button>
                <button class="btn btn-outline-primary btn-sm" type="button" id="signatureUseBtn">Usar assinatura</button>
              </div>
            </div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-primary btn-sm" type="submit">Salvar assinatura</button></div>
          </form>
          <div class="table-responsive">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>Tipo</th><th>Nome</th><th>Cargo</th><th>Empresa</th></tr></thead>
              <tbody>
                <% if (!signatures.length) { %><tr><td colspan="4" class="text-center text-muted py-3">Sem assinaturas.</td></tr><% } %>
                <% signatures.forEach((item) => { %>
                  <tr>
                    <td><%= item.signer_type %></td>
                    <td><%= item.signer_name %></td>
                    <td><%= item.signer_role || "-" %></td>
                    <td><%= item.signer_company || "-" %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Equipe tecnica</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/technicians" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-6"><input class="form-control" name="name" placeholder="Nome" required /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="role" placeholder="Funcao" /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="company" placeholder="Empresa" /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="email" placeholder="Email" /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="phone" placeholder="Telefone" /></div>
            <div class="col-12 col-md-6 d-flex align-items-center"><div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="is_lead" value="true" /><label class="form-check-label">Lider</label></div></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-outline-primary btn-sm" type="submit">Adicionar tecnico</button></div>
          </form>
          <ul class="mt-3 mb-0">
            <% if (!technicians.length) { %><li class="text-muted">Sem tecnicos.</li><% } %>
            <% technicians.forEach((item) => { %><li><strong><%= item.name %></strong> - <%= item.role || "-" %> (<%= item.company || "-" %>)</li><% }) %>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-12 col-xl-6">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Instrumentos utilizados</h2>
          <form method="post" action="/admin/report-service/orders/<%= order.id %>/instruments" class="row g-2">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-6"><input class="form-control" name="name" placeholder="Nome do instrumento" required /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="model" placeholder="Modelo" /></div>
            <div class="col-12 col-md-6"><input class="form-control" name="serial_number" placeholder="Serial" /></div>
            <div class="col-12 col-md-6"><input class="form-control" type="date" name="calibration_due_date" /></div>
            <div class="col-12"><textarea class="form-control" name="notes" rows="2" placeholder="Notas"></textarea></div>
            <div class="col-12 d-flex justify-content-end"><button class="btn btn-outline-primary btn-sm" type="submit">Adicionar instrumento</button></div>
          </form>
          <ul class="mt-3 mb-0">
            <% if (!instruments.length) { %><li class="text-muted">Sem instrumentos.</li><% } %>
            <% instruments.forEach((item) => { %><li><strong><%= item.name %></strong> - <%= item.model || "-" %> (SN: <%= item.serial_number || "-" %>)</li><% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill-better-table@1.2.10/dist/quill-better-table.min.js"></script>
<script>
  (function () {
    var canvas = document.getElementById("signatureCanvas");
    var outputInput = document.getElementById("signatureDataInput");
    var clearBtn = document.getElementById("signatureClearBtn");
    var useBtn = document.getElementById("signatureUseBtn");
    if (!canvas || !outputInput || !clearBtn || !useBtn) return;

    var ctx = canvas.getContext("2d");
    var drawing = false;

    function getPosition(event) {
      var rect = canvas.getBoundingClientRect();
      var source = event.touches && event.touches[0] ? event.touches[0] : event;
      return {
        x: source.clientX - rect.left,
        y: source.clientY - rect.top
      };
    }

    function startDraw(event) {
      drawing = true;
      var point = getPosition(event);
      ctx.beginPath();
      ctx.moveTo(point.x, point.y);
      event.preventDefault();
    }

    function draw(event) {
      if (!drawing) return;
      var point = getPosition(event);
      ctx.lineWidth = 2;
      ctx.lineCap = "round";
      ctx.strokeStyle = "#1a1a1a";
      ctx.lineTo(point.x, point.y);
      ctx.stroke();
      event.preventDefault();
    }

    function endDraw(event) {
      drawing = false;
      event.preventDefault();
    }

    canvas.addEventListener("mousedown", startDraw);
    canvas.addEventListener("mousemove", draw);
    canvas.addEventListener("mouseup", endDraw);
    canvas.addEventListener("mouseleave", endDraw);
    canvas.addEventListener("touchstart", startDraw, { passive: false });
    canvas.addEventListener("touchmove", draw, { passive: false });
    canvas.addEventListener("touchend", endDraw, { passive: false });

    clearBtn.addEventListener("click", function () {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      outputInput.value = "";
    });

    useBtn.addEventListener("click", function () {
      outputInput.value = canvas.toDataURL("image/png");
    });
  })();
</script>
