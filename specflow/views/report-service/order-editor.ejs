<script>
  (function () {
    var dailyLogForm = document.querySelector('form[action="/admin/report-service/orders/<%= order.id %>/daily-logs"]');
    if (!dailyLogForm) return;

    var dateInput = dailyLogForm.querySelector("input[data-default-today]");
    var idInput = dailyLogForm.querySelector("input[data-daily-log-id]");
    var notesInput = dailyLogForm.querySelector("input[data-daily-log-notes]");
    var titleInput = dailyLogForm.querySelector('input[name="title"]');
    var sortOrderInput = dailyLogForm.querySelector('input[name="sort_order"]');
    var submitBtn = document.getElementById("dailyLogSubmitBtn");
    var cancelEditBtn = document.getElementById("dailyLogCancelEditBtn");
    var aiReviseBtn = document.getElementById("dailyLogAiReviseBtn");
    var aiStatus = document.getElementById("dailyLogAiStatus");
    var csrfInput = dailyLogForm.querySelector('input[name="_csrf"]');
    var csrfToken = csrfInput ? csrfInput.value : "";
    if (dateInput) {
      var now = new Date();
      var yyyy = String(now.getFullYear());
      var mm = String(now.getMonth() + 1).padStart(2, "0");
      var dd = String(now.getDate()).padStart(2, "0");
      dateInput.value = yyyy + "-" + mm + "-" + dd;
    }

    var editorEl = dailyLogForm.querySelector("[data-daily-log-quill]");
    var contentInput = dailyLogForm.querySelector("[data-daily-log-content]");
    if (!editorEl || !contentInput || typeof window.Quill === "undefined") return;

    var dailyToolbar = [
      [{ header: [1, 2, false] }],
      ["bold", "italic", "underline"],
      [{ align: [] }],
      [{ list: "ordered" }, { list: "bullet" }],
      ["blockquote", "link"],
      ["clean"]
    ];
    var dailyFormats = ["header", "bold", "italic", "underline", "align", "list", "blockquote", "link"];

    var quill = new window.Quill(editorEl, {
      theme: "snow",
      modules: { toolbar: dailyToolbar },
      formats: dailyFormats,
      placeholder: "Descreva a atividade diaria..."
    });
    quill.format("align", "justify", "silent");

    function getTodayRichDateLabel() {
      var now = new Date();
      var months = [
        "JANEIRO",
        "FEVEREIRO",
        "MARCO",
        "ABRIL",
        "MAIO",
        "JUNHO",
        "JULHO",
        "AGOSTO",
        "SETEMBRO",
        "OUTUBRO",
        "NOVEMBRO",
        "DEZEMBRO"
      ];
      var day = String(now.getDate());
      var monthLabel = months[now.getMonth()] || "";
      return (day + " " + monthLabel).trim();
    }

    function seedEditorWithTodayDate() {
      var label = getTodayRichDateLabel();
      quill.setContents([
        { insert: label, attributes: { bold: true } },
        { insert: "\n", attributes: { align: "justify" } }
      ]);
      quill.setSelection(quill.getLength(), 0, "silent");
    }

    function resetFormToCreate() {
      if (idInput) idInput.value = "";
      if (notesInput) notesInput.value = "";
      if (titleInput) titleInput.value = "";
      if (sortOrderInput) sortOrderInput.value = "";
      if (dateInput) {
        var now = new Date();
        dateInput.value = String(now.getFullYear()) + "-" + String(now.getMonth() + 1).padStart(2, "0") + "-" + String(now.getDate()).padStart(2, "0");
      }
      seedEditorWithTodayDate();
      if (submitBtn) submitBtn.textContent = "Adicionar log diario";
      if (cancelEditBtn) cancelEditBtn.classList.add("d-none");
    }

    seedEditorWithTodayDate();

    var logs = Array.isArray(window.dailyLogsIndex) ? window.dailyLogsIndex : [];
    var logsById = new Map(
      logs
        .filter(function (item) { return Number.isInteger(Number(item && item.id)) && Number(item.id) > 0; })
        .map(function (item) { return [Number(item.id), item]; })
    );
    var editButtons = Array.prototype.slice.call(document.querySelectorAll("[data-daily-log-edit-id]"));
    editButtons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var logId = Number(btn.getAttribute("data-daily-log-edit-id") || 0);
        var item = logsById.get(logId);
        if (!item) return;
        if (idInput) idInput.value = String(item.id || "");
        if (notesInput) notesInput.value = item.notes || "";
        if (dateInput) dateInput.value = String(item.activityDate || "").slice(0, 10);
        if (titleInput) titleInput.value = item.title || "";
        if (sortOrderInput) sortOrderInput.value = Number(item.sortOrder || 0) ? String(item.sortOrder) : "";
        quill.setText("");
        if (item.content) quill.clipboard.dangerouslyPasteHTML(item.content);
        if (submitBtn) submitBtn.textContent = "Salvar edicao";
        if (cancelEditBtn) cancelEditBtn.classList.remove("d-none");
        dailyLogForm.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    if (cancelEditBtn) {
      cancelEditBtn.addEventListener("click", function () {
        resetFormToCreate();
      });
    }

    if (aiReviseBtn) {
      aiReviseBtn.addEventListener("click", async function () {
        var sourceText = quill.getText().replace(/\s+/g, " ").trim();
        var sourceHtml = String(quill.root && quill.root.innerHTML ? quill.root.innerHTML : "").trim();
        if (!sourceText) {
          if (aiStatus) aiStatus.textContent = "Digite um texto no editor para revisar com IA.";
          return;
        }

        var defaultPrompt = "Revise o texto abaixo sem mudar muitas palavras";
        var userPrompt = window.prompt("Informe o prompt para enviar a IA:", defaultPrompt);
        if (userPrompt === null) {
          if (aiStatus) aiStatus.textContent = "Revisao com IA cancelada.";
          return;
        }
        userPrompt = String(userPrompt || "").trim() || defaultPrompt;

        aiReviseBtn.disabled = true;
        if (aiStatus) aiStatus.textContent = "Revisando texto com IA...";
        try {
          var response = await fetch("/admin/report-service/orders/<%= order.id %>/daily-logs/revise-text", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "X-CSRF-Token": csrfToken
            },
            credentials: "same-origin",
            body: JSON.stringify({
              text: sourceText,
              html: sourceHtml,
              prompt: userPrompt,
              preserveFormatting: true
            })
          });
          var payload = await response.json().catch(function () { return {}; });
          if (!response.ok || !payload || !payload.ok) {
            throw new Error(payload && payload.message ? payload.message : "Falha ao revisar texto com IA.");
          }
          var revisedHtml = String(payload.revisedHtml || "").trim();
          if (revisedHtml) {
            quill.setText("");
            quill.clipboard.dangerouslyPasteHTML(revisedHtml);
            if (aiStatus) aiStatus.textContent = "Texto revisado com IA mantendo formatacao.";
          } else {
            var revisedText = String(payload.revisedText || "").trim();
            if (!revisedText) throw new Error("A IA nao retornou texto revisado.");
            quill.setText(revisedText);
            if (aiStatus) aiStatus.textContent = "Texto revisado com IA.";
          }
        } catch (err) {
          if (aiStatus) aiStatus.textContent = err && err.message ? err.message : "Falha ao revisar texto com IA.";
        } finally {
          aiReviseBtn.disabled = false;
        }
      });
    }

    dailyLogForm.addEventListener("submit", function () {
      var plainText = quill.getText().replace(/\s+/g, " ").trim();
      contentInput.value = plainText ? quill.root.innerHTML : "";
    });
  })();
</script>
