<%- include("../partials/head", { pageTitle }) %>
<style>
  @import url("https://cdn.jsdelivr.net/npm/gridjs/dist/theme/mermaid.min.css");

  .spare-parts-grid-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    max-width: 100%;
  }

  .spare-parts-grid-wrap .gridjs-wrapper {
    border: 0;
    box-shadow: none;
  }

  .spare-parts-grid-wrap .gridjs-th,
  .spare-parts-grid-wrap .gridjs-td {
    border-color: color-mix(in srgb, var(--border) 58%, transparent);
    vertical-align: middle !important;
    padding: 0.3rem 0.5rem !important;
    line-height: 1.15 !important;
    font-size: 0.8rem !important;
  }

  .spare-parts-grid-wrap .gridjs-th {
    text-align: center !important;
    font-size: 0.82rem !important;
    font-weight: 600;
  }

  .spare-parts-grid-wrap .gridjs-table .gridjs-tbody > .gridjs-tr:nth-of-type(odd) > .gridjs-td {
    background-color: color-mix(in srgb, var(--surface-2) 78%, transparent) !important;
  }

  .spare-parts-grid-wrap .gridjs-table .gridjs-tbody > .gridjs-tr:nth-of-type(even) > .gridjs-td {
    background-color: color-mix(in srgb, var(--surface-2) 92%, transparent) !important;
  }
</style>
<%
  const errorMessages = {
    equipment_invalid: t("rs.spare.errEquipmentInvalid"),
    equipment_not_found: t("rs.spare.errEquipmentNotFound"),
    spare_part_invalid: t("rs.spare.errSpareInvalid"),
    spare_part_not_found: t("rs.spare.errSpareNotFound"),
    quantity_invalid: t("rs.spare.errQuantityInvalid"),
    family_empty: t("rs.spare.errFamilyEmpty"),
    model_empty: t("rs.spare.errModelEmpty"),
    pn_duplicate: t("rs.spare.errPnDuplicate")
  };
  const errorMessage = error && errorMessages[error] ? errorMessages[error] : "";
%>

<section class="token-console">
  <div class="card app-card token-hero-card">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">SERVICE REPORT</span>
        <h1 class="h4 app-card-title mb-1"><%= t("rs.spare.pageTitle") %></h1>
        <p class="text-muted mb-0"><%= t("rs.spare.pageSubtitle") %></p>
      </div>
      <div class="token-hero-actions">
        <a class="btn btn-outline-secondary btn-sm" href="/admin/hub">Service Hub</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders"><%= t("rs.orders.pageTitle") %></a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/equipments"><%= t("rs.equip.pageTitle") %></a>
        <button class="btn btn-primary btn-sm" type="button" id="printSparePartsBtn"><%= t("rs.spare.printList") %></button>
        <button class="btn btn-outline-secondary btn-sm" type="button" id="exportSparePartsBtn">&#8595; Exportar</button>
        <button class="btn btn-outline-success btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#aiImportModal">&#129302; Importar com IA</button>
      </div>
    </div>
  </div>

  <% if (created) { %><div class="alert alert-success mb-0"><%= t("rs.spare.createdSuccess") %></div><% } %>
  <% if (saved) { %><div class="alert alert-success mb-0"><%= t("rs.spare.updatedSuccess") %></div><% } %>
  <% if (deleted) { %><div class="alert alert-success mb-0"><%= t("rs.spare.deletedSuccess") %></div><% } %>
  <% if (linked) { %><div class="alert alert-success mb-0"><%= t("rs.spare.linkedSuccess") %></div><% } %>
  <% if (unlinked) { %><div class="alert alert-success mb-0"><%= t("rs.spare.unlinkedSuccess") %></div><% } %>
  <% if (quantitySaved) { %><div class="alert alert-success mb-0"><%= t("rs.spare.quantityUpdated") %></div><% } %>
  <% if (autoLinkedCount > 0) { %><div class="alert alert-success mb-0"><%= autoLinkedCount %> <%= t("rs.spare.linkedByFamily") %></div><% } %>
  <% if (autoFamilyNoMatch) { %><div class="alert alert-warning mb-0"><%= t("rs.spare.autoFamilyNoMatch") %></div><% } %>
  <% if (errorMessage) { %><div class="alert alert-danger mb-0"><%= errorMessage %></div><% } %>

  <div class="row g-3">
    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3"><%= t("rs.spare.listTitle") %></h2>
          <form method="post" action="/admin/report-service/spare-parts" class="row g-2 mb-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="col-12 col-md-6">
              <input class="form-control" name="description" placeholder="<%= t('rs.spare.descriptionPh') %>" required />
            </div>
            <div class="col-12 col-md-3">
              <input class="form-control" name="manufacturer" placeholder="<%= t('rs.spare.manufacturerPh') %>" />
            </div>
            <div class="col-12 col-md-3">
              <input class="form-control" name="equipment_model" placeholder="<%= t('rs.spare.modelPh') %>" />
            </div>
            <div class="col-12 col-md-3">
              <input class="form-control" name="part_number" placeholder="<%= t('rs.spare.partNumberPh') %>" />
            </div>
            <div class="col-12 col-md-3">
              <input class="form-control" name="lead_time" placeholder="<%= t('rs.spare.leadTimePh') %>" />
            </div>
            <div class="col-12 col-md-3">
              <input class="form-control" name="replaced_by_part_number" placeholder="<%= t('rs.spare.replacedByPh') %>" />
            </div>
            <div class="col-12 col-md-4">
              <input class="form-control" name="equipment_family" placeholder="<%= t('rs.spare.familyPh') %>" />
            </div>
            <div class="col-12 col-md-2 d-flex align-items-center">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="newSpareObsolete" name="is_obsolete" />
                <label class="form-check-label" for="newSpareObsolete"><%= t("rs.spare.obsolete") %></label>
              </div>
            </div>
            <div class="col-12 d-flex justify-content-end">
              <button class="btn btn-primary btn-sm" type="submit"><%= t("rs.spare.createBtn") %></button>
            </div>
          </form>

          <div class="spare-parts-grid-wrap">
            <div id="sparePartsGrid"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3"><%= t("rs.spare.linkTitle") %></h2>

          <form method="get" action="/admin/report-service/spare-parts" class="row g-2 mb-3" id="sparePartFilterForm">
            <div class="col-12 col-md-4">
              <select class="form-select" name="customer_id" id="sparePartFilterCustomer">
                <option value=""><%= t("rs.spare.allCustomers") %></option>
                <% (customers || []).forEach((customer) => { %>
                  <option value="<%= customer.id %>" <%= Number(selectedCustomerId) === Number(customer.id) ? 'selected' : '' %>>
                    <%= customer.name || '-' %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-md-5">
              <select class="form-select" name="equipment_id" id="sparePartFilterEquipment">
                <option value=""><%= Number(selectedCustomerId) > 0 ? t("rs.spare.selectEquipmentCustomer") : t("rs.spare.selectEquipment") %></option>
                <% (equipments || []).forEach((equipment) => { %>
                  <option value="<%= equipment.id %>" <%= Number(selectedEquipmentId) === Number(equipment.id) ? 'selected' : '' %>>
                    <%= equipment.tag_number || '-' %> - <%= equipment.dt_number || '-' %> - <%= equipment.site_name || '-' %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-md-3 d-flex justify-content-end">
              <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t("rs.spare.loadAssociations") %></button>
            </div>
          </form>

          <% if (selectedEquipment) { %>
            <div class="alert alert-light border mb-3">
              <strong><%= t("rs.spare.selectedEquipLabel") %>:</strong>
              #<%= selectedEquipment.id %> - <%= selectedEquipment.type || '-' %> (Serial: <%= selectedEquipment.serial_number || '-' %>)
              <br />
              <strong>Model Family:</strong> <%= selectedEquipment.model_family || '-' %>
            </div>

            <div class="mb-3 d-flex justify-content-end">
              <button class="btn btn-outline-primary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#autoLinkModal">
                &#128279; <%= t("rs.spare.autoLinkTitle") %>
              </button>
            </div>

            <%# Hidden form submitted by the modal %>
            <form method="post" action="/admin/report-service/spare-parts/equipment-links/auto-family" id="autoLinkForm">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="equipment_id" value="<%= selectedEquipment.id %>" />
              <input type="hidden" name="link_mode" id="autoLinkMode" value="family" />
            </form>

            <form method="post" action="/admin/report-service/spare-parts/equipment-links" class="row g-2 mb-3">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="equipment_id" value="<%= selectedEquipment.id %>" />
              <div class="col-12 col-md-7">
                <select class="form-select" name="spare_part_id" required>
                  <option value=""><%= t("rs.spare.selectSpareToLink") %></option>
                  <% (availableSpareParts || []).forEach((item) => { %>
                    <option value="<%= item.id %>">
                      #<%= item.id %> - <%= item.description || '-' %> (PN: <%= item.part_number || '-' %>)
                    </option>
                  <% }) %>
                  <% if (!(availableSpareParts || []).length) { %>
                    <option value="" disabled><%= t("rs.spare.noSpareAvailable") %></option>
                  <% } %>
                </select>
              </div>
              <div class="col-12 col-md-2">
                <input class="form-control" type="number" min="1" step="1" name="quantity" value="1" required />
              </div>
              <div class="col-12 col-md-3 d-flex justify-content-end">
                <button class="btn btn-primary btn-sm" type="submit"><%= t("rs.spare.linkBtn") %></button>
              </div>
            </form>

            <div class="d-flex justify-content-between align-items-center mb-2">
              <span class="small text-muted"><%= t("rs.spare.linkedSparePartsLabel") %></span>
              <div class="d-flex gap-1">
                <button class="btn btn-outline-secondary btn-sm" type="button" id="exportLinkedSparePartsBtn">&#8595; Exportar</button>
                <button class="btn btn-primary btn-sm" type="button" id="printLinkedSparePartsBtn"><%= t("rs.spare.printList") %></button>
              </div>
            </div>
            <div class="spare-parts-grid-wrap">
              <div id="linkedSparePartsGrid"></div>
            </div>
          <% } else { %>
            <div class="text-muted"><%= t("rs.spare.selectEquipHint") %></div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="modal fade" id="editSparePartModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <form method="post" id="editSparePartForm">
        <div class="modal-header">
          <h5 class="modal-title"><%= t("rs.spare.editTitle") %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('rs.cancel') %>"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="row g-2">
            <div class="col-12 col-md-6"><input class="form-control" name="description" id="editSpDescription" placeholder="<%= t('rs.spare.descriptionPh') %>" required /></div>
            <div class="col-12 col-md-3"><input class="form-control" name="manufacturer" id="editSpManufacturer" placeholder="<%= t('rs.spare.manufacturerPh') %>" /></div>
            <div class="col-12 col-md-3"><input class="form-control" name="equipment_model" id="editSpEquipmentModel" placeholder="<%= t('rs.spare.modelPh') %>" /></div>
            <div class="col-12 col-md-3"><input class="form-control" name="part_number" id="editSpPartNumber" placeholder="<%= t('rs.spare.partNumberPh') %>" /></div>
            <div class="col-12 col-md-3"><input class="form-control" name="lead_time" id="editSpLeadTime" placeholder="<%= t('rs.spare.leadTimePh') %>" /></div>
            <div class="col-12 col-md-3"><input class="form-control" name="replaced_by_part_number" id="editSpReplacedBy" placeholder="<%= t('rs.spare.replacedByPh') %>" /></div>
            <div class="col-12 col-md-4"><input class="form-control" name="equipment_family" id="editSpFamily" placeholder="<%= t('rs.spare.familyPh') %>" /></div>
            <div class="col-12 col-md-2 d-flex align-items-center">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" id="editSpObsolete" name="is_obsolete" />
                <label class="form-check-label" for="editSpObsolete"><%= t("rs.spare.obsolete") %></label>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-dismiss="modal"><%= t("rs.cancel") %></button>
          <button class="btn btn-primary btn-sm" type="submit"><%= t("rs.save") %></button>
        </div>
      </form>
    </div>
  </div>
</div>

<form method="post" id="deleteSparePartForm" class="d-none">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
</form>

<script src="https://cdn.jsdelivr.net/npm/gridjs/dist/gridjs.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script>
  (function () {
    var spareParts = <%- JSON.stringify(spareParts || []).replace(/</g, "\\u003c") %>;
    var gridTarget = document.getElementById("sparePartsGrid");
    var editModalEl = document.getElementById("editSparePartModal");
    var editForm = document.getElementById("editSparePartForm");
    var deleteForm = document.getElementById("deleteSparePartForm");
    if (!gridTarget || !window.gridjs || !window.gridjs.Grid || !editForm || !deleteForm) return;

    var i18n = {
      edit: <%- JSON.stringify(t("rs.edit")) %>,
      deleteBtn: <%- JSON.stringify(t("rs.delete")) %>,
      confirmDelete: <%- JSON.stringify(t("rs.spare.confirmDelete")) %>,
      colId: "ID",
      colDescription: <%- JSON.stringify(t("rs.spare.colDescription")) %>,
      colManufacturer: <%- JSON.stringify(t("rs.spare.colManufacturer")) %>,
      colModel: <%- JSON.stringify(t("rs.spare.colModel")) %>,
      colPartNumber: <%- JSON.stringify(t("rs.spare.colPartNumber")) %>,
      colLeadTime: <%- JSON.stringify(t("rs.spare.colLeadTime")) %>,
      colObsolete: <%- JSON.stringify(t("rs.spare.colObsolete")) %>,
      colReplacedBy: <%- JSON.stringify(t("rs.spare.colReplacedBy")) %>,
      colFamily: <%- JSON.stringify(t("rs.spare.colFamily")) %>,
      colActions: <%- JSON.stringify(t("rs.actions")) %>,
      yes: <%- JSON.stringify(t("rs.spare.yes")) %>,
      no: <%- JSON.stringify(t("rs.spare.no")) %>,
      searchPh: <%- JSON.stringify(t("rs.spare.searchPh")) %>,
      loading: <%- JSON.stringify(t("rs.loading")) %>,
      noRecords: <%- JSON.stringify(t("rs.noRecords")) %>,
      error: <%- JSON.stringify(t("rs.error")) %>,
      noSpare: <%- JSON.stringify(t("rs.spare.noSpare")) %>
    };

    function esc(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function actionButtons(row) {
      var id = Number(row.id || 0);
      return ""
        + "<div class=\"d-flex gap-1\">"
        + "<button class=\"btn btn-outline-primary btn-sm\" type=\"button\" data-edit-spare-part=\"" + id + "\">" + i18n.edit + "</button>"
        + "<button class=\"btn btn-outline-danger btn-sm\" type=\"button\" data-delete-spare-part=\"" + id + "\">" + i18n.deleteBtn + "</button>"
        + "</div>";
    }

    var data = (spareParts || []).map(function (row) {
      return {
        id: Number(row.id || 0),
        description: esc(row.description || "-"),
        manufacturer: esc(row.manufacturer || "-"),
        equipmentModel: esc(row.equipment_model || "-"),
        partNumber: esc(row.part_number || "-"),
        leadTime: esc(row.lead_time || "-"),
        obsolete: row.is_obsolete ? i18n.yes : i18n.no,
        replacedBy: esc(row.replaced_by_part_number || "-"),
        family: esc(row.equipment_family || "-"),
        actions: actionButtons(row)
      };
    });

    window._sparePartsGridData = data;
    window._sparePartsGridI18n = i18n;

    if (!data.length) {
      gridTarget.innerHTML = "<div class=\"text-center text-muted py-4\">" + i18n.noSpare + "</div>";
      return;
    }

    new window.gridjs.Grid({
      columns: [
        { id: "id", name: i18n.colId, width: "80px" },
        { id: "description", name: i18n.colDescription, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "manufacturer", name: i18n.colManufacturer, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "equipmentModel", name: i18n.colModel, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "partNumber", name: i18n.colPartNumber, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "leadTime", name: i18n.colLeadTime, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "obsolete", name: i18n.colObsolete },
        { id: "replacedBy", name: i18n.colReplacedBy, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "family", name: i18n.colFamily, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "actions", name: i18n.colActions, sort: false, formatter: function (cell) { return window.gridjs.html(cell); } }
      ],
      data: data,
      search: true,
      sort: true,
      pagination: { limit: 15, summary: false },
      language: {
        search: { placeholder: i18n.searchPh },
        loading: i18n.loading,
        noRecordsFound: i18n.noRecords,
        error: i18n.error
      }
    }).render(gridTarget);

    function openEditModal(item) {
      editForm.action = "/admin/report-service/spare-parts/" + encodeURIComponent(String(item.id)) + "/update";
      document.getElementById("editSpDescription").value = item.description || "";
      document.getElementById("editSpManufacturer").value = item.manufacturer || "";
      document.getElementById("editSpEquipmentModel").value = item.equipment_model || "";
      document.getElementById("editSpPartNumber").value = item.part_number || "";
      document.getElementById("editSpLeadTime").value = item.lead_time || "";
      document.getElementById("editSpReplacedBy").value = item.replaced_by_part_number || "";
      document.getElementById("editSpFamily").value = item.equipment_family || "";
      document.getElementById("editSpObsolete").checked = Boolean(item.is_obsolete);
      if (window.bootstrap && editModalEl) {
        window.bootstrap.Modal.getOrCreateInstance(editModalEl).show();
      }
    }

    document.addEventListener("click", function (event) {
      var editBtn = event.target.closest("[data-edit-spare-part]");
      if (editBtn) {
        var editId = Number(editBtn.getAttribute("data-edit-spare-part") || 0);
        var item = (spareParts || []).find(function (it) { return Number(it.id) === editId; });
        if (item) openEditModal(item);
        return;
      }

      var deleteBtn = event.target.closest("[data-delete-spare-part]");
      if (!deleteBtn) return;
      var deleteId = Number(deleteBtn.getAttribute("data-delete-spare-part") || 0);
      if (!deleteId) return;
      if (!window.confirm(i18n.confirmDelete)) return;
      deleteForm.action = "/admin/report-service/spare-parts/" + encodeURIComponent(String(deleteId)) + "/delete";
      deleteForm.submit();
    });
  })();
</script>
<script>
  (function () {
    var linkedTarget = document.getElementById("linkedSparePartsGrid");
    if (!linkedTarget || !window.gridjs || !window.gridjs.Grid) return;

    var linkedData = <%- JSON.stringify(linkedSpareParts || []).replace(/</g, "\\u003c") %>;
    var equipmentId = <%- JSON.stringify((selectedEquipment && selectedEquipment.id) ? String(selectedEquipment.id) : "") %>;
    var csrfToken  = <%- JSON.stringify(csrfToken || "") %>;

    var i18n = {
      save: <%- JSON.stringify(t("rs.save")) %>,
      colId: "ID",
      colDescription: <%- JSON.stringify(t("rs.spare.colDescription")) %>,
      colPartNumber: <%- JSON.stringify(t("rs.spare.colPartNumber")) %>,
      colManufacturer: <%- JSON.stringify(t("rs.spare.colManufacturer")) %>,
      colQuantity: <%- JSON.stringify(t("rs.spare.colQuantity")) %>,
      colObsolete: <%- JSON.stringify(t("rs.spare.colObsolete")) %>,
      colActions: <%- JSON.stringify(t("rs.actions")) %>,
      unlinkBtn: <%- JSON.stringify(t("rs.spare.unlinkBtn")) %>,
      confirmUnlink: <%- JSON.stringify(t("rs.spare.confirmUnlink")) %>,
      yes: <%- JSON.stringify(t("rs.spare.yes")) %>,
      no: <%- JSON.stringify(t("rs.spare.no")) %>,
      filterPh: <%- JSON.stringify(t("rs.spare.filterPh")) %>,
      loading: <%- JSON.stringify(t("rs.loading")) %>,
      noRecords: <%- JSON.stringify(t("rs.noRecords")) %>,
      error: <%- JSON.stringify(t("rs.error")) %>,
      noLinked: <%- JSON.stringify(t("rs.spare.noLinked")) %>
    };

    window._linkedSparePartsRaw = linkedData;
    window._linkedSparePartsI18n = i18n;

    if (!linkedData.length) {
      linkedTarget.innerHTML = "<div class=\"text-center text-muted py-4\">" + i18n.noLinked + "</div>";
      return;
    }

    function esc(v) {
      return String(v || "")
        .replace(/&/g, "&amp;").replace(/</g, "&lt;")
        .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
    }

    function qtyCell(row) {
      var url = "/admin/report-service/spare-parts/equipment-links/" + esc(equipmentId) + "/" + esc(row.id) + "/quantity";
      return "<form method=\"post\" action=\"" + url + "\" class=\"d-flex align-items-center gap-1\" style=\"min-width:130px;\">"
        + "<input type=\"hidden\" name=\"_csrf\" value=\"" + esc(csrfToken) + "\" />"
        + "<input class=\"form-control form-control-sm\" type=\"number\" min=\"1\" step=\"1\" name=\"quantity\" value=\"" + Number(row.quantity || 1) + "\" required style=\"width:70px;\" />"
        + "<button class=\"btn btn-outline-primary btn-sm\" type=\"submit\">" + i18n.save + "</button>"
        + "</form>";
    }

    function deleteCell(row) {
      var url = "/admin/report-service/spare-parts/equipment-links/" + esc(equipmentId) + "/" + esc(row.id) + "/delete";
      return "<form method=\"post\" action=\"" + url + "\" onsubmit=\"return confirm('" + i18n.confirmUnlink.replace(/'/g, "\\'") + "');\">"
        + "<input type=\"hidden\" name=\"_csrf\" value=\"" + esc(csrfToken) + "\" />"
        + "<button class=\"btn btn-outline-danger btn-sm\" type=\"submit\">" + i18n.unlinkBtn + "</button>"
        + "</form>";
    }

    var data = linkedData.map(function (row) {
      return {
        id: Number(row.id || 0),
        description: esc(row.description || "-"),
        partNumber: esc(row.part_number || "-"),
        manufacturer: esc(row.manufacturer || "-"),
        quantity: qtyCell(row),
        obsolete: row.is_obsolete ? i18n.yes : i18n.no,
        actions: deleteCell(row)
      };
    });

    new window.gridjs.Grid({
      columns: [
        { id: "id", name: i18n.colId, width: "70px" },
        { id: "description", name: i18n.colDescription, formatter: function (c) { return window.gridjs.html(c); } },
        { id: "partNumber", name: i18n.colPartNumber, formatter: function (c) { return window.gridjs.html(c); } },
        { id: "manufacturer", name: i18n.colManufacturer, formatter: function (c) { return window.gridjs.html(c); } },
        { id: "quantity", name: i18n.colQuantity, sort: false, formatter: function (c) { return window.gridjs.html(c); } },
        { id: "obsolete", name: i18n.colObsolete, width: "90px" },
        { id: "actions", name: i18n.colActions, sort: false, formatter: function (c) { return window.gridjs.html(c); } }
      ],
      data: data,
      search: true,
      sort: true,
      pagination: { limit: 15, summary: false },
      language: {
        search: { placeholder: i18n.filterPh },
        loading: i18n.loading,
        noRecordsFound: i18n.noRecords,
        error: i18n.error
      }
    }).render(linkedTarget);
  })();
</script>
<script>
  (function () {
