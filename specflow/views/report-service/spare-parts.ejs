                <div class="mt-1"><span class="badge bg-secondary"><%= selectedEquipment.type %></span></div>
              <% } %>
            </div>
          </label>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal"><%= t("rs.cancel") %></button>
        <button type="button" class="btn btn-primary btn-sm" id="autoLinkConfirmBtn"><%= t("rs.spare.autoLinkConfirm") %></button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var confirmBtn = document.getElementById("autoLinkConfirmBtn");
  var form = document.getElementById("autoLinkForm");
  var modeInput = document.getElementById("autoLinkMode");
  if (!confirmBtn || !form || !modeInput) return;

  confirmBtn.addEventListener("click", function () {
    var selected = document.querySelector('input[name="autoLinkChoice"]:checked');
    modeInput.value = selected ? selected.value : "family";
    form.submit();
  });
})();
</script>

<%# ===== MODAL IMPORTAR COM IA ===== %>
<div class="modal fade" id="aiImportModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">&#129302; Importar Spare Parts com IA</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">

        <div class="mb-4">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge bg-secondary rounded-pill">1</span>
            <strong class="small">Modelo JSON (schema da tabela spare_parts)</strong>
          </div>
          <p class="text-muted small mb-2">Esta é a estrutura que a IA vai preencher para cada peça encontrada no documento.</p>
          <pre id="aiImportSchema" class="border rounded p-2 small" style="background:#f8f9fa;max-height:160px;overflow:auto;font-size:0.76rem;"></pre>
        </div>

        <div class="mb-4">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge bg-secondary rounded-pill">2</span>
            <strong class="small">Prompt para a IA <span class="text-muted fw-normal">(editável)</span></strong>
          </div>
          <p class="text-muted small mb-2">O prompt é enviado junto com o PDF. Edite as instruções conforme necessário para o seu documento.</p>
          <textarea id="aiImportPrompt" class="form-control font-monospace" rows="10" style="font-size:0.76rem;"></textarea>
        </div>

        <div class="mb-4">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge bg-secondary rounded-pill">3</span>
            <strong class="small">Enviar documento para a IA</strong>
          </div>
          <p class="text-muted small mb-2">Selecione um documento com a lista de spare parts (PDF, TXT ou XLSX). A IA irá ler e extrair todos os dados automaticamente.</p>
          <div class="d-flex gap-2 align-items-center flex-wrap">
            <input class="form-control form-control-sm" type="file" id="aiImportPdfFile" accept="application/pdf,.pdf,text/plain,.txt,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,.xlsx,application/vnd.ms-excel,.xls" style="max-width:420px;" />
            <button class="btn btn-outline-primary btn-sm" type="button" id="aiExtractBtn" disabled>
              <span id="aiExtractSpinner" class="spinner-border spinner-border-sm d-none me-1" role="status"></span>
              Extrair com IA
            </button>
          </div>
          <div id="aiExtractStatus" class="mt-2 small text-muted"></div>
        </div>

        <div class="mb-2" id="aiJsonReviewSection">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge bg-success rounded-pill">4</span>
            <strong class="small">Revisar JSON</strong>
            <span id="aiJsonBadge" class="badge bg-secondary ms-1"></span>
            <span class="text-muted fw-normal small ms-auto">ou carregue um JSON diretamente:</span>
            <input type="file" id="aiJsonFileInput" accept="application/json,.json" class="form-control form-control-sm" style="max-width:200px;" />
          </div>
          <p class="text-muted small mb-2">Revise os dados antes de importar. Você pode editar o JSON manualmente, colá-lo diretamente ou carregar um arquivo <code>.json</code>.</p>
          <textarea id="aiImportJsonEditor" class="form-control font-monospace" rows="14" style="font-size:0.76rem;" placeholder="JSON gerado pela IA ou colado/carregado diretamente..." spellcheck="false"></textarea>
          <div id="aiJsonValidStatus" class="mt-2 small"></div>
        </div>

        <div class="mb-2 mt-3 pt-3 border-top" id="aiEquipmentSection">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="badge bg-secondary rounded-pill">5</span>
            <strong class="small">Associar ao equipamento <span class="text-muted fw-normal">(opcional)</span></strong>
          </div>
          <p class="text-muted small mb-2">
            Se selecionar um equipamento, todos os spare parts importados serão associados a ele.<br />
            PNs já cadastrados serão apenas vinculados (sem duplicação). PNs novos serão cadastrados e vinculados.
          </p>
          <div class="row g-2">
            <div class="col-12 col-md-6">
              <select class="form-select form-select-sm" id="aiImportCustomerSelect">
                <option value="">— Nenhum cliente (não associar) —</option>
                <% (customers || []).forEach(function(c) { %>
                  <option value="<%= c.id %>"><%= c.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-12 col-md-6">
              <select class="form-select form-select-sm" id="aiImportEquipmentSelect" disabled>
                <option value="">— Selecione um cliente primeiro —</option>
              </select>
            </div>
          </div>
        </div>

      </div>
      <div class="modal-footer gap-2 flex-wrap">
        <span id="aiImportResult" class="small me-auto"></span>
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Fechar</button>
        <button type="button" class="btn btn-success btn-sm" id="aiImportBtn" disabled>
          <span id="aiImportSpinner" class="spinner-border spinner-border-sm d-none me-1" role="status"></span>
          Importar Spare Parts
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  window._aiAllEquipments = <%- JSON.stringify((allEquipments || []).map(function(e) {
    return { id: e.id, tag_number: e.tag_number || '', dt_number: e.dt_number || '', serial_number: e.serial_number || '', customer_id: e.customer_id };
  })).replace(/</g, "\\u003c") %>;
</script>
<script>
(function () {
  var csrfToken = "<%= csrfToken %>";
  var aiConfigUrl = "/admin/report-service/spare-parts/ai-config";
  var aiExtractUrl = "/admin/report-service/spare-parts/ai-extract";
  var aiBulkImportUrl = "/admin/report-service/spare-parts/bulk-import";

  var modal = document.getElementById("aiImportModal");
  var pdfFileInput = document.getElementById("aiImportPdfFile");
  var extractBtn = document.getElementById("aiExtractBtn");
  var extractSpinner = document.getElementById("aiExtractSpinner");
  var extractStatus = document.getElementById("aiExtractStatus");
  var promptTextarea = document.getElementById("aiImportPrompt");
  var schemaEl = document.getElementById("aiImportSchema");
  var jsonEditor = document.getElementById("aiImportJsonEditor");
  var jsonBadge = document.getElementById("aiJsonBadge");
  var jsonValidStatus = document.getElementById("aiJsonValidStatus");
  var jsonFileInput = document.getElementById("aiJsonFileInput");
  var importBtn = document.getElementById("aiImportBtn");
  var importSpinner = document.getElementById("aiImportSpinner");
  var importResult = document.getElementById("aiImportResult");
  var customerSelect = document.getElementById("aiImportCustomerSelect");
  var equipmentSelect = document.getElementById("aiImportEquipmentSelect");
  var allEquipments = window._aiAllEquipments || [];

  function buildEquipmentLabel(eq) {
    var parts = [eq.tag_number, eq.dt_number, eq.serial_number].filter(Boolean);
    return parts.length ? parts.join(" - ") : "ID " + eq.id;
  }

  function filterEquipments(customerId) {
    equipmentSelect.innerHTML = "";
    var noneOpt = document.createElement("option");
    noneOpt.value = "";
    if (!customerId) {
      noneOpt.textContent = "— Selecione um cliente primeiro —";
      equipmentSelect.appendChild(noneOpt);
      equipmentSelect.disabled = true;
      return;
    }
    noneOpt.textContent = "— Nenhum equipamento (não associar) —";
    equipmentSelect.appendChild(noneOpt);
    var filtered = allEquipments.filter(function(e) { return Number(e.customer_id) === Number(customerId); });
    filtered.forEach(function(eq) {
      var opt = document.createElement("option");
      opt.value = eq.id;
      opt.textContent = buildEquipmentLabel(eq);
      equipmentSelect.appendChild(opt);
    });
    equipmentSelect.disabled = filtered.length === 0;
    if (filtered.length === 0) {
      noneOpt.textContent = "— Nenhum equipamento para este cliente —";
    }
  }

  if (customerSelect) {
    customerSelect.addEventListener("change", function() {
      filterEquipments(customerSelect.value);
    });
  }

  var _extractStartedAt = null;
  var _extractTimer = null;

  function formatElapsedTime(ms) {
    var sec = Math.max(0, Math.floor((ms || 0) / 1000));
    var mm = String(Math.floor(sec / 60)).padStart(2, "0");
    var ss = String(sec % 60).padStart(2, "0");
    return mm + ":" + ss;
  }

  function setExtractStatus(text, elapsed, cls) {
    extractStatus.className = "mt-2 small " + (cls || "text-muted");
    extractStatus.textContent = "Status: " + text + " | Tempo: " + formatElapsedTime(elapsed);
  }

  function startExtractTimer() {
    _extractStartedAt = Date.now();
    clearInterval(_extractTimer);
    setExtractStatus("Processando...", 0, "text-warning");
    _extractTimer = setInterval(function () {
      setExtractStatus("Processando...", Date.now() - _extractStartedAt, "text-warning");
    }, 1000);
  }

  function stopExtractTimer(statusText, cls) {
    clearInterval(_extractTimer);
    _extractTimer = null;
    var elapsed = _extractStartedAt ? (Date.now() - _extractStartedAt) : 0;
    setExtractStatus(statusText || "Concluído", elapsed, cls || "text-muted");
    _extractStartedAt = null;
    return elapsed;
  }

  if (!modal) return;

  modal.addEventListener("show.bs.modal", function () {
    if (promptTextarea.value) return;
    fetch(aiConfigUrl, { credentials: "same-origin" })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data && data.defaultPrompt) promptTextarea.value = data.defaultPrompt;
        if (data && data.jsonSchema) schemaEl.textContent = data.jsonSchema;
      })
      .catch(function () { extractStatus.textContent = "Erro ao carregar configuracao de IA."; });
  });

  pdfFileInput.addEventListener("change", function () {
    var hasFile = pdfFileInput.files && pdfFileInput.files.length > 0;
    extractBtn.disabled = !hasFile;
    if (!hasFile) extractStatus.textContent = "";
  });

  extractBtn.addEventListener("click", function () {
    var file = pdfFileInput.files && pdfFileInput.files[0];
    if (!file) return;

    extractBtn.disabled = true;
    extractSpinner.classList.remove("d-none");
    importBtn.disabled = true;
    jsonEditor.value = "";
    importResult.textContent = "";
    startExtractTimer();

    var reader = new FileReader();
    reader.onerror = function () {
      stopExtractTimer("Falha", "text-danger");
      extractSpinner.classList.add("d-none");
      extractBtn.disabled = false;
      extractStatus.textContent = "Status: Erro ao ler o arquivo. | Tempo: --:--";
    };
    reader.onload = function () {
      var dataUrl = String(reader.result || "");
      var commaIdx = dataUrl.indexOf(",");
      var fileBase64 = commaIdx >= 0 ? dataUrl.slice(commaIdx + 1) : "";

      fetch(aiExtractUrl, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "x-csrf-token": csrfToken
        },
        credentials: "same-origin",
        body: JSON.stringify({
          fileName: file.name || "documento.pdf",
          mimeType: file.type || "application/pdf",
          fileBase64: fileBase64,
          promptTemplate: promptTextarea.value.trim()
        })
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          extractSpinner.classList.add("d-none");
          extractBtn.disabled = false;
          if (!data || !data.ok) {
            var errMsg = (data && data.message ? data.message : "Erro ao extrair.");
            var elapsed = stopExtractTimer("Falha", "text-danger");
            extractStatus.className = "mt-2 small text-danger";
            extractStatus.textContent = "Status: \u274C " + errMsg + " | Tempo: " + formatElapsedTime(elapsed);
            return;
          }
          stopExtractTimer("Conclu\u00EDdo", "text-success");
          jsonEditor.value = JSON.stringify(data.spareParts, null, 2);
          validateJson();
        })
        .catch(function () {
          stopExtractTimer("Falha", "text-danger");
          extractSpinner.classList.add("d-none");
          extractBtn.disabled = false;
        });
    };
    reader.readAsDataURL(file);
  });

  jsonEditor.addEventListener("input", validateJson);

  if (jsonFileInput) {
    jsonFileInput.addEventListener("change", function () {
      var file = jsonFileInput.files && jsonFileInput.files[0];
      if (!file) return;
      var reader = new FileReader();
      reader.onerror = function () {
        jsonValidStatus.innerHTML = "<span class='text-danger'>\u274C Falha ao ler o arquivo JSON.</span>";
      };
      reader.onload = function () {
        var text = String(reader.result || "").trim();
        jsonEditor.value = text;
        jsonFileInput.value = "";
        validateJson();
      };
      reader.readAsText(file, "utf-8");
    });
  }

  function validateJson() {
    var raw = jsonEditor.value.trim();
    if (!raw) {
      jsonValidStatus.textContent = "";
      jsonBadge.textContent = "";
      importBtn.disabled = true;
      return;
    }
    var parsed;
    try { parsed = JSON.parse(raw); } catch (e) {
      jsonValidStatus.innerHTML = "<span class='text-danger'>\u274C JSON inv\u00e1lido: " + e.message + "</span>";
      jsonBadge.textContent = "inválido";
      jsonBadge.className = "badge bg-danger ms-1";
      importBtn.disabled = true;
      return;
    }
    if (!Array.isArray(parsed)) {
      jsonValidStatus.innerHTML = "<span class='text-danger'>\u274C O JSON deve ser um array [ ].</span>";
      jsonBadge.textContent = "inválido";
      jsonBadge.className = "badge bg-danger ms-1";
      importBtn.disabled = true;
      return;
    }
    var withDesc = parsed.filter(function (item) { return String(item.description || "").trim(); });
    jsonValidStatus.innerHTML = "<span class='text-success'>\u2705 JSON v\u00e1lido &mdash; <strong>" + parsed.length + "</strong> item(s), <strong>" + withDesc.length + "</strong> com descri\u00e7\u00e3o.</span>";
    jsonBadge.textContent = parsed.length + " itens";
    jsonBadge.className = "badge bg-success ms-1";
    importBtn.disabled = withDesc.length === 0;
  }

  importBtn.addEventListener("click", function () {
    var raw = jsonEditor.value.trim();
    var parsed;
    try { parsed = JSON.parse(raw); } catch (_e) { return; }
    if (!Array.isArray(parsed) || !parsed.length) return;

    importBtn.disabled = true;
    importSpinner.classList.remove("d-none");
    importResult.textContent = "Importando...";

    var body = new URLSearchParams();
    body.append("_csrf", csrfToken);
    body.append("spare_parts", JSON.stringify(parsed));
    var selectedEquipmentId = equipmentSelect && equipmentSelect.value ? equipmentSelect.value : "";
    if (selectedEquipmentId) body.append("equipment_id", selectedEquipmentId);

    fetch(aiBulkImportUrl, {
      method: "POST",
      headers: {
        "Content-Type": "application/x-www-form-urlencoded",
        "Accept": "application/json"
      },
      credentials: "same-origin",
      body: body.toString()
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        importSpinner.classList.add("d-none");
        if (!data || !data.ok) {
          importResult.innerHTML = "<span class='text-danger'>\u274C " + (data && data.message ? data.message : "Erro ao importar.") + "</span>";
          importBtn.disabled = false;
          return;
        }
        var skipParts = [];
        if (data.skippedExisting > 0) skipParts.push(data.skippedExisting + " PN j\u00e1 cadastrado" + (data.skippedExisting > 1 ? "s" : ""));
        if (data.skippedIntraJson > 0) skipParts.push(data.skippedIntraJson + " PN duplicado" + (data.skippedIntraJson > 1 ? "s" : "") + " no JSON");
        var skipMsg = skipParts.length ? " &mdash; Ignorados: <strong>" + data.skipped + "</strong> (" + skipParts.join(", ") + ")" : (data.skipped > 0 ? " &mdash; Ignorados: <strong>" + data.skipped + "</strong>" : "");
        var linkedMsg = (data.linked > 0) ? " &mdash; Vinculados ao equipamento: <strong>" + data.linked + "</strong>" : "";
        importResult.innerHTML = "<span class='text-success'>\u2705 Importados: <strong>" + data.inserted + "</strong>" + skipMsg + linkedMsg + "</span>";
        if (data.inserted > 0) {
          setTimeout(function () { window.location.href = "/admin/report-service/spare-parts?created=1"; }, 1600);
        }
      })
      .catch(function () {
        importSpinner.classList.add("d-none");
        importResult.innerHTML = "<span class='text-danger'>\u274C Falha na comunicacao com o servidor.</span>";
        importBtn.disabled = false;
      });
  });
})();
</script>

<%- include("../partials/footer") %>
