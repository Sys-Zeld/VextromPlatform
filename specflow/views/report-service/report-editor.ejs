            rows="4"
            placeholder="Ex: Revise o texto mantendo a formatação, corrija erros gramaticais, use linguagem mais formal..."
          ></textarea>
        </div>
      </div>
      <div class="modal-footer py-2">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="aiReviseModalCancelBtn" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary btn-sm" id="aiReviseModalConfirmBtn">Revisar</button>
      </div>
    </div>
  </div>
</div>
<script>
  (function () {
    var _aiReviseCallback = null;
    var modalEl = document.getElementById("aiReviseModal");
    var input = document.getElementById("aiReviseComplementInput");
    var confirmBtn = document.getElementById("aiReviseModalConfirmBtn");
    var cancelBtn = document.getElementById("aiReviseModalCancelBtn");
    var bsModal = new bootstrap.Modal(modalEl);

    function cleanup() {
      _aiReviseCallback = null;
      if (input) input.value = "";
    }

    modalEl.addEventListener("hidden.bs.modal", function () {
      if (_aiReviseCallback) { _aiReviseCallback(null); }
      cleanup();
    });

    if (confirmBtn) {
      confirmBtn.addEventListener("click", function () {
        var cb = _aiReviseCallback;
        cleanup();
        bsModal.hide();
        if (cb) cb(String(input ? input.value : "").trim());
      });
    }

    window.openAiReviseModal = function (callback) {
      if (input) input.value = "";
      _aiReviseCallback = callback;
      bsModal.show();
      setTimeout(function () { if (input) input.focus(); }, 300);
    };
  })();
</script>

