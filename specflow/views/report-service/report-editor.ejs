<%- include("../partials/head", { pageTitle }) %>
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/quill-better-table@1.2.10/dist/quill-better-table.css" rel="stylesheet" />
<link href="/public/css/report-editor.css" rel="stylesheet" />
<%
  function fmtDate(value) {
    if (!value) return "-";
    const raw = String(value).trim();
    const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (iso) return `${iso[3]}/${iso[2]}/${iso[1].slice(-2)}`;
    const d = new Date(raw);
    if (Number.isNaN(d.getTime())) return "-";
    return `${String(d.getDate()).padStart(2,"0")}/${String(d.getMonth()+1).padStart(2,"0")}/${String(d.getFullYear()).slice(-2)}`;
  }
  function fmtDateTime(value) {
    if (!value) return "-";
    const d = new Date(value);
    if (Number.isNaN(d.getTime())) return "-";
    const dd = String(d.getDate()).padStart(2,"0");
    const mo = String(d.getMonth()+1).padStart(2,"0");
    const yy = String(d.getFullYear()).slice(-2);
    const hh = String(d.getHours()).padStart(2,"0");
    const mi = String(d.getMinutes()).padStart(2,"0");
    const ss = String(d.getSeconds()).padStart(2,"0");
    return `${dd}/${mo}/${yy} ${hh}:${mi}:${ss}`;
  }

  function extractImageFileName(filePath) {
    return String(filePath || "")
      .split(/[\\/]/)
      .filter(Boolean)
      .pop() || "";
  }

  function getSectionImageRegistry(sectionKey) {
    const list = Array.isArray(images) ? images : [];
    return list
      .filter((item) => String(item.section_key || "") === String(sectionKey || ""))
      .sort((a, b) => Number(a.sort_order || 0) - Number(b.sort_order || 0) || Number(a.id || 0) - Number(b.id || 0));
  }

  function getTagImageRegistry() {
    return getSectionImageRegistry("__tag__");
  }

  function formatDateShort(value) {
    if (!value) return "-";
    const raw = String(value).trim();
    const iso = raw.match(/^(\d{4})-(\d{2})-(\d{2})/);
    if (iso) return `${iso[3]}/${iso[2]}/${iso[1]}`;
    const date = new Date(raw);
    if (Number.isNaN(date.getTime())) return "-";
    const day = String(date.getDate()).padStart(2, "0");
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const year = String(date.getFullYear());
    return `${day}/${month}/${year}`;
  }

  function getReorderSectionLabel(section) {
    const fallback = String(section && section.section_key ? section.section_key : "").trim();
    const raw = String(section && section.section_title_text ? section.section_title_text : "").trim();
    const firstLine = raw.split(/\r?\n/)[0] || "";
    const normalized = firstLine.replace(/\s+/g, " ").trim();
    if (!normalized) return fallback || "Sem titulo";
    return normalized.length > 120 ? `${normalized.slice(0, 117)}...` : normalized;
  }
%>

<section class="token-console">
  <div class="card app-card token-hero-card">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">EDITAR RELATÓRIO</span>
        <h1 class="h4 app-card-title mb-1"><%= order.service_order_display || "-" %></h1>
        <p class="text-muted mb-0"><%= order.title %> - <%= order.customer_name %></p>
      </div>
      <div class="token-hero-actions">
        <span class="badge text-bg-secondary">Status: <%= order.status || "draft" %></span>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders">Ordens</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/analytics">Relatório/Dashboard</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders/<%= order.id %>">Editar OS</a>
        <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#tagsSupportModal">Tag's</button>
        <a class="btn btn-outline-secondary btn-sm" href="<%= templatePreviewRoute || (`/admin/report-service/orders/${order.id}/preview-html/template/${templateKey || 'modern'}`) %>" target="_blank" rel="noopener">Preview HTML</a>
        <% if (String(order.status || "").toLowerCase() === "valid") { %>
          <a class="btn btn-outline-success btn-sm" href="/admin/report-service/orders/<%= order.id %>/sign-report">Assinar Relatorio</a>
        <% } %>
        <button
          class="btn btn-outline-primary btn-sm"
          type="button"
          id="openTranslateModalBtn"
          data-bs-toggle="modal"
          data-bs-target="#translateReportModal"
        >
          Traduzir
        </button>
        <form method="post" action="/admin/report-service/orders/<%= order.id %>/validate-os">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn-success btn-sm" type="submit">Validar OS</button>
        </form>
      </div>
    </div>
  </div>

  <% if (saved) { %><div class="alert alert-success mb-0">Capitulo salvo com sucesso.</div><% } %>
  <% if (editLocked) { %><div class="alert alert-warning mb-0">OS aprovada. Edicao bloqueada. Revalide a OS na tela da OS para liberar.</div><% } %>
  <% if (revalidated) { %><div class="alert alert-success mb-0">OS revalidada com sucesso. Status atualizado para <strong>valid</strong>.</div><% } %>
  <% if (revalidateError === 'forbidden_admin') { %><div class="alert alert-warning mb-0">Somente usuario com perfil <strong>admin</strong> pode revalidar OS.</div><% } %>
  <% if (revalidateError === 'invalid_state') { %><div class="alert alert-warning mb-0">A OS precisa estar com status <strong>approved</strong> para revalidar.</div><% } %>
  <% if (signRequestUpdated) { %><div class="alert alert-success mb-0">Dados do signatario atualizados com sucesso.</div><% } %>
  <% if (signRequestEditBlocked) { %><div class="alert alert-warning mb-0">Nao e permitido editar links que ja foram assinados/cancelados.</div><% } %>
  <% if (emailSent) { %><div class="alert alert-success mb-0">Relatorio assinado enviado por e-mail com sucesso.</div><% } %>
  <% if (emailError) { %><div class="alert alert-danger mb-0"><%= emailError %></div><% } %>
  <% if (translated) { %>
    <div class="alert alert-success mb-0">
      Relatorio traduzido com sucesso para
      <strong><%= (reportLanguages && reportLanguages[translatedTo] && reportLanguages[translatedTo].label) || ((reportLanguages && reportLanguages[reportLanguage] && reportLanguages[reportLanguage].label) || "Idioma selecionado") %></strong>.
    </div>
  <% } %>
  <% if (translationError) { %><div class="alert alert-danger mb-0"><%= translationError %></div><% } %>
  <% if (signLocked) { %><div class="alert alert-warning mb-0">Assinatura do relatorio liberada apenas para OS com status <strong>valid</strong>.</div><% } %>
  <% if (validationSuccess) { %><div class="alert alert-success mb-0">OS validada com sucesso. Status atualizado para <strong>valid</strong>.</div><% } %>
  <% if (validationError && osValidation && !osValidation.valid) { %>
    <div class="alert alert-danger mb-0">
      <div class="fw-semibold mb-1">Nao foi possivel validar a OS. Pendencias:</div>
      <ul class="mb-0">
        <% (osValidation.missing || []).forEach((item) => { %>
          <li><%= item %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="modal fade" id="tagsSupportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Tabela de apoio de tags do relatório</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div class="table-responsive">
            <table class="table table-sm app-table mb-0">
              <thead>
                <tr>
                  <th style="white-space:nowrap;">Tag</th>
                  <th>Descrição</th>
                  <th>IDs/Valores registrados</th>
                  <th>Exemplo</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><code>@img=ID</code></td>
                  <td>Renderiza uma imagem inline do banco de imagens</td>
                  <td>
                    <% const tagImageRegistryAll = getTagImageRegistry(); %>
                    <% if (tagImageRegistryAll.length) { %>
                      <% tagImageRegistryAll.forEach((item) => { %>
                        <span class="badge text-bg-light border me-1 mb-1"><code><%= item.ref_id || item.id %></code></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-muted">Nenhuma imagem registrada</span>
                    <% } %>
                  </td>
                  <td><code>@img=3</code></td>
                </tr>
                <tr>
                  <td><code>@equip=ID</code></td>
                  <td>Exibe TAG ou tipo do equipamento pelo ID de referência da OS</td>
                  <td>
                    <% const tagEquipRegistry = (orderEquipments || []).filter((item) => Number.isInteger(Number(item && (item.ref_id || item.equipment_id)))); %>
                    <% if (tagEquipRegistry.length) { %>
                      <% tagEquipRegistry.forEach((item) => { %>
                        <span class="badge text-bg-light border me-1 mb-1"><code><%= Number(item.ref_id || item.equipment_id) %></code></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-muted">Nenhum equipamento vinculado</span>
                    <% } %>
                  </td>
                  <td><code>@equip=1</code></td>
                </tr>
                <tr>
                  <td><code>@tagsequip</code></td>
                  <td>Exibe todas as TAGs dos equipamentos vinculados à OS, separadas por vírgula</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@tagsequip</code></td>
                </tr>
                <tr>
                  <td><code>@site</code></td>
                  <td>Exibe o nome do site vinculado à OS</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@site</code></td>
                </tr>
                <tr>
                  <td><code>@descricaodia=ID</code></td>
                  <td>Exibe um log diário específico pelo ID de sequência</td>
                  <td>
                    <% const tagDailyRegistry = (dailyLogs || []).filter((item) => String(item.notes || "").trim().toLowerCase() !== "conclusaogeral"); %>
                    <% if (tagDailyRegistry.length) { %>
                      <% tagDailyRegistry.forEach((item) => { %>
                        <span class="badge text-bg-light border me-1 mb-1"><code><%= Number(item.order_seq || item.id) %></code></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-muted">Nenhuma descrição diária registrada</span>
                    <% } %>
                  </td>
                  <td><code>@descricaodia=2</code></td>
                </tr>
                <tr>
                  <td><code>@descricaodia</code></td>
                  <td>Exibe todas as descrições diárias (exceto conclusão geral)</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@descricaodia</code></td>
                </tr>
                <tr>
                  <td><code>@conclusaogeral</code></td>
                  <td>Exibe o bloco de conclusão geral</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@conclusaogeral</code></td>
                </tr>
                <tr>
                  <td><code>@tblcmpr</code></td>
                  <td>Tabela de componentes substituídos (categoria: replaced)</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@tblcmpr</code></td>
                </tr>
                <tr>
                  <td><code>@tblcmpq</code></td>
                  <td>Tabela de componentes necessários (categoria: required)</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@tblcmpq</code></td>
                </tr>
                <tr>
                  <td><code>@tblcmps</code></td>
                  <td>Tabela de componentes sobressalentes (categoria: spare)</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@tblcmps</code></td>
                </tr>
                <tr>
                  <td><code>@tblequip</code></td>
                  <td>Tabela completa dos equipamentos vinculados à OS (dados da tabela de equipamentos)</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@tblequip</code></td>
                </tr>
                <tr>
                  <td><code>@timesheet</code></td>
                  <td>Tabela de horas e horários do timesheet</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@timesheet</code></td>
                </tr>
                <tr>
                  <td><code>@equipetecnica</code></td>
                  <td>Tabela da equipe técnica (nome, função, empresa)</td>
                  <td><span class="text-muted">Automático</span></td>
                  <td><code>@equipetecnica</code></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="translateReportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Tradução automática do relatório</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div class="mb-2 small text-muted">
            Idioma atual:
            <strong><%= (reportLanguages && reportLanguages[reportLanguage] && reportLanguages[reportLanguage].label) || "Português" %></strong>
          </div>
          <div class="mb-3">
            <label class="form-label small mb-1" for="translateTargetLanguage">Traduzir para</label>
            <select class="form-select form-select-sm" id="translateTargetLanguage">
              <option value="pt" <%= reportLanguage === 'pt' ? 'selected' : '' %>>Português</option>
              <option value="en" <%= reportLanguage === 'en' ? 'selected' : '' %>>Inglês</option>
              <option value="es" <%= reportLanguage === 'es' ? 'selected' : '' %>>Espanhol</option>
              <option value="fr" <%= reportLanguage === 'fr' ? 'selected' : '' %>>Francês</option>
            </select>
          </div>
          <div id="translateProgressWrap" class="d-none">
            <div class="d-flex justify-content-between small mb-1">
              <span id="translateProgressLabel">Iniciando...</span>
              <span id="translateProgressPercent">0%</span>
            </div>
            <div class="progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
              <div id="translateProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width:0%">0%</div>
            </div>
            <div id="translateProgressMessage" class="small text-muted mt-2">Preparando tradução com IA...</div>
          </div>
          <div id="translateErrorBox" class="alert alert-danger mt-3 d-none mb-0"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal" id="translateCloseBtn">Fechar</button>
          <button type="button" class="btn btn-primary btn-sm" id="startTranslateJobBtn">Iniciar tradução</button>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">

    <%# ===== CAPITULOS ===== %>
    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="h6 app-card-title mb-0">Capitulos editaveis do relatorio</h2>
            <div class="d-flex gap-2 align-items-center flex-wrap">
              <form method="post" action="/admin/report-service/orders/<%= order.id %>/sections" class="d-flex gap-2 align-items-center flex-wrap">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="return_to" value="report-editor" />
                <input class="form-control form-control-sm" name="section_title" placeholder="Titulo do novo capitulo" required style="min-width:180px;" />
                <select class="form-select form-select-sm" name="insert_after" style="min-width:160px;">
                  <option value="end">Inserir no final</option>
                  <option value="start">Inserir no inicio</option>
                  <% sections.forEach((sec, idx) => { %>
                    <option value="<%= sec.section_key %>">Apos: <%= idx + 1 %>. <%= sec.section_title_text || sec.section_key %></option>
                  <% }) %>
                </select>
                <button class="btn btn-outline-primary btn-sm" type="submit">Adicionar capitulo</button>
              </form>
              <button
                class="btn btn-outline-secondary btn-sm"
                type="button"
                data-bs-toggle="modal"
                data-bs-target="#reorderSectionsModal"
              >Reordenar capitulos</button>
            </div>
          </div>
          <div class="report-section-cards">
            <% sections.forEach((section, index) => { %>
              <form
                method="post"
                action="/admin/report-service/orders/<%= order.id %>/sections/<%= section.section_key %>"
                class="report-section-card"
                data-report-section-form
                data-section-key="<%= section.section_key %>"
                data-ai-revise-endpoint="/admin/report-service/orders/<%= order.id %>/sections/revise-text"
                data-image-upload-endpoint="/admin/report-service/orders/<%= order.id %>/images/import"
              >
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="return_to" value="report-editor" />
                <input type="hidden" name="section_title" value="<%= section.section_title || '' %>" data-section-title-text />
                <textarea class="d-none" name="section_title_delta_json" data-section-title-delta><%= JSON.stringify(section?.section_title_delta_json || { ops: [{ insert: "\\n" }] }) %></textarea>
                <textarea class="d-none" name="section_title_html" data-section-title-html><%= section ? section.section_title_html : '' %></textarea>
                <input type="hidden" name="section_title_text" value="<%= section ? section.section_title_text : '' %>" data-section-title-plain />

                <textarea class="d-none" name="content_delta_json" data-section-delta><%= JSON.stringify(section?.content_delta_json || { ops: [{ insert: "\\n" }] }) %></textarea>
                <textarea class="d-none" name="content_html" data-section-html><%= section ? section.content_html : '' %></textarea>
                <input type="hidden" name="content_text" value="<%= section ? section.content_text : '' %>" data-section-text />

                <div class="report-section-commandbar mb-2">
                  <div class="report-section-commandbar-top d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <span class="badge bg-secondary-subtle text-secondary-emphasis border">Capitulo <%= index + 1 %></span>
                      <code class="small ms-1"><%= section.section_key %></code>
                      <div class="form-check form-switch m-0 ms-1">
                        <input type="hidden" name="is_visible" value="false" />
                        <input class="form-check-input" type="checkbox" name="is_visible" value="true" <%= section?.is_visible === false ? "" : "checked" %> />
                        <label class="form-check-label">Exibir secao</label>
                      </div>
                    </div>
                  </div>
                  <div class="report-section-commandbar-actions d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <% if (section.section_key === "scope" || section.section_key === "recommendations") { %>
                        <button class="btn btn-outline-secondary btn-sm" type="button" data-load-default-model-btn>Carregar modelo</button>
                      <% } %>
                      <button
                        type="button"
                        class="btn btn-link btn-sm p-0 text-decoration-none"
                        data-bs-toggle="modal"
                        data-bs-target="#reportTagsHelpModal"
                      >
                        Ver tags disponíveis
                      </button>
                      <button class="btn btn-outline-secondary btn-sm" type="button" data-section-ai-revise-btn>Revisar com IA</button>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap report-section-commandbar-primary">
                      <button class="btn btn-outline-primary btn-sm" type="submit">Salvar capitulo</button>
                      <button
                        class="btn btn-outline-danger btn-sm"
                        type="submit"
                        formaction="/admin/report-service/orders/<%= order.id %>/sections/<%= section.section_key %>/delete"
                        formnovalidate
                        onclick="return confirm('Excluir este capitulo?');"
                      >
                        Excluir capitulo
                      </button>
                    </div>
                  </div>
                </div>
                <div class="small text-muted mb-1" data-section-ai-status></div>

                <div class="report-title-editor-block">
                  <label class="form-label mb-1 small text-muted">Titulo do capitulo (rich text)</label>
                  <div class="small text-muted mb-2">
                    Use este campo somente para o titulo do capitulo (primeira linha). O conteudo do relatorio deve ser escrito no campo abaixo.
                  </div>
                  <div data-report-tag-anchor></div>
                </div>
                <% if (section.section_key === "scope" || section.section_key === "recommendations") { %>
                  <textarea class="d-none" data-load-default-model-html><%= section.section_key === "scope" ? (reportConfig.defaultScopeHtml || "") : (reportConfig.defaultRecommendationsHtml || "") %></textarea>
                <% } %>
                <div class="report-quill-title-editor mb-3 report-title-editor-block">
                  <div data-quill-title-editor></div>
                </div>

                <label class="form-label mb-0 small text-muted">Conteudo do capitulo</label>
                <div class="report-quill-editor">
                  <div data-quill-editor></div>
                </div>

              </form>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <%# ===== MODAL REORDENAR CAPITULOS ===== %>
    <div class="modal fade" id="reorderSectionsModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Reordenar capitulos</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
          </div>
          <div class="modal-body p-0">
            <p class="px-3 pt-3 text-muted small mb-2">Arraste os capitulos para definir a ordem desejada e clique em Salvar.</p>
            <ul class="list-group list-group-flush" id="reorderSectionsList">
              <% sections.forEach((sec, idx) => { %>
                <li
                  class="list-group-item d-flex align-items-center gap-2 reorder-section-item"
                  data-section-key="<%= sec.section_key %>"
                  draggable="true"
                  style="cursor:grab;"
                >
                  <span class="reorder-drag-handle text-muted" title="Arrastar">&#9776;</span>
                  <span class="badge bg-secondary-subtle text-secondary-emphasis border reorder-section-idx"><%= idx + 1 %></span>
                  <span class="flex-grow-1 small fw-medium"><%= getReorderSectionLabel(sec) %></span>
                </li>
              <% }) %>
            </ul>
          </div>
          <div class="modal-footer gap-2">
            <span id="reorderSectionsStatus" class="text-muted small me-auto"></span>
            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
            <button type="button" class="btn btn-primary btn-sm" id="saveReorderBtn">Salvar ordem</button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="reportTagsHelpModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Tags disponíveis</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
          </div>
          <div class="modal-body">
            <div class="table-responsive">
              <table class="table table-sm table-bordered mb-0" style="font-size:0.8rem;">
                <thead class="table-light">
                  <tr>
                    <th style="white-space:nowrap;">Tag</th>
                    <th>Descrição</th>
                    <th>Exemplo</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td><code>@img=ID</code></td><td>Renderiza uma imagem inline do banco de imagens pelo ID</td><td><code>@img=3</code></td></tr>
                  <tr><td><code>@equip=ID</code></td><td>Exibe a TAG ou tipo do equipamento pelo ID</td><td><code>@equip=1</code></td></tr>
                  <tr><td><code>@tagsequip</code></td><td>Exibe todas as TAGs dos equipamentos vinculados à OS, separadas por vírgula</td><td><code>@tagsequip</code></td></tr>
                  <tr><td><code>@site</code></td><td>Exibe o nome do site vinculado à OS</td><td><code>@site</code></td></tr>
                  <tr><td><code>@descricaodia=ID</code></td><td>Exibe o conteúdo de um log diário específico pelo ID de sequência</td><td><code>@descricaodia=2</code></td></tr>
                  <tr><td><code>@descricaodia</code></td><td>Exibe todos os logs diários em sequência (exceto conclusão geral)</td><td><code>@descricaodia</code></td></tr>
                  <tr><td><code>@conclusaogeral</code></td><td>Exibe a conclusão geral gerada por IA (log marcado como conclusaogeral)</td><td><code>@conclusaogeral</code></td></tr>
                  <tr><td><code>@tblcmpr</code></td><td>Tabela de componentes substituídos (categoria: replaced)</td><td><code>@tblcmpr</code></td></tr>
                  <tr><td><code>@tblcmpq</code></td><td>Tabela de componentes necessários (categoria: required)</td><td><code>@tblcmpq</code></td></tr>
                  <tr><td><code>@tblcmps</code></td><td>Tabela de componentes sobressalentes (categoria: spare)</td><td><code>@tblcmps</code></td></tr>
                  <tr><td><code>@tblequip</code></td><td>Tabela completa dos equipamentos vinculados à OS (dados da tabela de equipamentos)</td><td><code>@tblequip</code></td></tr>
                  <tr><td><code>@timesheet</code></td><td>Tabela de timesheet com datas e horários de entrada/saída</td><td><code>@timesheet</code></td></tr>
                  <tr><td><code>@equipetecnica</code></td><td>Tabela da equipe técnica com nome, função e empresa</td><td><code>@equipetecnica</code></td></tr>
                </tbody>
              </table>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Fechar</button>
          </div>
        </div>
      </div>
    </div>

    <%# ===== BANCO DE IMAGENS ===== %>
    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Banco de imagens para tags (@img=ID)</h2>
          <div class="border rounded p-3 mt-1 bg-light">
            <div class="fw-semibold mb-2">Importar imagem para docs/report/img</div>
            <div class="row g-2 align-items-end">
              <div class="col-12 col-md-6">
                <label class="form-label mb-1">Arquivo de imagem</label>
                <input type="file" class="form-control" id="tagImageFileInput" accept="image/png,image/jpeg,image/webp,image/gif" />
              </div>
              <div class="col-12 col-md-4">
                <label class="form-label mb-1">Legenda (opcional)</label>
                <input class="form-control" id="tagImageCaptionInput" placeholder="Imagem importada" />
              </div>
              <div class="col-12 col-md-2">
                <button class="btn btn-outline-primary w-100" type="button" id="tagImageImportBtn">Importar</button>
              </div>
            </div>
            <div class="small text-muted mt-2" id="tagImageImportStatus">Selecione um arquivo para importar.</div>
          </div>

          <div class="small text-muted mt-2">
            Use no texto do capitulo: <code>@img=ID</code> para renderizar a imagem no preview no ponto da tag.
          </div>

          <div class="table-responsive mt-3">
            <table class="table table-sm app-table mb-0">
              <thead><tr><th>ID</th><th>Preview</th><th>Arquivo</th><th>Legenda</th><th>Acoes</th></tr></thead>
              <tbody>
                <% const tagImageRegistry = getTagImageRegistry(); %>
                <% if (!tagImageRegistry.length) { %><tr><td colspan="5" class="text-center text-muted py-3">Sem imagens cadastradas para tags.</td></tr><% } %>
                <% tagImageRegistry.forEach((item) => { %>
                  <% const imgSrc = "/docs/report/img/" + encodeURIComponent(extractImageFileName(item.file_path)); %>
                  <% const imgCaption = item.caption || extractImageFileName(item.file_path); %>
                  <tr>
                    <td><code><%= item.ref_id || item.id %></code></td>
                    <td>
                      <img
                        src="<%= imgSrc %>"
                        alt="<%= imgCaption %>"
                        data-preview-src="<%= imgSrc %>"
                        data-preview-caption="<%= imgCaption %>"
                        style="width:48px;height:48px;object-fit:cover;border-radius:4px;border:1px solid #dee2e6;cursor:pointer;"
                        onclick="openImagePreviewModal(this.dataset.previewSrc, this.dataset.previewCaption)"
                        title="Clique para ampliar"
                      />
                    </td>
                    <td><code><%= extractImageFileName(item.file_path) %></code></td>
                    <td><%= item.caption || "-" %></td>
                    <td>
                      <div class="d-flex gap-1">
                        <button
                          class="btn btn-outline-secondary btn-sm"
                          type="button"
                          data-preview-src="<%= imgSrc %>"
                          data-preview-caption="<%= imgCaption %>"
                          onclick="openImagePreviewModal(this.dataset.previewSrc, this.dataset.previewCaption)"
                        >Ver</button>
                        <form method="post" action="/admin/report-service/orders/<%= order.id %>/images/<%= (item.ref_id || item.id) %>/delete" class="m-0" onsubmit="return confirm('Excluir esta imagem do banco de tags?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <%# ===== ASSINATURA ELETRÔNICA ===== %>
    <div class="col-12">
      <div class="card app-card">
        <div class="card-body">
          <h2 class="h6 app-card-title mb-3">Assinatura eletrônica</h2>

          <% if (signedLinkCreated) { %>
            <div class="alert alert-success mb-3">Link de assinatura gerado com sucesso.</div>
          <% } %>
          <% if (signLinkEmailSent) { %>
            <div class="alert alert-success mb-3">E-mail enviado automaticamente para o signatário com o link de assinatura.</div>
          <% } %>
          <% if (signLinkEmailError) { %>
            <div class="alert alert-warning mb-3"><%= signLinkEmailError %></div>
          <% } %>
          <% if (signLinkBlocked && signRequestGuard && !signRequestGuard.allowed) { %>
            <div class="alert alert-warning mb-3">
              <div class="fw-semibold mb-1">Não foi possível gerar o link de assinatura eletrônica.</div>
              <ul class="mb-0">
                <% (signRequestGuard.reasons || []).forEach(function(reason) { %>
                  <li><%= reason %></li>
                <% }); %>
              </ul>
            </div>
          <% } %>

          <%# Lista de links gerados %>
          <% const activeRequests = (signRequests || []).filter(r => r.status === 'pending' || r.status === 'signed'); %>
          <% if (activeRequests.length > 0) { %>
            <div class="table-responsive mb-4">
              <table class="table table-sm app-table mb-0">
                <thead>
                  <tr>
                    <th>Destinatario</th>
                    <th>Empresa</th>
                    <th>E-mail</th>
                    <th>Status</th>
                    <th>Expiracao</th>
                    <th>Link</th>
                    <th>Acoes</th>
                  </tr>
                </thead>
                <tbody>
                  <% activeRequests.forEach(function(sr) { %>
                    <%
                      var srStatus = sr.status;
                      var srBadge = srStatus === 'signed' ? 'bg-success' : 'bg-warning text-dark';
                      var srLabel = srStatus === 'signed' ? 'Assinado' : 'Aguardando';
                      var expDate = sr.expires_at ? fmtDate(sr.expires_at) : '-';
                      var signLink = '/r/sign/' + sr.token;
                    %>
                    <tr>
                      <td><%= sr.signer_name || '-' %><% if (sr.signer_role) { %><br><small class="text-muted"><%= sr.signer_role %></small><% } %></td>
                      <td><%= sr.signer_company || '-' %></td>
                      <td><%= sr.signer_email || '-' %></td>
                      <td><span class="badge <%= srBadge %>"><%= srLabel %></span></td>
                      <td><%= expDate %></td>
                      <td>
                        <% if (srStatus === 'pending') { %>
                          <input type="text" class="form-control form-control-sm" style="min-width:260px;font-size:0.78rem;" readonly data-sign-path="<%= signLink %>" onclick="if(!this.value)this.value=window.location.origin+this.dataset.signPath; this.select()" onfocus="if(!this.value)this.value=window.location.origin+this.dataset.signPath; this.select()" />
                        <% } else { %>
                          <span class="text-muted small">-</span>
                        <% } %>
                      </td>
                      <td>
                        <div class="d-flex gap-1 flex-wrap">
                          <% if (srStatus === 'pending') { %>
                            <details>
                              <summary class="btn btn-outline-secondary btn-sm">Editar</summary>
                              <form method="post" action="/admin/report-service/orders/<%= order.id %>/sign-requests/<%= sr.id %>/update" class="border rounded p-2 mt-2 bg-light" style="min-width:280px;">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                <div class="mb-2">
                                  <label class="form-label mb-1 small">Nome signatario</label>
                                  <input class="form-control form-control-sm" name="signer_name" value="<%= sr.signer_name || '' %>" required />
                                </div>
                                <div class="mb-2">
                                  <label class="form-label mb-1 small">Cargo / Funcao</label>
                                  <input class="form-control form-control-sm" name="signer_role" value="<%= sr.signer_role || '' %>" />
                                </div>
                                <div class="mb-2">
                                  <label class="form-label mb-1 small">Empresa</label>
                                  <input class="form-control form-control-sm" name="signer_company" value="<%= sr.signer_company || '' %>" />
                                </div>
                                <div class="mb-2">
                                  <label class="form-label mb-1 small">E-mail</label>
                                  <input class="form-control form-control-sm" name="signer_email" type="email" value="<%= sr.signer_email || '' %>" />
                                </div>
                                <div class="mb-2">
                                  <label class="form-label mb-1 small">Observacoes</label>
                                  <input class="form-control form-control-sm" name="notes" value="<%= sr.notes || '' %>" />
                                </div>
                                <button class="btn btn-outline-primary btn-sm" type="submit">Salvar</button>
                              </form>
                            </details>
                            <form method="post" action="/admin/report-service/orders/<%= order.id %>/sign-requests/<%= sr.id %>/cancel" class="m-0" onsubmit="return confirm('Cancelar este link de assinatura?');">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <button class="btn btn-outline-warning btn-sm" type="submit">Cancelar</button>
                            </form>
                          <% } %>
                          <form method="post" action="/admin/report-service/orders/<%= order.id %>/sign-requests/<%= sr.id %>/delete" class="m-0" onsubmit="return confirm('Excluir esta assinatura eletronica?');">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <p class="text-muted small mb-3">Nenhum link de assinatura ativo. Gere um link para enviar ao responsável do cliente.</p>
          <% } %>

          <% const refusedRequests = (signRequests || []).filter((r) => String(r.status || '').toLowerCase() === 'cancelled' && String(r.notes || '').toUpperCase().startsWith('RECUSA:')); %>
          <% if (refusedRequests.length > 0) { %>
            <h3 class="h6 mb-2">Assinaturas recusadas</h3>
            <div class="table-responsive mb-4">
              <table class="table table-sm app-table mb-0">
                <thead>
                  <tr>
                    <th>Destinatario</th>
                    <th>Empresa</th>
                    <th>Data</th>
                    <th>Motivo da recusa</th>
                    <th>Acoes</th>
                  </tr>
                </thead>
                <tbody>
                  <% refusedRequests.forEach(function(sr) { %>
                    <tr>
                      <td><%= sr.signer_name || '-' %><% if (sr.signer_role) { %><br><small class="text-muted"><%= sr.signer_role %></small><% } %></td>
                      <td><%= sr.signer_company || '-' %></td>
                      <td><%= sr.updated_at ? fmtDateTime(sr.updated_at) : '-' %></td>
                      <td style="min-width:280px;">
                        <details>
                          <summary class="btn btn-outline-secondary btn-sm">Abrir motivo</summary>
                          <div class="border rounded bg-light p-2 mt-2 small">
                            <%= String(sr.notes || '').replace(/^RECUSA:\s*/i, '') || '-' %>
                          </div>
                        </details>
                      </td>
                      <td>
                        <form method="post" action="/admin/report-service/orders/<%= order.id %>/sign-requests/<%= sr.id %>/delete" class="m-0" onsubmit="return confirm('Excluir esta recusa de assinatura?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="btn btn-outline-danger btn-sm" type="submit">Excluir recusa</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>

          <% if (canSendSignedReport) { %>
            <details class="border rounded p-3 bg-light mb-4">
              <summary class="fw-semibold" style="cursor:pointer;">Enviar relatorio assinado por e-mail</summary>
              <form method="post" action="/admin/report-service/orders/<%= order.id %>/send-signed-email" class="row g-2 mt-2">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="col-12 col-md-4">
                  <label class="form-label mb-1 small">Template PDF</label>
                  <select class="form-select form-select-sm" name="template_key" id="signedEmailTemplateKey">
                    <% ((reportConfig && reportConfig.templateOptions) || []).forEach(function (item) { %>
                      <option value="<%= item.key %>" <%= item.key === templateKey ? "selected" : "" %>><%= item.name %></option>
                    <% }); %>
                  </select>
                </div>
                <div class="col-12 col-md-8 d-flex align-items-end">
                  <a class="btn btn-outline-secondary btn-sm" id="signedEmailTemplatePreviewLink" href="/admin/report-service/orders/<%= order.id %>/preview-html/template/<%= templateKey || 'modern' %>" target="_blank" rel="noopener">Abrir preview do template selecionado</a>
                </div>
                <div class="col-12 col-md-6">
                  <label class="form-label mb-1 small">Para <span class="text-danger">*</span></label>
                  <input class="form-control form-control-sm" name="to" type="text" placeholder="email@empresa.com; outro@empresa.com" required />
                </div>
                <div class="col-12 col-md-6">
                  <label class="form-label mb-1 small">CC (opcional)</label>
                  <input class="form-control form-control-sm" name="cc" type="text" placeholder="cc@empresa.com" />
                </div>
                <div class="col-12">
                  <label class="form-label mb-1 small">Mensagem (opcional)</label>
                  <textarea class="form-control form-control-sm" name="message" rows="3" placeholder="Mensagem para o destinatario"></textarea>
                </div>
                <div class="col-12">
                  <button class="btn btn-outline-primary btn-sm" type="submit">Enviar e-mail + PDF assinado</button>
                </div>
              </form>
            </details>
          <% } %>

          <%# Assinaturas registradas %>
          <% const registeredSignatures = Array.isArray(signatures) ? signatures : []; %>
          <% if (registeredSignatures.length > 0) { %>
            <h3 class="h6 mb-2">Assinaturas registradas</h3>
            <div class="table-responsive mb-4">
              <table class="table table-sm app-table mb-0">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Cargo</th>
                    <th>Empresa</th>
                    <th>Data</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% registeredSignatures.forEach(function(sig) { %>
                    <tr>
                      <td><%= sig.signer_name || '-' %></td>
                      <td><%= sig.signer_role || '-' %></td>
                      <td><%= sig.signer_company || '-' %></td>
                      <td><%= sig.signed_at ? fmtDateTime(sig.signed_at) : '-' %></td>
                      <td>
                        <form method="post" action="/admin/report-service/orders/<%= order.id %>/signatures/<%= sig.id %>/delete" class="m-0" onsubmit="return confirm('Excluir esta assinatura eletrônica?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="btn btn-outline-danger btn-sm" type="submit">Excluir</button>
                        </form>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          <% } %>
          <%# Formulário para gerar novo link %>
          <% if (signRequestGuard && signRequestGuard.allowed) { %>
            <details class="border rounded p-3 bg-light">
              <summary class="fw-semibold" style="cursor:pointer;">Gerar novo link de assinatura</summary>
              <form method="post" action="/admin/report-service/orders/<%= order.id %>/sign-requests" class="row g-2 mt-2">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <div class="col-12 col-md-4">
                  <label class="form-label mb-1 small">Nome do signatário <span class="text-danger">*</span></label>
                  <input class="form-control form-control-sm" name="signer_name" placeholder="Ex: João Silva" required />
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label mb-1 small">Cargo / Função</label>
                  <input class="form-control form-control-sm" name="signer_role" placeholder="Ex: Gerente de Manutenção" />
                </div>
                <div class="col-12 col-md-4">
                  <label class="form-label mb-1 small">Empresa</label>
                  <input class="form-control form-control-sm" name="signer_company" placeholder="Ex: Empresa Ltda." />
                </div>
                <div class="col-12 col-md-6">
                  <label class="form-label mb-1 small">E-mail <span class="text-danger">*</span></label>
                  <input class="form-control form-control-sm" name="signer_email" type="email" placeholder="email@empresa.com" required />
                </div>
                <div class="col-12 col-md-6">
                  <label class="form-label mb-1 small">Observações</label>
                  <input class="form-control form-control-sm" name="notes" placeholder="Opcional" />
                </div>
                <div class="col-12">
                  <button class="btn btn-primary btn-sm" type="submit">Gerar link de assinatura</button>
                  <span class="text-muted small ms-2">O link expira em 30 dias.</span>
                </div>
              </form>
            </details>
          <% } else { %>
            <div class="alert alert-light border mb-0 small">
              Para gerar o link de assinatura eletrônica, cumpra os pré-requisitos:
              <ul class="mb-0 mt-1">
                <li>OS com status <strong>valid</strong></li>
                <li>Pelo menos uma assinatura do técnico Vextrom</li>
              </ul>
            </div>
          <% } %>

        </div>
      </div>
    </div>

  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill-better-table@1.2.10/dist/quill-better-table.min.js"></script>
<script>
  (function () {
    var startBtn = document.getElementById("startTranslateJobBtn");
    var closeBtn = document.getElementById("translateCloseBtn");
    var langSelect = document.getElementById("translateTargetLanguage");
    var progressWrap = document.getElementById("translateProgressWrap");
    var progressBar = document.getElementById("translateProgressBar");
    var progressPercent = document.getElementById("translateProgressPercent");
    var progressMessage = document.getElementById("translateProgressMessage");
    var progressLabel = document.getElementById("translateProgressLabel");
    var errorBox = document.getElementById("translateErrorBox");
    var csrfToken = "<%= csrfToken %>";
    var orderId = <%= Number(order.id) %>;
    if (!startBtn || !langSelect || !progressWrap || !progressBar || !progressPercent || !progressMessage || !progressLabel || !errorBox) return;

    var pollTimer = null;
    function stopPolling() {
      if (pollTimer) {
        clearTimeout(pollTimer);
        pollTimer = null;
      }
    }
    function setProgress(value, message) {
      var safe = Math.max(0, Math.min(100, Number(value || 0)));
      progressBar.style.width = safe + "%";
      progressBar.textContent = safe + "%";
      progressBar.setAttribute("aria-valuenow", String(safe));
      progressPercent.textContent = safe + "%";
      if (message) progressMessage.textContent = message;
      if (safe >= 100) {
        progressBar.classList.remove("progress-bar-animated");
      } else {
        progressBar.classList.add("progress-bar-animated");
      }
    }
    function showError(message) {
      errorBox.textContent = String(message || "Falha ao iniciar tradução.");
      errorBox.classList.remove("d-none");
    }
    function clearError() {
      errorBox.textContent = "";
      errorBox.classList.add("d-none");
    }
    async function pollJob(jobId, targetLanguage) {
      try {
        var response = await fetch("/admin/report-service/orders/" + orderId + "/translate/jobs/" + encodeURIComponent(jobId), {
          method: "GET",
          credentials: "same-origin"
        });
        var payload = await response.json().catch(function () { return {}; });
        if (!response.ok || !payload || !payload.ok) {
          throw new Error(payload && payload.message ? payload.message : "Não foi possível consultar progresso.");
        }
        setProgress(payload.progress, payload.message || "Traduzindo...");
        if (payload.status === "completed") {
          progressLabel.textContent = "Concluído";
          setProgress(100, payload.message || "Tradução concluída.");
          stopPolling();
          setTimeout(function () {
            window.location.href = "/admin/report-service/orders/" + orderId + "/report-editor?translated=1&translated_to=" + encodeURIComponent(targetLanguage) + "&saved=1";
          }, 800);
          return;
        }
        if (payload.status === "failed") {
          stopPolling();
          progressLabel.textContent = "Falha";
          showError(payload.error || payload.message || "Falha na tradução.");
          startBtn.disabled = false;
          if (closeBtn) closeBtn.disabled = false;
          return;
        }
        pollTimer = setTimeout(function () {
          pollJob(jobId, targetLanguage);
        }, 1200);
      } catch (err) {
        stopPolling();
        showError(err && err.message ? err.message : "Falha ao acompanhar progresso.");
        startBtn.disabled = false;
        if (closeBtn) closeBtn.disabled = false;
      }
    }

    startBtn.addEventListener("click", async function () {
      clearError();
      stopPolling();
      progressWrap.classList.remove("d-none");
      progressLabel.textContent = "Processando";
      setProgress(2, "Iniciando tradução com IA...");
      startBtn.disabled = true;
      if (closeBtn) closeBtn.disabled = true;
      var targetLanguage = String(langSelect.value || "pt");
      try {
        var response = await fetch("/admin/report-service/orders/" + orderId + "/translate/start", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "X-CSRF-Token": csrfToken
          },
          credentials: "same-origin",
          body: JSON.stringify({ target_language: targetLanguage })
        });
        var payload = await response.json().catch(function () { return {}; });
        if (!response.ok || !payload || !payload.ok || !payload.jobId) {
          throw new Error(payload && payload.message ? payload.message : "Falha ao iniciar job de tradução.");
        }
        setProgress(payload.progress || 5, "Job criado. Traduzindo conteúdo...");
        pollJob(payload.jobId, targetLanguage);
      } catch (err) {
        showError(err && err.message ? err.message : "Falha ao iniciar tradução.");
        startBtn.disabled = false;
        if (closeBtn) closeBtn.disabled = false;
      }
    });

    var modalEl = document.getElementById("translateReportModal");
    if (modalEl) {
      modalEl.addEventListener("hidden.bs.modal", function () {
        stopPolling();
        startBtn.disabled = false;
        if (closeBtn) closeBtn.disabled = false;
        progressWrap.classList.add("d-none");
        progressLabel.textContent = "Iniciando...";
        setProgress(0, "Preparando tradução com IA...");
        clearError();
      });
    }
  })();

  </script>
