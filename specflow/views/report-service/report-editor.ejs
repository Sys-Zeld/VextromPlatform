<script>
(function () {
  var list = document.getElementById("reorderSectionsList");
  var saveBtn = document.getElementById("saveReorderBtn");
  var statusEl = document.getElementById("reorderSectionsStatus");
  var csrfToken = "<%= csrfToken %>";
  var reorderUrl = "/admin/report-service/orders/<%= order.id %>/sections/reorder";

  if (!list || !saveBtn) return;

  var draggingEl = null;

  list.addEventListener("dragstart", function (e) {
    draggingEl = e.target.closest(".reorder-section-item");
    if (draggingEl) {
      draggingEl.classList.add("reorder-dragging");
      e.dataTransfer.effectAllowed = "move";
    }
  });

  list.addEventListener("dragend", function () {
    if (draggingEl) draggingEl.classList.remove("reorder-dragging");
    draggingEl = null;
    list.querySelectorAll(".reorder-drop-over").forEach(function (el) {
      el.classList.remove("reorder-drop-over");
    });
    updateIndexBadges();
  });

  list.addEventListener("dragover", function (e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = "move";
    var target = e.target.closest(".reorder-section-item");
    if (!target || target === draggingEl) return;
    list.querySelectorAll(".reorder-drop-over").forEach(function (el) { el.classList.remove("reorder-drop-over"); });
    target.classList.add("reorder-drop-over");
    var rect = target.getBoundingClientRect();
    var midY = rect.top + rect.height / 2;
    if (e.clientY < midY) {
      list.insertBefore(draggingEl, target);
    } else {
      list.insertBefore(draggingEl, target.nextSibling);
    }
  });

  list.addEventListener("dragleave", function (e) {
    var target = e.target.closest(".reorder-section-item");
    if (target) target.classList.remove("reorder-drop-over");
  });

  list.addEventListener("drop", function (e) {
    e.preventDefault();
  });

  function updateIndexBadges() {
    var items = list.querySelectorAll(".reorder-section-item");
    items.forEach(function (item, i) {
      var badge = item.querySelector(".reorder-section-idx");
      if (badge) badge.textContent = i + 1;
    });
  }

  saveBtn.addEventListener("click", function () {
    var items = list.querySelectorAll(".reorder-section-item");
    var keys = Array.prototype.map.call(items, function (el) { return el.getAttribute("data-section-key"); });
    saveBtn.disabled = true;
    if (statusEl) statusEl.textContent = "Salvando...";
    fetch(reorderUrl, {
      method: "POST",
      headers: {
        "Content-Type": "application/x-www-form-urlencoded",
        "Accept": "application/json",
        "x-csrf-token": csrfToken
      },
      credentials: "same-origin",
      body: "_csrf=" + encodeURIComponent(csrfToken) + "&section_keys=" + encodeURIComponent(JSON.stringify(keys))
    })
      .then(function (resp) { return resp.json(); })
      .then(function (data) {
        if (data && data.ok) {
          if (statusEl) statusEl.textContent = "Ordem salva!";
          setTimeout(function () { window.location.reload(); }, 600);
        } else {
          throw new Error(data && data.message ? data.message : "Erro ao salvar.");
        }
      })
      .catch(function (err) {
        if (statusEl) statusEl.textContent = err && err.message ? err.message : "Erro ao salvar.";
        saveBtn.disabled = false;
      });
  });
})();
</script>

