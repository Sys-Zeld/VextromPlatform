<script>
  (function () {
    var input = document.getElementById("tagImageFileInput");
    var captionInput = document.getElementById("tagImageCaptionInput");
    var button = document.getElementById("tagImageImportBtn");
    var status = document.getElementById("tagImageImportStatus");
    if (!input || !captionInput || !button || !status) return;

    var csrfInput = document.querySelector('input[name="_csrf"]');
    var csrfToken = csrfInput ? csrfInput.value : "";
    var endpoint = "/admin/report-service/orders/<%= order.id %>/images/import";

    button.addEventListener("click", async function () {
      var file = input.files && input.files[0];
      if (!file) {
        status.textContent = "Selecione um arquivo de imagem.";
        return;
      }
      button.disabled = true;
      status.textContent = "Importando imagem...";
      try {
        var buffer = await file.arrayBuffer();
        var response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": file.type || "application/octet-stream",
            "X-CSRF-Token": csrfToken,
            "X-File-Name": encodeURIComponent(file.name || "imagem"),
            "X-Caption": captionInput.value || ""
          },
          body: buffer
        });
        if (!response.ok) throw new Error("Falha no upload.");
        status.textContent = "Imagem importada com sucesso. Recarregando lista...";
        setTimeout(function () { window.location.reload(); }, 400);
      } catch (_err) {
        status.textContent = "Falha ao importar imagem.";
      } finally {
        button.disabled = false;
      }
    });
  })();
</script>
