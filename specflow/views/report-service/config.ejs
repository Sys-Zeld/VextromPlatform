<%- include("../partials/head", { pageTitle }) %>
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/quill-better-table@1.2.10/dist/quill-better-table.css" rel="stylesheet" />
<link href="/public/css/report-editor.css" rel="stylesheet" />
<style>
  /* wrappers dos editores de config */
  .report-quill-editor:has(#default-scope-editor),
  .report-quill-editor:has(#default-recommendations-editor) {
    margin-bottom: 8px;
  }

  /* #default-*-editor agora É o ql-container */
  #default-scope-editor,
  #default-recommendations-editor {
    height: auto;
    min-height: 140px;
  }

  #default-scope-editor .ql-editor,
  #default-recommendations-editor .ql-editor {
    min-height: 140px;
  }

  .report-config-save-row {
    clear: both;
    margin-top: 12px;
  }
</style>

<section class="card app-card mb-3">
  <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
    <div>
      <h1 class="h5 app-card-title mb-1">Config Report</h1>
      <p class="text-muted mb-0">Defina o template padrao e os logos usados no preview/generacao do Report Service.</p>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders">Voltar para ordens</a>
    </div>
  </div>
</section>

<% if (saved) { %>
  <div class="alert alert-success">Configuracoes salvas com sucesso.</div>
<% } %>

<section class="card app-card mb-3">
  <div class="card-body">
    <form method="post" action="/admin/report-service/config" class="row g-3" id="config-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="col-12 d-flex justify-content-end report-config-save-row">
        <button class="btn btn-primary btn-sm" type="submit" id="btn-save">Salvar configuracao padrao</button>
      </div>

      <div class="col-12 col-lg-4">
        <label class="form-label">Template padrao do report</label>
        <select class="form-select" name="template_key" required>
          <% (reportConfig.templateOptions || []).forEach((item) => { %>
            <option value="<%= item.key %>" <%= item.key === reportConfig.templateKey ? "selected" : "" %>><%= item.name %></option>
          <% }) %>
        </select>
        <div class="form-text">Cada template possui rota/codigo de renderizacao proprio no preview HTML.</div>
      </div>

      <!-- Logo Vextrom -->
      <div class="col-12 col-lg-4">
        <label class="form-label">Logo Vextrom</label>

        <% if (reportConfig.logoVextrom) { %>
          <div class="mb-2 p-2 border rounded text-center" style="background:var(--app-bg,#f8f9fa);min-height:60px">
            <img id="preview-vextrom"
                 src="<%= reportConfig.logoVextrom %>"
                 alt="Logo Vextrom"
                 style="max-height:56px;max-width:100%;object-fit:contain"
                 onerror="this.style.display='none';document.getElementById('preview-vextrom-empty').style.display='block'" />
            <span id="preview-vextrom-empty" class="text-muted small" style="display:none">Nao foi possivel carregar a imagem</span>
          </div>
        <% } else { %>
          <div class="mb-2 p-2 border rounded text-center" style="background:var(--app-bg,#f8f9fa);min-height:60px">
            <img id="preview-vextrom" src="" alt="" style="max-height:56px;max-width:100%;object-fit:contain;display:none" />
            <span id="preview-vextrom-empty" class="text-muted small">Nenhuma logo definida</span>
          </div>
        <% } %>

        <div class="input-group mb-1">
          <input class="form-control form-control-sm" id="input-logo-vextrom" name="logo_vextrom"
                 value="<%= reportConfig.logoVextrom || '' %>" placeholder="/public/img/logo-vextrom.svg" />
          <label class="btn btn-outline-secondary btn-sm" for="file-vextrom" title="Importar arquivo de logo">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
              <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
            </svg>
            Importar
          </label>
          <input type="file" id="file-vextrom" accept=".svg,.png,.jpg,.jpeg" class="d-none"
                 onchange="handleLogoUpload('vextrom', this)" />
        </div>
        <div id="status-vextrom" class="form-text">PNG, JPG ou SVG — max 5 MB. Ou informe uma URL/caminho publico.</div>
      </div>

      <!-- Logo Chloride -->
      <div class="col-12 col-lg-4">
        <label class="form-label">Logo Chloride</label>

        <% if (reportConfig.logoChloride) { %>
          <div class="mb-2 p-2 border rounded text-center" style="background:var(--app-bg,#f8f9fa);min-height:60px">
            <img id="preview-chloride"
                 src="<%= reportConfig.logoChloride %>"
                 alt="Logo Chloride"
                 style="max-height:56px;max-width:100%;object-fit:contain"
                 onerror="this.style.display='none';document.getElementById('preview-chloride-empty').style.display='block'" />
            <span id="preview-chloride-empty" class="text-muted small" style="display:none">Nao foi possivel carregar a imagem</span>
          </div>
        <% } else { %>
          <div class="mb-2 p-2 border rounded text-center" style="background:var(--app-bg,#f8f9fa);min-height:60px">
            <img id="preview-chloride" src="" alt="" style="max-height:56px;max-width:100%;object-fit:contain;display:none" />
            <span id="preview-chloride-empty" class="text-muted small">Nenhuma logo definida</span>
          </div>
        <% } %>

        <div class="input-group mb-1">
          <input class="form-control form-control-sm" id="input-logo-chloride" name="logo_chloride"
                 value="<%= reportConfig.logoChloride || '' %>" placeholder="https://... ou /public/img/..." />
          <label class="btn btn-outline-secondary btn-sm" for="file-chloride" title="Importar arquivo de logo">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
              <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
            </svg>
            Importar
          </label>
          <input type="file" id="file-chloride" accept=".svg,.png,.jpg,.jpeg" class="d-none"
                 onchange="handleLogoUpload('chloride', this)" />
        </div>
        <div id="status-chloride" class="form-text">PNG, JPG ou SVG — max 5 MB. Ou informe uma URL/caminho publico.</div>
      </div>

      <!-- Logo da Capa (cover-logo-image) -->
      <div class="col-12 col-lg-4">
        <label class="form-label">Logo da capa (cover-logo-image)</label>

        <% if (reportConfig.logoCover) { %>
          <div class="mb-2 p-2 border rounded text-center" style="background:var(--app-bg,#f8f9fa);min-height:60px">
            <img id="preview-cover"
                 src="<%= reportConfig.logoCover %>"
                 alt="Logo da capa"
                 style="max-height:56px;max-width:100%;object-fit:contain"
                 onerror="this.style.display='none';document.getElementById('preview-cover-empty').style.display='block'" />
            <span id="preview-cover-empty" class="text-muted small" style="display:none">Nao foi possivel carregar a imagem</span>
          </div>
        <% } else { %>
          <div class="mb-2 p-2 border rounded text-center" style="background:var(--app-bg,#f8f9fa);min-height:60px">
            <img id="preview-cover" src="" alt="" style="max-height:56px;max-width:100%;object-fit:contain;display:none" />
            <span id="preview-cover-empty" class="text-muted small">Nenhuma logo definida</span>
          </div>
        <% } %>

        <div class="input-group mb-1">
          <input class="form-control form-control-sm" id="input-logo-cover" name="logo_cover"
                 value="<%= reportConfig.logoCover || '' %>" placeholder="https://... ou /public/img/..." />
          <label class="btn btn-outline-secondary btn-sm" for="file-cover" title="Importar arquivo de logo da capa">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
              <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z"/>
              <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z"/>
            </svg>
            Importar
          </label>
          <input type="file" id="file-cover" accept=".svg,.png,.jpg,.jpeg" class="d-none"
                 onchange="handleLogoUpload('cover', this)" />
        </div>
        <div id="status-cover" class="form-text">PNG, JPG ou SVG â€” max 5 MB. Ou informe uma URL/caminho publico.</div>
      </div>

      <!-- Rodape HTML -->
      <div class="col-12">
        <label class="form-label">Rodape do relatorio (HTML)</label>
        <div class="mb-2 p-2 border rounded" style="background:#f8f9fa;font-size:0.75rem;color:#6b7280;">
          O HTML abaixo e inserido no rodape de cada pagina do relatorio. Use as classes <code>report-footer-inner</code>, <code>report-footer-col</code> e <code>rf-icon</code> para manter o layout padrao em duas colunas.
        </div>
        <textarea
          name="footer_html"
          id="footer-html-input"
          class="form-control form-control-sm font-monospace"
          rows="10"
          style="font-size:0.72rem;resize:vertical;"
        ><%= reportConfig.footerHtml || '' %></textarea>
        <div class="d-flex gap-2 mt-2">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="previewFooter()">Previsualizar</button>
          <button type="button" class="btn btn-outline-danger btn-sm" onclick="resetFooter()">Restaurar padrao</button>
        </div>
        <div id="footer-preview-wrap" class="mt-2" style="display:none;">
          <div class="border rounded p-2" style="background:#fff;font-size:0.7rem;color:#6e7e74;">
            <div id="footer-preview-content"></div>
          </div>
        </div>
      </div>

      <div class="col-12">
        <div class="card app-card">
          <div class="card-body">
            <label class="form-label">Capitulo padrao: ESCOPO</label>
            <div class="mb-2 p-2 border rounded" style="background:#f8f9fa;font-size:0.75rem;color:#6b7280;">
              Conteudo padrao aplicado ao capitulo <strong>ESCOPO</strong> na criacao de novos relatorios.
            </div>
            <div class="d-flex gap-2 mb-2">
              <button type="button" class="btn btn-outline-secondary btn-sm" id="edit-scope-btn">Editar</button>
              <button type="button" class="btn btn-primary btn-sm" id="save-scope-btn">Salvar</button>
              <button type="button" class="btn btn-outline-danger btn-sm" id="reset-scope-btn">Restaurar padrao</button>
            </div>
            <div class="report-quill-editor">
              <div id="default-scope-editor"></div>
            </div>
            <textarea class="d-none" name="default_scope_html" id="default-scope-html"><%= reportConfig.defaultScopeHtml || "" %></textarea>
          </div>
        </div>
      </div>

      <div class="col-12">
        <div class="card app-card">
          <div class="card-body">
            <label class="form-label">Capitulo padrao: RECOMENDACOES</label>
            <div class="mb-2 p-2 border rounded" style="background:#f8f9fa;font-size:0.75rem;color:#6b7280;">
              Conteudo padrao aplicado ao capitulo <strong>RECOMENDACOES</strong> na criacao de novos relatorios.
            </div>
            <div class="d-flex gap-2 mb-2">
              <button type="button" class="btn btn-outline-secondary btn-sm" id="edit-recommendations-btn">Editar</button>
              <button type="button" class="btn btn-primary btn-sm" id="save-recommendations-btn">Salvar</button>
              <button type="button" class="btn btn-outline-danger btn-sm" id="reset-recommendations-btn">Restaurar padrao</button>
            </div>
            <div class="report-quill-editor">
              <div id="default-recommendations-editor"></div>
            </div>
            <textarea class="d-none" name="default_recommendations_html" id="default-recommendations-html"><%= reportConfig.defaultRecommendationsHtml || "" %></textarea>
          </div>
        </div>
      </div>

    </form>
  </div>
</section>

<script>
async function handleLogoUpload(brand, fileInput) {
  const file = fileInput.files[0];
  if (!file) return;

  const csrfToken = document.querySelector('#config-form input[name="_csrf"]').value;
  const statusEl = document.getElementById('status-' + brand);
  const pathInput = document.getElementById('input-logo-' + brand);
  const previewImg = document.getElementById('preview-' + brand);
  const previewEmpty = document.getElementById('preview-' + brand + '-empty');
  const btnSave = document.getElementById('btn-save');

  statusEl.textContent = 'Enviando...';
  statusEl.className = 'form-text text-muted';
  btnSave.disabled = true;

  try {
    const resp = await fetch('/admin/report-service/config/logo-upload', {
      method: 'POST',
      headers: {
        'Content-Type': file.type || 'application/octet-stream',
        'x-file-name': encodeURIComponent(file.name),
        'x-logo-brand': brand,
        'x-csrf-token': csrfToken
      },
      body: file
    });

    const json = await resp.json();

    if (json.ok) {
      pathInput.value = json.data.filePath;
      previewImg.src = json.data.filePath;
      previewImg.style.display = 'block';
      if (previewEmpty) previewEmpty.style.display = 'none';
      statusEl.textContent = 'Upload concluido. Clique em "Salvar" para confirmar.';
      statusEl.className = 'form-text text-success';
    } else {
      statusEl.textContent = json.error || 'Erro no upload.';
      statusEl.className = 'form-text text-danger';
    }
  } catch (err) {
    statusEl.textContent = 'Erro ao enviar arquivo.';
    statusEl.className = 'form-text text-danger';
  } finally {
    btnSave.disabled = false;
    fileInput.value = '';
  }
}
</script>

<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill-better-table@1.2.10/dist/quill-better-table.min.js"></script>
<script>
(function () {
  if (typeof window.Quill === "undefined") return;
  var FontAttributor = window.Quill.import("formats/font");
  FontAttributor.whitelist = ["arial", "serif", "monospace"];
  window.Quill.register(FontAttributor, true);
  if (window.QuillBetterTable) {
    window.Quill.register({ "modules/better-table": window.QuillBetterTable }, true);
  }
})();
</script>
<script>
var DEFAULT_FOOTER_HTML = <%- JSON.stringify(reportConfig.defaultFooterHtml || '') %>;
var DEFAULT_SCOPE_HTML = <%- JSON.stringify(reportConfig.defaultSystemScopeHtml || "") %>;
var DEFAULT_RECOMMENDATIONS_HTML = <%- JSON.stringify(reportConfig.defaultSystemRecommendationsHtml || "") %>;
var configForm = document.getElementById("config-form");

function syncEditorToInput(state) {
  if (!state || !state.quill || !state.input) return;
  var plain = state.quill.getText().replace(/\s+/g, " ").trim();
  state.input.value = plain ? String(state.quill.root.innerHTML || "").trim() : "";
}

function buildConfigSectionEditor(editorId, inputId, editBtnId, saveBtnId, resetBtnId, defaultHtml) {
  var editorEl = document.getElementById(editorId);
  var inputEl = document.getElementById(inputId);
  var editBtn = document.getElementById(editBtnId);
  var saveBtn = document.getElementById(saveBtnId);
  var resetBtn = document.getElementById(resetBtnId);
  if (!editorEl || !inputEl || typeof window.Quill === "undefined") return null;

  var quill = new window.Quill(editorEl, {
    theme: "snow",
    modules: {
      toolbar: {
        container: [
          [{ font: ["arial", "serif", "monospace"] }, { size: ["small", false, "large", "huge"] }],
          [{ header: [1, 2, 3, false] }],
          ["bold", "italic", "underline", { color: [] }],
          [{ list: "ordered" }, { list: "bullet" }],
          [{ align: [] }],
          ["link", "image", "clean"]
        ],
        handlers: {
          image: function () {
            var q = quill;
            var csrfInput = document.querySelector('#config-form input[name="_csrf"]');
            var csrfToken = csrfInput ? csrfInput.value : "";
            var input = document.createElement("input");
            input.setAttribute("type", "file");
            input.setAttribute("accept", "image/*");
            input.style.display = "none";
            document.body.appendChild(input);
            input.click();
            input.onchange = function () {
              var file = input.files && input.files[0];
              if (!file) { document.body.removeChild(input); return; }
              fetch("/admin/report-service/config/image-upload", {
                method: "POST",
                headers: {
                  "Content-Type": file.type || "application/octet-stream",
                  "x-file-name": encodeURIComponent(file.name),
                  "x-csrf-token": csrfToken
                },
                body: file
              })
                .then(function (resp) { return resp.json(); })
                .then(function (json) {
                  if (json.ok && json.data && json.data.filePath) {
                    var imgSrc = "/docs/report/img/" + encodeURIComponent(json.data.filePath);
                    var range = q.getSelection(true);
                    var index = range && Number.isInteger(range.index) ? range.index : q.getLength();
                    q.insertEmbed(index, "image", imgSrc, "user");
                    q.setSelection(index + 1, 0, "user");
                  }
                  document.body.removeChild(input);
                })
                .catch(function () { document.body.removeChild(input); });
            };
          }
        }
      }
    },
    formats: [
      "font",
      "size",
      "header",
      "bold",
      "italic",
      "underline",
      "color",
      "list",
      "align",
      "link",
      "image"
    ],
    placeholder: "Digite o conteudo padrao..."
  });

  var toolbarModule = quill.getModule("toolbar");
  if (toolbarModule && toolbarModule.container) {
    Array.prototype.forEach.call(toolbarModule.container.querySelectorAll("button"), function (btn) {
      btn.setAttribute("type", "button");
    });
    toolbarModule.container.addEventListener("mousedown", function (e) {
      if (e.target && e.target.tagName !== "INPUT") {
        e.preventDefault();
      }
    });
  }

  if (String(inputEl.value || "").trim()) {
    quill.clipboard.dangerouslyPasteHTML(String(inputEl.value));
  } else {
    quill.setText("");
  }
  quill.format("align", "justify", "silent");
  var state = { quill: quill, input: inputEl };

  function setEditing(isEditing) {
    quill.enable(Boolean(isEditing));
    if (editBtn) editBtn.disabled = Boolean(isEditing);
    if (saveBtn) saveBtn.disabled = !Boolean(isEditing);
    if (resetBtn) resetBtn.disabled = !Boolean(isEditing);
  }

  setEditing(false);

  if (editBtn) {
    editBtn.addEventListener("click", function () {
      setEditing(true);
      quill.focus();
    });
  }

  if (saveBtn) {
    saveBtn.addEventListener("click", function () {
      syncEditorToInput(state);
      if (configForm && typeof configForm.requestSubmit === "function") {
        configForm.requestSubmit();
      } else if (configForm) {
        configForm.submit();
      }
    });
  }

  if (resetBtn) {
    resetBtn.addEventListener("click", function () {
      if (!confirm("Restaurar para o padrao?")) return;
      quill.setText("");
      if (String(defaultHtml || "").trim()) quill.clipboard.dangerouslyPasteHTML(String(defaultHtml));
      setEditing(true);
    });
  }

  return state;
}

function previewFooter() {
  var html = document.getElementById('footer-html-input').value;
  var wrap = document.getElementById('footer-preview-wrap');
  var content = document.getElementById('footer-preview-content');
  content.innerHTML = html;
  wrap.style.display = 'block';
}

function resetFooter() {
  if (!confirm('Restaurar o rodape para o modelo padrao?')) return;
  document.getElementById('footer-html-input').value = DEFAULT_FOOTER_HTML;
  var wrap = document.getElementById('footer-preview-wrap');
  wrap.style.display = 'none';
}

var scopeEditorState = buildConfigSectionEditor(
  "default-scope-editor",
  "default-scope-html",
  "edit-scope-btn",
  "save-scope-btn",
  "reset-scope-btn",
  DEFAULT_SCOPE_HTML
);
var recommendationsEditorState = buildConfigSectionEditor(
  "default-recommendations-editor",
  "default-recommendations-html",
  "edit-recommendations-btn",
  "save-recommendations-btn",
  "reset-recommendations-btn",
  DEFAULT_RECOMMENDATIONS_HTML
);

if (configForm) {
  configForm.addEventListener("submit", function () {
    syncEditorToInput(scopeEditorState);
    syncEditorToInput(recommendationsEditorState);
  });
}
</script>

<%- include("../partials/footer") %>
