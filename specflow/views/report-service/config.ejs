<%- include("../partials/head", { pageTitle }) %>

<section class="card app-card mb-3">
  <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
    <div>
      <h1 class="h5 app-card-title mb-1">Config Report</h1>
      <p class="text-muted mb-0">Defina o template padrao e os logos usados no preview/generacao do Report Service.</p>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/orders">Voltar para ordens</a>
    </div>
  </div>
</section>

<% if (saved) { %>
  <div class="alert alert-success">Configuracoes salvas com sucesso.</div>
<% } %>

<section class="card app-card">
  <div class="card-body">
    <form method="post" action="/admin/report-service/config" class="row g-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="col-12 col-lg-4">
        <label class="form-label">Template padrao do report</label>
        <select class="form-select" name="template_key" required>
          <% (reportConfig.templateOptions || []).forEach((item) => { %>
            <option value="<%= item.key %>" <%= item.key === reportConfig.templateKey ? "selected" : "" %>><%= item.name %></option>
          <% }) %>
        </select>
        <div class="form-text">Cada template possui rota/codigo de renderizacao proprio no preview HTML.</div>
      </div>

      <div class="col-12 col-lg-4">
        <label class="form-label">Logo Vextrom (URL ou caminho publico)</label>
        <input class="form-control" name="logo_vextrom" value="<%= reportConfig.logoVextrom || '' %>" placeholder="/public/img/logo-vextrom.svg" />
      </div>

      <div class="col-12 col-lg-4">
        <label class="form-label">Logo Chloride (URL ou caminho publico)</label>
        <input class="form-control" name="logo_chloride" value="<%= reportConfig.logoChloride || '' %>" placeholder="https://..." />
      </div>

      <div class="col-12 d-flex justify-content-end">
        <button class="btn btn-primary btn-sm" type="submit">Salvar configuracao padrao</button>
      </div>
    </form>
  </div>
</section>

<%- include("../partials/footer") %>
