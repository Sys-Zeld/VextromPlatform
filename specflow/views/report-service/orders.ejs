<%- include("../partials/head", { pageTitle }) %>
<style>
  @import url("https://cdn.jsdelivr.net/npm/gridjs/dist/theme/mermaid.min.css");

  .orders-grid-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    max-width: 100%;
  }

  .orders-grid-wrap .gridjs-wrapper {
    border: 0;
    box-shadow: none;
  }

  .orders-grid-wrap .gridjs-table {
    width: 100%;
    border-collapse: collapse !important;
    table-layout: auto;
  }

  .orders-grid-wrap .gridjs-container {
    min-width: max-content;
  }

  .orders-grid-wrap .gridjs-th,
  .orders-grid-wrap .gridjs-td {
    border-color: color-mix(in srgb, var(--border) 58%, transparent);
    vertical-align: middle !important;
    padding: 0.34rem 0.74rem !important;
    line-height: 1.15 !important;
    font-size: 0.88rem !important;
    height: auto !important;
    min-height: 0 !important;
  }

  .orders-grid-wrap .gridjs-th {
    text-align: center !important;
    font-size: 0.9rem !important;
    font-weight: 600;
  }

  .orders-grid-wrap .gridjs-table .gridjs-tbody > .gridjs-tr:nth-of-type(odd) > .gridjs-td {
    background-color: color-mix(in srgb, var(--surface-2) 78%, transparent) !important;
  }

  .orders-grid-wrap .gridjs-table .gridjs-tbody > .gridjs-tr:nth-of-type(even) > .gridjs-td {
    background-color: color-mix(in srgb, var(--surface-2) 92%, transparent) !important;
  }

  .orders-grid-wrap .orders-status-badge {
    font-size: 0.76rem;
    font-weight: 600;
    color: #fff;
    border: 1px solid transparent;
  }

  .orders-grid-wrap .orders-status-draft {
    background: #6c757d;
    border-color: #6c757d;
  }

  .orders-grid-wrap .orders-status-valid {
    background: #0d6efd;
    border-color: #0d6efd;
  }

  .orders-grid-wrap .orders-status-approved {
    background: #198754;
    border-color: #198754;
  }

  .orders-grid-wrap .orders-status-other {
    background: #dc3545;
    border-color: #dc3545;
  }

  .orders-grid-wrap .orders-actions {
    display: flex;
    gap: 8px;
    flex-wrap: nowrap;
  }

  .orders-grid-wrap .orders-actions .btn {
    padding: 0.23rem 0.5rem !important;
    font-size: 0.76rem !important;
    line-height: 1.12 !important;
    white-space: nowrap;
  }

  .orders-grid-wrap .gridjs-td code {
    font-size: 0.83rem !important;
    line-height: 1 !important;
    padding: 0 !important;
  }

  .orders-grid-wrap .gridjs-td .badge {
    font-size: 0.76rem !important;
    padding: 0.2rem 0.38rem !important;
    line-height: 1 !important;
  }

  .orders-grid-wrap .gridjs-tr {
    height: auto !important;
  }

  .orders-grid-wrap .gridjs-search .gridjs-input {
    max-width: 260px;
    padding: 0.41rem 0.56rem !important;
    font-size: 0.88rem !important;
  }

  @media (max-width: 768px) {
    .orders-grid-wrap .gridjs-container,
    .orders-grid-wrap .gridjs-head,
    .orders-grid-wrap .gridjs-wrapper,
    .orders-grid-wrap .gridjs-table {
      min-width: 980px !important;
    }

    .orders-grid-wrap .gridjs-th,
    .orders-grid-wrap .gridjs-td {
      white-space: nowrap;
    }
  }
</style>

<section class="token-console">
  <% const isSystemAdmin = String(adminRole || "").toLowerCase() === "admin"; %>
  <div class="card app-card token-hero-card">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">SERVICE REPORT</span>
        <h1 class="h4 app-card-title mb-1"><%= t("rs.orders.pageTitle") %></h1>
        <p class="text-muted mb-0"><%= t("rs.orders.pageSubtitle") %></p>
      </div>
      <div class="token-hero-actions">
        <a class="btn btn-outline-secondary btn-sm" href="/admin/hub">Service Hub</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/customers"><%= t("rs.orders.navCustomers") %></a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/equipments"><%= t("rs.orders.navEquipments") %></a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/spare-parts">Spare-Parts</a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/assets"><%= t("rs.orders.navGlobalRegistry") %></a>
        <a class="btn btn-outline-secondary btn-sm" href="/admin/report-service/analytics"><%= t("rs.orders.navAnalytics") %></a>
      </div>
    </div>
  </div>

  <% if (created) { %><div class="alert alert-success mb-0"><%= t("rs.orders.created") %></div><% } %>
  <% if (createError === 'forbidden_admin') { %><div class="alert alert-warning mb-0"><%- t("rs.orders.adminOnlyWarning") %></div><% } %>
  <% if (updated) { %><div class="alert alert-success mb-0"><%= t("rs.orders.updated") %></div><% } %>
  <% if (updateError) { %><div class="alert alert-danger mb-0"><%= t("rs.orders.updateError") %></div><% } %>
  <% if (editLocked) { %><div class="alert alert-warning mb-0"><%= t("rs.orders.editLocked") %></div><% } %>
  <% if (deleted) { %><div class="alert alert-success mb-0"><%= t("rs.orders.deleted") %></div><% } %>

  <div class="modal fade" id="editOrderRegistrationModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <form method="post" id="editOrderRegistrationForm" class="modal-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="modal-header">
            <h5 class="modal-title"><%= t("rs.orders.editModalTitle") %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body row g-2">
            <div class="col-12 col-md-8">
              <label class="form-label"><%= t("rs.title") %></label>
              <input class="form-control" name="title" id="editOrderTitleInput" required />
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label"><%= t("rs.orders.openingDateLabel") %></label>
              <input class="form-control" type="date" name="opening_date" id="editOrderOpeningDateInput" />
            </div>
            <div class="col-12">
              <label class="form-label"><%= t("rs.description") %></label>
              <textarea class="form-control" name="description" id="editOrderDescriptionInput" rows="3"></textarea>
            </div>
            <div class="col-12">
              <label class="form-label"><%= t("rs.orders.techTeamLabel") %> <span class="text-danger">*</span></label>
              <% if (!(allGlobalTechnicians || []).length) { %>
                <div class="alert alert-warning py-2 mb-0"><%= t("rs.orders.noTechnicians") %> <a href="/admin/report-service/assets"><%= t("rs.orders.registerTechHere") %></a></div>
              <% } else { %>
                <div class="d-flex gap-2 mb-2">
                  <select class="form-select" id="editOrderTechSelect">
                    <option value=""><%= t("rs.orders.selectTechnician") %></option>
                    <% (allGlobalTechnicians || []).forEach(function(t) { %>
                      <option value="<%= t.id %>"><%= t.name %><% if (t.role) { %> â€” <%= t.role %><% } %><% if (t.company) { %> (<%= t.company %>)<% } %></option>
                    <% }); %>
                  </select>
                  <button class="btn btn-outline-primary btn-sm" type="button" id="editOrderAddTechBtn" style="white-space:nowrap"><%= t("rs.orders.addTechBtn") %></button>
                </div>
              <% } %>
              <div id="editOrderTechList"></div>
              <div class="form-text text-danger d-none" id="editOrderTechRequired"><%= t("rs.orders.techRequired") %></div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal"><%= t("rs.cancel") %></button>
            <button type="submit" class="btn btn-primary btn-sm"><%= t("rs.saveChanges") %></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <% if (isSystemAdmin) { %>
    <div class="card app-card">
      <div class="card-body">
        <h2 class="h6 app-card-title mb-3"><%= t("rs.orders.newTitle") %></h2>
        <form method="post" action="/admin/report-service/orders" class="row g-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="col-12 col-md-4">
          <label class="form-label"><%= t("rs.orders.customerLabel") %></label>
          <select class="form-select" name="customer_id" required>
            <option value=""><%= t("rs.select") %></option>
            <% customers.forEach((customer) => { %>
              <option value="<%= customer.id %>"><%= customer.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12 col-md-4">
          <label class="form-label"><%= t("rs.orders.siteLabel") %> <span class="text-danger">*</span></label>
          <select class="form-select" name="site_id" id="newOrderSiteSelect" required>
            <option value=""><%= t("rs.orders.selectClientFirst") %></option>
          </select>
        </div>
        <input type="hidden" name="opening_date" value="<%= new Date().toISOString().slice(0, 10) %>" />
        <div class="col-12 col-md-2">
          <label class="form-label"><%= t("rs.status") %></label>
          <select class="form-select" name="status">
            <% ["draft","valid","in_progress","waiting_review","approved","issued","closed","cancelled"].forEach((status) => { %>
              <option value="<%= status %>"><%= status %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-12">
          <label class="form-label"><%= t("rs.title") %></label>
          <input class="form-control" name="title" required />
        </div>
        <div class="col-12">
          <label class="form-label"><%= t("rs.description") %></label>
          <textarea class="form-control" name="description" rows="2"></textarea>
        </div>
        <div class="col-12">
          <label class="form-label"><%= t("rs.orders.techTeamLabel") %> <span class="text-danger">*</span></label>
          <% if (!(allGlobalTechnicians || []).length) { %>
            <div class="alert alert-warning py-2"><%= t("rs.orders.noTechnicians") %> <a href="/admin/report-service/assets"><%= t("rs.orders.registerTechHere") %></a></div>
          <% } else { %>
            <div class="d-flex gap-2 mb-2">
              <select class="form-select" id="newOrderTechSelect">
                <option value=""><%= t("rs.orders.selectTechnician") %></option>
                <% (allGlobalTechnicians || []).forEach(function(t) { %>
                  <option value="<%= t.id %>" data-name="<%= t.name %>" data-role="<%= t.role || '' %>" data-company="<%= t.company || '' %>"><%= t.name %><% if (t.role) { %> — <%= t.role %><% } %><% if (t.company) { %> (<%= t.company %>)<% } %></option>
                <% }); %>
              </select>
              <button class="btn btn-outline-primary btn-sm" type="button" id="newOrderAddTechBtn" style="white-space:nowrap"><%= t("rs.orders.addTechBtn") %></button>
            </div>
            <div id="newOrderTechList"></div>
            <div class="form-text text-danger d-none" id="newOrderTechRequired"><%= t("rs.orders.techRequired") %></div>
          <% } %>
        </div>
          <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-primary btn-sm" type="submit" id="newOrderSubmitBtn"><%= t("rs.orders.btnCreate") %></button>
          </div>
        </form>
      </div>
    </div>
  <% } else { %>
    <div class="alert alert-warning mb-0"><%- t("rs.orders.adminOnlyCreate") %></div>
  <% } %>

  <div class="card app-card">
    <div class="card-body">
      <h2 class="h6 app-card-title mb-3"><%= t("rs.orders.listTitle") %></h2>
      <div class="orders-grid-wrap">
        <div id="ordersGrid"></div>
      </div>
    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/gridjs/dist/gridjs.umd.js"></script>
<script>
  (function () {
    var csrfToken = <%- JSON.stringify(csrfToken || "") %>;
    var i18n = {
      searchPh:       <%- JSON.stringify(t("rs.searchPlaceholder")) %>,
      sortAsc:        <%- JSON.stringify(t("admin.grid.sortAsc")) %>,
      sortDesc:       <%- JSON.stringify(t("admin.grid.sortDesc")) %>,
      previous:       <%- JSON.stringify(t("admin.grid.paginationPrevious")) %>,
      next:           <%- JSON.stringify(t("admin.grid.paginationNext")) %>,
      navigate:       <%- JSON.stringify(t("admin.grid.paginationNavigate")) %>,
      page:           <%- JSON.stringify(t("admin.grid.paginationPage")) %>,
      showing:        <%- JSON.stringify(t("admin.grid.paginationShowing")) %>,
      of:             <%- JSON.stringify(t("admin.grid.paginationOf")) %>,
      to:             <%- JSON.stringify(t("admin.grid.paginationTo")) %>,
      results:        <%- JSON.stringify(t("admin.grid.paginationResults")) %>,
      loading:        <%- JSON.stringify(t("rs.loading")) %>,
      noRecords:      <%- JSON.stringify(t("rs.noRecords")) %>,
      error:          <%- JSON.stringify(t("rs.error")) %>,
      colCode:        <%- JSON.stringify(t("rs.orders.colCode")) %>,
      colTitle:       <%- JSON.stringify(t("rs.orders.colTitle")) %>,
      colCustomer:    <%- JSON.stringify(t("rs.orders.colCustomer")) %>,
      colSite:        <%- JSON.stringify(t("rs.orders.colSite")) %>,
      colOpening:     <%- JSON.stringify(t("rs.orders.colOpening")) %>,
      colStatus:      <%- JSON.stringify(t("rs.orders.colStatus")) %>,
      colActions:     <%- JSON.stringify(t("rs.orders.colActions")) %>,
      btnEdit:        <%- JSON.stringify(t("rs.orders.btnEdit")) %>,
      btnOpenEditor:  <%- JSON.stringify(t("rs.orders.btnOpenEditor")) %>,
      btnDelete:      <%- JSON.stringify(t("rs.orders.btnDelete")) %>,
      confirmDelete:  <%- JSON.stringify(t("rs.orders.confirmDelete")) %>,
      empty:          <%- JSON.stringify(t("rs.orders.empty")) %>
    };
    var orderTechnicianIdsByOrder = <%- JSON.stringify(orderTechnicianIdsByOrder || {}).replace(/</g, "\\u003c") %>;
    var orders = <%- JSON.stringify((orders || []).map(function (order) {
      return {
        id: order.id,
        code: order.service_order_display || "-",
        title: order.title || "-",
        description: order.description || "",
        customer: order.customer_name || "-",
        site: order.site_name || "-",
        status: order.status || "-",
        opening_date: order.opening_date || "",
        technicianIds: (orderTechnicianIdsByOrder[String(order.id)] || []).map(function(id) { return Number(id); }).filter(function(id) { return Number.isInteger(id) && id > 0; })
      };
    })).replace(/</g, "\\u003c") %>;

    function formatDateShort(iso) {
      if (!iso) return "-";
      var m = String(iso).match(/^(\d{4})-(\d{2})-(\d{2})/);
      if (!m) return iso;
      return m[3] + "/" + m[2] + "/" + m[1];
    }

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function buildActionsHtml(order) {
      var idSafe = encodeURIComponent(String(order.id || ""));
      return ""
        + "<div class=\"orders-actions\">"
        + "<button class=\"btn btn-outline-secondary btn-sm\" type=\"button\" data-order-edit=\"1\" data-order-id=\"" + idSafe + "\">" + escapeHtml(i18n.btnEdit) + "</button>"
        + "<a class=\"btn btn-outline-primary btn-sm\" href=\"/admin/report-service/orders/" + idSafe + "\">" + escapeHtml(i18n.btnOpenEditor) + "</a>"
        + "<form method=\"post\" action=\"/admin/report-service/orders/" + idSafe + "/delete\" class=\"m-0\" onsubmit=\"return confirm(" + JSON.stringify(i18n.confirmDelete) + ");\">"
        + "<input type=\"hidden\" name=\"_csrf\" value=\"" + escapeHtml(csrfToken) + "\" />"
        + "<button class=\"btn btn-outline-danger btn-sm\" type=\"submit\">" + escapeHtml(i18n.btnDelete) + "</button>"
        + "</form>"
        + "</div>";
    }

    function getStatusClass(status) {
      var normalized = String(status || "").toLowerCase().trim();
      if (normalized === "draft") return "orders-status-draft";
      if (normalized === "valid") return "orders-status-valid";
      if (normalized === "approved") return "orders-status-approved";
      return "orders-status-other";
    }

    var gridTarget = document.getElementById("ordersGrid");
    if (!gridTarget || !window.gridjs || !window.gridjs.Grid) return;

    if (!orders.length) {
      gridTarget.innerHTML = "<div class=\"text-center text-muted py-4\">" + escapeHtml(i18n.empty) + "</div>";
      return;
    }

    var data = orders.map(function (order) {
      return {
        code: "<code>" + escapeHtml(order.code) + "</code>",
        title: escapeHtml(order.title),
        customer: escapeHtml(order.customer),
        site: escapeHtml(order.site),
        opening_date: formatDateShort(order.opening_date),
        status: "<span class=\"badge orders-status-badge " + getStatusClass(order.status) + "\">" + escapeHtml(order.status) + "</span>",
        actions: buildActionsHtml(order)
      };
    });

    new window.gridjs.Grid({
      columns: [
        { id: "code", name: i18n.colCode, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "title", name: i18n.colTitle },
        { id: "customer", name: i18n.colCustomer },
        { id: "site", name: i18n.colSite },
        { id: "opening_date", name: i18n.colOpening },
        { id: "status", name: i18n.colStatus, formatter: function (cell) { return window.gridjs.html(cell); } },
        { id: "actions", name: i18n.colActions, sort: false, formatter: function (cell) { return window.gridjs.html(cell); } }
      ],
      data: data,
      search: true,
      sort: true,
      language: {
        search: { placeholder: i18n.searchPh },
        sort: { sortAsc: i18n.sortAsc, sortDesc: i18n.sortDesc },
        pagination: {
          previous: i18n.previous,
          next: i18n.next,
          navigate: function (page, pages) { return i18n.navigate.replace("{page}", page).replace("{pages}", pages); },
          page: function (page) { return i18n.page.replace("{page}", page); },
          showing: i18n.showing,
          of: i18n.of,
          to: i18n.to,
          results: i18n.results
        },
        loading: i18n.loading,
        noRecordsFound: i18n.noRecords,
        error: i18n.error
      },
      pagination: {
        limit: 20,
        summary: false
      }
    }).render(gridTarget);

    var editModalEl = document.getElementById("editOrderRegistrationModal");
    var editForm = document.getElementById("editOrderRegistrationForm");
    var editTitleInput = document.getElementById("editOrderTitleInput");
    var editDescriptionInput = document.getElementById("editOrderDescriptionInput");
    var editTechSelect = document.getElementById("editOrderTechSelect");
    var editAddTechBtn = document.getElementById("editOrderAddTechBtn");
    var editTechList = document.getElementById("editOrderTechList");
    var editTechRequired = document.getElementById("editOrderTechRequired");
    var selectedTechIds = [];

    function getOrderById(orderId) {
      var target = String(orderId || "");
      for (var i = 0; i < orders.length; i += 1) {
        if (String(orders[i].id) === target) return orders[i];
      }
      return null;
    }

    function getTechLabelById(techId) {
      if (!editTechSelect || !editTechSelect.options) return "Tecnico #" + String(techId);
      for (var i = 0; i < editTechSelect.options.length; i += 1) {
        var opt = editTechSelect.options[i];
        if (String(opt.value) === String(techId)) return opt.text || ("Tecnico #" + String(techId));
      }
      return "Tecnico #" + String(techId);
    }

    function refreshEditTechOptions() {
      if (!editTechSelect || !editTechSelect.options) return;
      var used = selectedTechIds.map(function(id) { return String(id); });
      Array.prototype.forEach.call(editTechSelect.options, function(opt) {
        if (!opt.value) return;
        opt.disabled = used.indexOf(String(opt.value)) !== -1;
      });
    }

    function renderEditTechList() {
      if (!editTechList) return;
      editTechList.innerHTML = "";
      if (!selectedTechIds.length) return;
      var table = document.createElement("table");
      table.className = "table table-sm app-table mb-0";
      var tbody = document.createElement("tbody");
      selectedTechIds.forEach(function(techId, idx) {
        var tr = document.createElement("tr");
        tr.innerHTML =
          "<td>" + escapeHtml(getTechLabelById(techId)) + "</td>" +
          "<td style=\"width:1%\">" +
            "<input type=\"hidden\" name=\"technician_ids[]\" value=\"" + escapeHtml(String(techId)) + "\" />" +
            "<button type=\"button\" class=\"btn btn-outline-danger btn-sm\" data-edit-tech-remove=\"" + String(idx) + "\">Remover</button>" +
          "</td>";
        tbody.appendChild(tr);
      });
      table.appendChild(tbody);
      editTechList.appendChild(table);
      editTechList.querySelectorAll("button[data-edit-tech-remove]").forEach(function(btn) {
        btn.addEventListener("click", function() {
          var index = Number(this.getAttribute("data-edit-tech-remove"));
          if (!Number.isInteger(index) || index < 0 || index >= selectedTechIds.length) return;
          selectedTechIds.splice(index, 1);
          renderEditTechList();
          refreshEditTechOptions();
        });
      });
    }

    function openEditRegistrationModal(orderId) {
      var order = getOrderById(orderId);
      if (!order || !editForm || !editTitleInput || !editDescriptionInput || !editModalEl) return;
      var editOpeningDateInput = document.getElementById("editOrderOpeningDateInput");
      editForm.action = "/admin/report-service/orders/" + encodeURIComponent(String(order.id)) + "/update-registration";
      editTitleInput.value = order.title && order.title !== "-" ? order.title : "";
      editDescriptionInput.value = order.description || "";
      if (editOpeningDateInput) editOpeningDateInput.value = order.opening_date || "";
      selectedTechIds = Array.from(new Set((order.technicianIds || []).map(function(id) { return Number(id); }).filter(function(id) { return Number.isInteger(id) && id > 0; })));
      renderEditTechList();
      refreshEditTechOptions();
      if (editTechRequired) editTechRequired.classList.add("d-none");
      if (window.bootstrap && window.bootstrap.Modal) {
        window.bootstrap.Modal.getOrCreateInstance(editModalEl).show();
      }
    }

    if (editAddTechBtn && editTechSelect) {
      editAddTechBtn.addEventListener("click", function() {
        var selectedValue = Number(editTechSelect.value);
        if (!Number.isInteger(selectedValue) || selectedValue <= 0) return;
        if (selectedTechIds.indexOf(selectedValue) !== -1) return;
        selectedTechIds.push(selectedValue);
        editTechSelect.value = "";
        renderEditTechList();
        refreshEditTechOptions();
        if (editTechRequired) editTechRequired.classList.add("d-none");
      });
    }

    if (editForm) {
      editForm.addEventListener("submit", function(e) {
        if (!selectedTechIds.length) {
          e.preventDefault();
          if (editTechRequired) editTechRequired.classList.remove("d-none");
          if (editTechSelect) editTechSelect.focus();
        }
      });
    }

    gridTarget.addEventListener("click", function(evt) {
      var target = evt.target;
      if (!target || !target.closest) return;
      var editBtn = target.closest("button[data-order-edit=\"1\"]");
      if (!editBtn) return;
      evt.preventDefault();
      openEditRegistrationModal(editBtn.getAttribute("data-order-id") || "");
    });
  })();
</script>
<script>
  (function () {
    var allSites = <%- JSON.stringify((sites || []).map(function(s) {
      return { id: s.id, customerId: s.customer_id, label: s.site_name + (s.location ? " — " + s.location : "") };
    })).replace(/</g, "\\u003c") %>;

    var customerSelect = document.querySelector("select[name='customer_id']");
    var siteSelect = document.getElementById("newOrderSiteSelect");
    if (!customerSelect || !siteSelect) return;

    function updateSites() {
      var customerId = Number(customerSelect.value);
      var filtered = customerId ? allSites.filter(function(s) { return Number(s.customerId) === customerId; }) : [];
      siteSelect.innerHTML = "";
      var placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = filtered.length ? "Selecione o site" : (customerId ? "Nenhum site cadastrado para este cliente" : "Selecione um cliente primeiro");
      siteSelect.appendChild(placeholder);
      filtered.forEach(function(s) {
        var opt = document.createElement("option");
        opt.value = s.id;
        opt.textContent = s.label;
        siteSelect.appendChild(opt);
      });
    }

    customerSelect.addEventListener("change", updateSites);
    updateSites();
  })();
</script>
<script>
  (function () {
    var addBtn = document.getElementById("newOrderAddTechBtn");
    var techSelect = document.getElementById("newOrderTechSelect");
    var techList = document.getElementById("newOrderTechList");
    var techRequired = document.getElementById("newOrderTechRequired");
    var submitBtn = document.getElementById("newOrderSubmitBtn");
    if (!addBtn || !techSelect || !techList) return;

    var selected = []; // [{id, label}]

    function render() {
      techList.innerHTML = "";
      if (!selected.length) return;
      var table = document.createElement("table");
      table.className = "table table-sm app-table mb-0";
      var tbody = document.createElement("tbody");
      selected.forEach(function (item, idx) {
        var tr = document.createElement("tr");
        tr.innerHTML =
          "<td>" + escHtml(item.label) + "</td>" +
          "<td style=\"width:1%\">" +
            "<input type=\"hidden\" name=\"technician_ids[]\" value=\"" + encodeURIComponent(item.id) + "\" />" +
            "<button type=\"button\" class=\"btn btn-outline-danger btn-sm\" data-idx=\"" + idx + "\">Remover</button>" +
          "</td>";
        tbody.appendChild(tr);
      });
      table.appendChild(tbody);
      techList.appendChild(table);
      techList.querySelectorAll("button[data-idx]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var i = Number(this.getAttribute("data-idx"));
          selected.splice(i, 1);
          render();
          refreshOptions();
        });
      });
    }

    function refreshOptions() {
      var usedIds = selected.map(function (s) { return s.id; });
      Array.prototype.forEach.call(techSelect.options, function (opt) {
        if (!opt.value) return;
        opt.disabled = usedIds.indexOf(opt.value) !== -1;
      });
    }

    function escHtml(str) {
      return String(str || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    addBtn.addEventListener("click", function () {
      var opt = techSelect.options[techSelect.selectedIndex];
      if (!opt || !opt.value) return;
      var label = opt.text;
      selected.push({ id: opt.value, label: label });
      techSelect.value = "";
      render();
      refreshOptions();
      if (techRequired) techRequired.classList.add("d-none");
    });

    var form = addBtn.closest("form");
    if (form) {
      form.addEventListener("submit", function (e) {
        if (techRequired && selected.length === 0) {
          e.preventDefault();
          techRequired.classList.remove("d-none");
          techSelect.focus();
        }
      });
    }
  })();
</script>

