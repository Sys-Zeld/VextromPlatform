<%- include("partials/head", { pageTitle }) %>

<div class="card app-card mb-4">
  <div class="card-body d-flex justify-content-between align-items-center gap-2 flex-wrap">
    <div>
      <h1 class="h4 app-card-title mb-1"><%= t("admin.publicTokenLinksTitle") %></h1>
      <p class="text-muted mb-0"><%= t("admin.publicTokenLinksSubtitle") %></p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a class="btn btn-outline-secondary btn-sm" href="/admin/maintenance"><%= t("admin.backToMaintenanceButton") %></a>
      <a class="btn btn-outline-primary btn-sm" href="/admin/tokens"><%= t("admin.backToTokensButton") %></a>
    </div>
  </div>
</div>

<% if (created) { %>
  <div class="alert alert-success"><%= t("admin.publicTokenLinkCreated") %></div>
<% } %>
<% if (toggled) { %>
  <div class="alert alert-success"><%= t("admin.publicTokenLinkUpdated") %></div>
<% } %>
<% if (deleted) { %>
  <div class="alert alert-success"><%= t("admin.publicTokenLinkDeleted") %></div>
<% } %>
<% if (flashError) { %>
  <div class="alert alert-danger"><%= flashError %></div>
<% } %>

<div class="card app-card mb-4">
  <div class="card-body">
    <h2 class="h6 app-card-title mb-2"><%= t("admin.publicTokenLinkCreateTitle") %></h2>
    <p class="text-muted mb-3"><%= t("admin.publicTokenHelp", { max: publicTokenMaxPerWindow, hours: publicTokenWindowHours }) %></p>
    <form method="post" action="/admin/public-token-links/create" class="row g-3 align-items-end">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="col-12 col-lg-8">
        <label for="profile_id" class="form-label"><%= t("admin.profileSelectLabel") %></label>
        <select id="profile_id" name="profile_id" class="form-select <%= formErrors.profile_id ? 'is-invalid' : '' %>" required>
          <option value=""><%= t("admin.profileManualOption") %></option>
          <% profiles.forEach((profile) => { %>
            <option value="<%= profile.id %>" <%= String(formValues.profile_id || '') === String(profile.id) ? 'selected' : '' %>>
              <%= profile.name %>
            </option>
          <% }) %>
        </select>
        <% if (formErrors.profile_id) { %><div class="invalid-feedback d-block"><%= formErrors.profile_id %></div><% } %>
      </div>
      <div class="col-12 col-lg-4">
        <button class="btn btn-primary w-100" type="submit"><%= t("admin.publicTokenLinkCreateButton") %></button>
      </div>
    </form>
  </div>
</div>

<div class="card app-card">
  <div class="card-body">
    <h2 class="h6 app-card-title mb-3"><%= t("admin.publicTokenLinksListTitle") %></h2>
    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0 app-table">
        <thead>
          <tr>
            <th><%= t("admin.publicTokenLinksTableProfile") %></th>
            <th><%= t("admin.publicTokenLinksTableLink") %></th>
            <th><%= t("admin.publicTokenLinksTableStatus") %></th>
            <th><%= t("admin.tableUpdatedAt") %></th>
            <th><%= t("admin.tableActions") %></th>
          </tr>
        </thead>
        <tbody>
          <% if (!links.length) { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4"><%= t("admin.noRecords") %></td>
            </tr>
          <% } %>
          <% links.forEach((link) => { %>
            <% const publicUrl = `${appBaseUrl}/form/public/${link.slug}/start`; %>
            <tr>
              <td><strong><%= link.profileName %></strong></td>
              <td>
                <div><code class="token-code"><%= link.slug %></code></div>
                <div class="small mt-1"><a href="<%= publicUrl %>" target="_blank" rel="noreferrer"><%= publicUrl %></a></div>
              </td>
              <td>
                <span class="badge <%= link.isActive ? 'text-bg-success' : 'text-bg-secondary' %>">
                  <%= link.isActive ? t("admin.publicTokenModuleEnabled") : t("admin.publicTokenModuleDisabled") %>
                </span>
              </td>
              <td><%= link.updatedAt ? new Date(link.updatedAt).toLocaleString(lang === "pt" ? "pt-BR" : "en-US") : "-" %></td>
              <td>
                <div class="d-flex gap-2 flex-wrap">
                  <a class="btn btn-outline-primary btn-sm" href="<%= publicUrl %>" target="_blank" rel="noreferrer"><%= t("admin.publicTokenOpenButton") %></a>
                  <form method="post" action="/admin/public-token-links/<%= link.id %>/toggle">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="btn btn-outline-secondary btn-sm" type="submit">
                      <%= link.isActive ? t("admin.publicTokenDisableButton") : t("admin.publicTokenEnableButton") %>
                    </button>
                  </form>
                  <form method="post" action="/admin/public-token-links/<%= link.id %>/delete" onsubmit="return confirm('<%= t("admin.publicTokenLinkDeleteConfirm") %>')">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button class="btn btn-outline-danger btn-sm" type="submit"><%= t("admin.deleteButton") %></button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include("partials/footer") %>
