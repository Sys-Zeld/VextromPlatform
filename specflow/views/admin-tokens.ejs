<%- include("partials/head", { pageTitle }) %>
<style>
  @import url("https://cdn.jsdelivr.net/npm/gridjs/dist/theme/mermaid.min.css");

  .token-grid-wrap .gridjs-wrapper {
    border: 0;
    box-shadow: none;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .token-grid-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    max-width: 100%;
  }

  .token-grid-wrap .gridjs-table {
    width: 100%;
  }

  .token-grid-wrap .gridjs-container {
    min-width: max-content;
  }

  .token-grid-wrap .gridjs-th,
  .token-grid-wrap .gridjs-td {
    border-color: color-mix(in srgb, var(--border) 58%, transparent);
    vertical-align: top;
    padding: 0.5rem 0.65rem !important;
    line-height: 1.25;
  }

  .token-grid-wrap .gridjs-th {
    text-align: center !important;
  }

  .token-grid-wrap .gridjs-table .gridjs-tbody > .gridjs-tr:nth-of-type(odd) > .gridjs-td {
    background-color: color-mix(in srgb, var(--surface-2) 78%, transparent) !important;
  }

  .token-grid-wrap .gridjs-table .gridjs-tbody > .gridjs-tr:nth-of-type(even) > .gridjs-td {
    background-color: color-mix(in srgb, var(--surface-2) 92%, transparent) !important;
  }

  .token-grid-wrap .token-code {
    display: inline-block;
    max-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    vertical-align: bottom;
  }

  .token-grid-wrap .token-row-actions {
    flex-wrap: nowrap !important;
  }

  .token-grid-wrap .token-row-actions .btn {
    padding: 0.2rem 0.45rem;
    font-size: 0.78rem;
    line-height: 1.2;
  }

  .token-grid-wrap .form-select.form-select-sm {
    min-width: 86px;
    padding-top: 0.15rem;
    padding-bottom: 0.15rem;
    font-size: 0.78rem;
    background: var(--input-bg);
    border-color: var(--input-border);
    color: var(--input-text);
  }

  .token-grid-wrap .token-status-badge {
    font-size: 0.72rem;
  }

  .token-grid-wrap .d-flex.gap-1.mt-2 {
    margin-top: 0.35rem !important;
  }

  @media (max-width: 768px) {
    .token-grid-wrap .gridjs-container,
    .token-grid-wrap .gridjs-head,
    .token-grid-wrap .gridjs-wrapper,
    .token-grid-wrap .gridjs-table {
      min-width: 1080px !important;
    }

    .token-grid-wrap .gridjs-th,
    .token-grid-wrap .gridjs-td {
      white-space: nowrap;
    }
  }

  @media (min-width: 769px) {
    .token-grid-wrap .gridjs-container,
    .token-grid-wrap .gridjs-head,
    .token-grid-wrap .gridjs-wrapper,
    .token-grid-wrap .gridjs-table {
      min-width: 0 !important;
      width: 100% !important;
    }
  }
</style>

<section class="token-console">
  <div class="card app-card token-hero-card mb-4">
    <div class="card-body token-hero-body">
      <div class="token-hero-copy">
        <span class="token-hero-eyebrow">VEXTROM Plataform</span>
        <h1 class="h4 app-card-title mb-1"><%= t("admin.pageTitle") %></h1>
        <p class="text-muted mb-0"><%= t("admin.pageSubtitle") %></p>
      </div>
      <div class="token-hero-actions">
        <a class="btn btn-primary btn-sm" href="/admin/clients/new"><%= t("admin.newClientButton") %></a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/hub">Service Hub</a>
        <a class="btn btn-outline-primary btn-sm" href="/admin/profiles"><%= t("admin.manageProfilesButton") %></a>
        <form method="post" action="/admin/logout">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button class="btn btn-outline-secondary btn-sm" type="submit"><%= t("admin.logoutSessionButton") %></button>
        </form>
      </div>
    </div>
  </div>

  <% if (deleted) { %>
    <div class="alert alert-success token-feedback"><%= t("admin.deletedSuccess") %></div>
  <% } %>
  <% if (saved) { %>
    <div class="alert alert-success token-feedback"><%= t("admin.clientConfigSaved") %></div>
  <% } %>
  <% if (tokenStatusSaved) { %>
    <div class="alert alert-success token-feedback">Status do token atualizado com sucesso.</div>
  <% } %>
  <% if (imported) { %>
    <div class="alert alert-success token-feedback"><%= t("admin.tokenImportApplied") %></div>
  <% } %>

  <div class="card app-card token-search-card">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
        <h2 class="h6 app-card-title mb-0">Gerenciamento de tokens</h2>
        <span class="badge text-bg-secondary" id="tokens-count">Total: 0</span>
      </div>
      <div class="token-grid-wrap">
        <div id="tokensGrid"></div>
      </div>
    </div>
  </div>
  </div>

  <div class="card app-card token-import-card mt-4" id="token-import-card" tabindex="-1">
    <div class="card-body">
      <div class="token-import-header">
        <h2 class="h6 app-card-title mb-2"><%= t("admin.tokenImportTitle") %></h2>
        <p class="text-muted mb-0"><%= t("admin.tokenImportSubtitle") %></p>
      </div>
      <% if (importJsonResult) { %>
        <div class="alert <%= importJsonResult.status === 'found' ? 'alert-info' : 'alert-warning' %> token-import-feedback">
          <div><%= importJsonResult.message %></div>
          <% if (importJsonResult.status === 'found') { %>
            <div class="mt-3 d-flex gap-2 flex-wrap">
              <a class="btn btn-outline-secondary btn-sm" href="<%= importJsonResult.reviewUrl %>"><%= t("admin.tokenImportOpenExisting") %></a>
              <a class="btn btn-outline-primary btn-sm" href="<%= importJsonResult.editUrl %>"><%= t("admin.tokenImportOpenEdit") %></a>
              <form method="post" action="/admin/tokens/import-json" onsubmit="return confirm('<%= t("admin.tokenImportConfirmUpdate") %>')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="import_action" value="apply_existing" />
                <textarea name="json_payload" hidden><%= importJsonPayload || '' %></textarea>
                <button class="btn btn-primary btn-sm" type="submit"><%= t("admin.tokenImportApplyExisting") %></button>
              </form>
            </div>
          <% } %>
          <% if (importJsonResult.status === 'missing' && importJsonResult.canCreate) { %>
            <div class="mt-3 d-flex gap-2 flex-wrap">
              <form method="post" action="/admin/tokens/import-json" onsubmit="return confirm('<%= t("admin.tokenImportConfirmCreate") %>')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <input type="hidden" name="import_action" value="create_new" />
                <textarea name="json_payload" hidden><%= importJsonPayload || '' %></textarea>
                <button class="btn btn-primary btn-sm" type="submit"><%= t("admin.tokenImportCreateNew") %></button>
              </form>
            </div>
          <% } %>
        </div>
      <% } %>
      <form method="post" action="/admin/tokens/import-json" class="token-import-form" id="admin-token-json-import-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="hidden" name="import_action" value="inspect" />
        <input type="hidden" name="json_payload" id="admin-token-json-payload" />
        <div class="token-import-input">
          <label for="admin-token-json-file" class="form-label"><%= t("admin.tokenImportFile") %></label>
          <input id="admin-token-json-file" class="form-control" type="file" accept=".json,application/json" required />
        </div>
        <div class="token-import-action">
          <button class="btn btn-outline-primary" type="submit"><%= t("admin.tokenImportInspect") %></button>
        </div>
      </form>
    </div>
  </div>
</section>
</div>

<script src="https://cdn.jsdelivr.net/npm/gridjs/dist/gridjs.umd.js"></script>
<script>
  (function () {
    var csrfToken = <%- JSON.stringify(csrfToken || "") %>;
    var gridRows = <%- JSON.stringify((rows || []).map(function (row) {
      return {
        id: row.id,
        token: row.token || "",
        purchaser: row.purchaser || "",
        purchaserContact: row.purchaserContact || "",
        profileName: row.profileName || "",
        status: row.status || "",
        updatedAt: row.updatedAt || null
      };
    })).replace(/</g, "\\u003c") %>;
    var labels = <%- JSON.stringify({
      tableToken: t("admin.tableToken"),
      tableBuyer: t("admin.tableBuyer"),
      tableProfile: t("admin.tableProfile"),
      tableStatus: t("admin.tableStatus"),
      tableUpdatedAt: t("admin.tableUpdatedAt"),
      tableActions: t("admin.tableActions"),
      viewButton: t("admin.viewButton"),
      clientConfigButton: t("admin.clientConfigButton"),
      deleteButton: t("admin.deleteButton"),
      noRecords: t("admin.noRecords"),
      saveStatusButton: "Salvar",
      statusAriaLabel: "Status do token",
      confirmDelete: t("admin.confirmDelete"),
      gridSearchPlaceholder: t("admin.grid.searchPlaceholder"),
      gridSortAsc: t("admin.grid.sortAsc"),
      gridSortDesc: t("admin.grid.sortDesc"),
      gridPaginationPrevious: t("admin.grid.paginationPrevious"),
      gridPaginationNext: t("admin.grid.paginationNext"),
      gridPaginationNavigate: t("admin.grid.paginationNavigate"),
      gridPaginationPage: t("admin.grid.paginationPage"),
      gridPaginationShowing: t("admin.grid.paginationShowing"),
      gridPaginationOf: t("admin.grid.paginationOf"),
      gridPaginationTo: t("admin.grid.paginationTo"),
      gridPaginationResults: t("admin.grid.paginationResults"),
      gridLoading: t("admin.grid.loading"),
      gridNoRecordsFound: t("admin.grid.noRecordsFound"),
      gridError: t("admin.grid.error")
    }) %>;
    var locale = <%- JSON.stringify(lang === "pt" ? "pt-BR" : "en-US") %>;

    function escapeHtml(value) {
      return String(value || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    function normalizeStatus(status) {
      var value = String(status || "").toLowerCase();
      if (value === "sent") return "send";
      if (value === "send" || value === "closed") return value;
      return "draft";
    }

    function statusBadgeClass(status) {
      if (status === "send") return "text-bg-primary";
      if (status === "closed") return "text-bg-dark";
      return "text-bg-secondary";
    }

    function buildStatusOptions(current) {
      var options = ["draft", "send", "closed"];
      return options.map(function (value) {
        return "<option value=\"" + value + "\"" + (value === current ? " selected" : "") + ">" + value + "</option>";
      }).join("");
    }

    function formatUpdatedAt(value) {
      if (!value) return "-";
      var date = new Date(value);
      if (Number.isNaN(date.getTime())) return "-";
      return date.toLocaleString(locale);
    }

    function buildStatusHtml(row) {
      var currentStatus = normalizeStatus(row.status);
      return ""
        + "<span class=\"badge " + statusBadgeClass(currentStatus) + " token-status-badge\">" + escapeHtml(currentStatus) + "</span>"
        + "<form method=\"post\" action=\"/admin/tokens/" + encodeURIComponent(row.id) + "/status\" class=\"d-flex gap-1 mt-2\">"
        + "<input type=\"hidden\" name=\"_csrf\" value=\"" + escapeHtml(csrfToken) + "\" />"
        + "<select class=\"form-select form-select-sm\" name=\"status\" aria-label=\"" + escapeHtml(labels.statusAriaLabel) + "\">"
        + buildStatusOptions(currentStatus)
        + "</select>"
        + "<button class=\"btn btn-outline-primary btn-sm\" type=\"submit\">" + escapeHtml(labels.saveStatusButton) + "</button>"
        + "</form>";
    }

    function buildActionsHtml(row) {
      var tokenSafe = encodeURIComponent(String(row.token || ""));
      var idSafe = encodeURIComponent(String(row.id || ""));
      var confirmText = String(labels.confirmDelete || "")
        .replace(/\\/g, "\\\\")
        .replace(/'/g, "\\'")
        .replace(/\r?\n/g, " ");
      return ""
        + "<div class=\"d-flex gap-2 flex-wrap token-row-actions\">"
        + "<a class=\"btn btn-outline-primary btn-sm\" href=\"/form/" + tokenSafe + "/review\">" + escapeHtml(labels.viewButton) + "</a>"
        + "<a class=\"btn btn-outline-secondary btn-sm\" href=\"/admin/tokens/" + idSafe + "/config\">" + escapeHtml(labels.clientConfigButton) + "</a>"
        + "<form method=\"post\" action=\"/admin/tokens/" + idSafe + "/delete\" onsubmit=\"return confirm('" + confirmText + "')\">"
        + "<input type=\"hidden\" name=\"_csrf\" value=\"" + escapeHtml(csrfToken) + "\" />"
        + "<button class=\"btn btn-outline-danger btn-sm\" type=\"submit\">" + escapeHtml(labels.deleteButton) + "</button>"
        + "</form>"
        + "</div>";
    }

    var tokensGrid = document.getElementById("tokensGrid");
    var tokensCount = document.getElementById("tokens-count");
    if (tokensCount) {
      tokensCount.textContent = "Total: " + String(gridRows.length);
    }
    if (tokensGrid && window.gridjs && window.gridjs.Grid) {
      if (!gridRows.length) {
        tokensGrid.innerHTML = "<div class=\"text-center text-muted py-4\">" + escapeHtml(labels.noRecords) + "</div>";
      } else {
        var formattedRows = gridRows.map(function (row) {
          return {
            token: "<code class=\"token-code\" title=\"" + escapeHtml(row.token) + "\">" + escapeHtml(row.token) + "</code>",
            buyer: "<span class=\"token-cell-strong\">" + escapeHtml(row.purchaser || "-") + "</span>",
            profile: escapeHtml(row.profileName || "-"),
            status: buildStatusHtml(row),
            updatedAt: escapeHtml(formatUpdatedAt(row.updatedAt)),
            actions: buildActionsHtml(row)
          };
        });

        new window.gridjs.Grid({
          columns: [
            { id: "token", name: labels.tableToken, width: "140px", formatter: function (cell) { return window.gridjs.html(cell); } },
            { id: "buyer", name: labels.tableBuyer, formatter: function (cell) { return window.gridjs.html(cell); } },
            { id: "profile", name: labels.tableProfile },
            { id: "status", name: labels.tableStatus, sort: false, formatter: function (cell) { return window.gridjs.html(cell); } },
            { id: "updatedAt", name: labels.tableUpdatedAt },
            { id: "actions", name: labels.tableActions, sort: false, formatter: function (cell) { return window.gridjs.html(cell); } }
          ],
          data: formattedRows,
          search: true,
          sort: true,
          language: {
            search: {
              placeholder: labels.gridSearchPlaceholder
            },
            sort: {
              sortAsc: labels.gridSortAsc,
              sortDesc: labels.gridSortDesc
            },
            pagination: {
              previous: labels.gridPaginationPrevious,
              next: labels.gridPaginationNext,
              navigate: function (page, pages) {
                return labels.gridPaginationNavigate
                  .replace("{page}", String(page))
                  .replace("{pages}", String(pages));
              },
              page: function (page) {
                return labels.gridPaginationPage.replace("{page}", String(page));
              },
              showing: labels.gridPaginationShowing,
              of: labels.gridPaginationOf,
              to: labels.gridPaginationTo,
              results: labels.gridPaginationResults
            },
            loading: labels.gridLoading,
            noRecordsFound: labels.gridNoRecordsFound,
            error: labels.gridError
          },
          pagination: {
            limit: 20,
            summary: false
          }
        }).render(tokensGrid);
      }
    }

    var importForm = document.getElementById("admin-token-json-import-form");
    var importFileInput = document.getElementById("admin-token-json-file");
    var importPayloadInput = document.getElementById("admin-token-json-payload");
    var importCard = document.getElementById("token-import-card");

    <% if (importJsonResult || imported) { %>
      if (importCard) {
        window.requestAnimationFrame(function () {
          importCard.scrollIntoView({ behavior: "smooth", block: "start" });
          importCard.focus({ preventScroll: true });
        });
      }
    <% } %>

    if (!importForm || !importFileInput || !importPayloadInput) return;

    importForm.addEventListener("submit", async function (event) {
      event.preventDefault();
      var file = importFileInput.files && importFileInput.files[0];
      if (!file) return;
      try {
        importPayloadInput.value = await file.text();
        importForm.submit();
      } catch (_err) {
        window.alert("<%= t("admin.tokenImportInvalid") %>");
      }
    });
  })();
</script>

<%- include("partials/footer") %>
