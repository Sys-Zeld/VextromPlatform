<%
  function formatClassicDateTime(value) {
    if (!value) return "-";
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return "-";
    const weekDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
    const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
    const day = String(date.getDate()).padStart(2, "0");
    const hours = String(date.getHours()).padStart(2, "0");
    const minutes = String(date.getMinutes()).padStart(2, "0");
    const seconds = String(date.getSeconds()).padStart(2, "0");
    return `${weekDays[date.getDay()]} ${months[date.getMonth()]} ${day} ${date.getFullYear()} ${hours}:${minutes}:${seconds}`;
  }
%>

<article class="report-doc" id="report-pages">
  <section class="report-page report-page-cover">
    <div class="topbar">
      <div class="brand-left">
        <img src="<%= brandAssets?.logoVextrom || '/public/img/logo-vextrom.svg' %>" alt="Logo Vextrom" />
      </div>
      <div class="brand-right">
        <% if (brandAssets?.logoChloride) { %>
          <img src="<%= brandAssets.logoChloride %>" alt="Logo Chloride" />
        <% } else { %>
          <div class="report-brand-slot">Espaco para logo Chloride</div>
        <% } %>
      </div>
    </div>
    <div class="cover-center">
      <img class="cover-logo-image" src="<%= brandAssets?.logoVextrom || '/public/img/logo-vextrom.svg' %>" alt="Vextrom" />
      <div class="cover-sub">atmosferas sob controle</div>
      <div class="cover-title"><%= report?.title || "SERVICE REPORT" %></div>
      <div class="report-cover-subtitle"><strong>Cliente:</strong> <%= customer?.name || "-" %></div>
      <div class="report-cover-subtitle"><strong>Site:</strong> <%= site?.site_name || "-" %></div>
      <div class="report-cover-subtitle"><%= order?.service_order_display || "-" %></div>
      <div class="report-cover-subtitle"><strong>Relatorio:</strong> <%= report?.report_number || "-" %> / Rev. <%= report?.revision || "-" %></div>
    </div>
  </section>

  <section class="report-page">
    <div class="topbar">
      <div class="brand-left">
        <img src="<%= brandAssets?.logoVextrom || '/public/img/logo-vextrom.svg' %>" alt="Logo Vextrom" />
      </div>
      <div class="brand-right">
        <% if (brandAssets?.logoChloride) { %>
          <img src="<%= brandAssets.logoChloride %>" alt="Logo Chloride" />
        <% } else { %>
          <div class="report-brand-slot">Espaco para logo Chloride</div>
        <% } %>
      </div>
    </div>

    <div class="report-section-title">METADADOS</div>
    <div class="report-meta-grid">
      <div class="report-meta-item"><strong>Executado por</strong><span><%= report?.prepared_by || "-" %></span></div>
      <div class="report-meta-item"><strong>Revisao</strong><span><%= report?.revision || "-" %></span></div>
      <div class="report-meta-item"><strong>OS</strong><span><%= order?.service_order_number || "-" %></span></div>
      <div class="report-meta-item"><strong>Atualizado em</strong><span><%= formatClassicDateTime(report?.last_modified_at || generatedAt) %></span></div>
    </div>

    <div class="report-section-title mt-4">SUMARIO</div>
    <ul class="report-toc">
      <% if (!toc || !toc.length) { %>
        <li>
          <span>Sem capitulos.</span>
          <span class="report-toc-page">-</span>
        </li>
      <% } %>
      <% (toc || []).forEach((item) => { %>
        <li>
          <a class="report-toc-link report-toc-title" href="#<%= item.anchorId %>"><%= item.title %></a>
          <span class="report-toc-dots"></span>
          <a class="report-toc-link report-toc-page" href="#<%= item.anchorId %>"><%= item.startPage %></a>
        </li>
      <% }) %>
    </ul>
  </section>

  <% (orderedVisibleSections || []).forEach((section, index) => { %>
    <%
      const isLastSection = index === (orderedVisibleSections || []).length - 1;
      const validSigs = isLastSection ? (signatures || []).filter(function(s) { return s.signer_name || s.signature_data; }) : [];
    %>
    <section
      class="report-page"
      data-auto-paginate="true"
      id="<%= section.anchor_id || ('section-' + (index + 1)) %>"
    >
      <div class="topbar">
        <div class="brand-left">
          <img src="<%= brandAssets?.logoVextrom || '/public/img/logo-vextrom.svg' %>" alt="Logo Vextrom" />
        </div>
        <div class="brand-right">
          <% if (brandAssets?.logoChloride) { %>
            <img src="<%= brandAssets.logoChloride %>" alt="Logo Chloride" />
          <% } else { %>
            <div class="report-brand-slot">Espaco para logo Chloride</div>
          <% } %>
        </div>
      </div>

      <div class="report-page-content">
        <div class="section-title">
          <span class="section-title-number"><%= index + 1 %>.</span>
          <div class="report-section-title-rich">
            <%- section.section_title_html_preview || section.section_title_html || section.section_title || "CAPITULO" %>
          </div>
        </div>
        <div class="rich-output">
          <%- section.content_html_preview || section.content_html || "<p><br></p>" %>
        </div>

        <% if (validSigs.length > 0) { %>
          <div class="report-signatures-block">
            <div class="report-signatures-label">ASSINATURAS</div>
            <div class="report-signatures-row">
              <% validSigs.forEach(function(sig) { %>
                <div class="report-signature-item">
                  <div class="report-signature-canvas">
                    <% if (sig.signature_data && sig.signature_data.indexOf('data:') === 0) { %>
                      <img class="report-signature-img" src="<%= sig.signature_data %>" alt="Assinatura" />
                    <% } %>
                  </div>
                  <div class="report-signature-line-hr"></div>
                  <div class="report-signature-meta">
                    <div class="report-signature-name"><%= sig.signer_name || '-' %></div>
                    <% if (sig.signer_role) { %><div class="report-signature-detail"><%= sig.signer_role %></div><% } %>
                    <% if (sig.signer_company) { %><div class="report-signature-detail"><%= sig.signer_company %></div><% } %>
                    <% if (sig.signed_at) { %><div class="report-signature-date"><%= new Date(sig.signed_at).toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric' }) %></div><% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    </section>
  <% }) %>
</article>
